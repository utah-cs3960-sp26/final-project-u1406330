	id: string,
	displayName: string,
	geodeSeconds: number,
	displayColor: Color3,
	rolls: { { resourceId: string, weight: number } }
)
	return {
		id = id,
		displayName = displayName,
		geodeSeconds = geodeSeconds,
		gridSize = {
			width = 2,
			height = 2,
		},
		displayColor = displayColor,
		rolls = rolls,
	}
end

