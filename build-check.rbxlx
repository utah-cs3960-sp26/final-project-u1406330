		{ kind = "body", x = 0.00, z = 0.00, height = 0.58, width = 1.78, depth = 1.12, yaw = 0, tint = 0.10 },
		{ kind = "top", x = 0.00, z = 0.00, height = 0.22, width = 1.38, depth = 0.74, yaw = 0, tint = 0.22 },
		{ kind = "edge", x = 0.00, z = -0.42, height = 0.16, width = 1.10, depth = 0.08, yaw = 0, tint = 0.34 },
		{ kind = "edge", x = 0.00, z = 0.42, height = 0.16, width = 1.10, depth = 0.08, yaw = 0, tint = 0.18 },
	},
	artifact = {
		{ x = -0.05, z = -0.04, height = 2.35, width = 0.58, depth = 0.68, yaw = 4, pitch = -5, roll = -4, tint = 0.24 },
		{ x = -0.56, z = 0.06, height = 1.74, width = 0.42, depth = 0.50, yaw = -24, pitch = 7, roll = 8, tint = 0.08 },
		{ x = 0.52, z = 0.10, height = 1.58, width = 0.38, depth = 0.48, yaw = 26, pitch = -8, roll = -8, tint = 0.34 },
		{ x = 0.18, z = 0.48, height = 1.12, width = 0.30, depth = 0.38, yaw = 42, pitch = 5, roll = -4, tint = 0.18 },
		{ x = -0.32, z = -0.44, height = 1.02, width = 0.30, depth = 0.36, yaw = -38, pitch = -5, roll = 5, tint = 0.12 },
	},
	cluster = {
		{ x = -0.14, z = -0.02, height = 2.02, width = 0.54, depth = 0.62, yaw = -8, pitch = -3, roll = 4, tint = 0.18 },
		{ x = -0.62, z = 0.04, height = 1.55, width = 0.42, depth = 0.52, yaw = -32, pitch = 8, roll = 9, tint = 0.06 },
		{ x = 0.48, z = -0.06, height = 1.45, width = 0.40, depth = 0.48, yaw = 24, pitch = -8, roll = -7, tint = 0.30 },
		{ x = 0.08, z = 0.44, height = 1.18, width = 0.34, depth = 0.42, yaw = 40, pitch = 6, roll = -2, tint = 0.20 },
		{ x = -0.34, z = -0.46, height = 0.96, width = 0.30, depth = 0.36, yaw = -46, pitch = -5, roll = 6, tint = 0.10 },
	},
	gemstone = {
		{ x = -0.02, z = 0.00, height = 1.90, width = 0.50, depth = 0.60, yaw = 0, pitch = -3, roll = 2, tint = 0.18 },
		{ x = -0.46, z = 0.06, height = 1.34, width = 0.36, depth = 0.44, yaw = -28, pitch = 8, roll = 8, tint = 0.04 },
		{ x = 0.43, z = -0.02, height = 1.24, width = 0.34, depth = 0.42, yaw = 24, pitch = -7, roll = -6, tint = 0.30 },
		{ x = 0.08, z = 0.40, height = 0.92, width = 0.28, depth = 0.34, yaw = 38, pitch = 4, roll = -3, tint = 0.16 },
	},
}

local function normalizeVisualKey(value: any): string
	if value == nil then
		return ""
	end

	local text = string.lower(tostring(value))
	text = text:gsub("[%s%-]+", "_")
	text = text:gsub("[^%w_]", "")
	return text
end

local function blendColor(baseColor: Color3, targetColor: Color3, alpha: number): Color3
	return baseColor:Lerp(targetColor, alpha)
end

local function cloneDefinition(definition: any): any
	local clone = {}

	for key, value in pairs(definition) do
		clone[key] = value
	end

	return clone
end

local function cloneDefinitions(definitions: { [number]: any }): { [number]: any }
	local cloned = table.create(#definitions)

	for index, definition in ipairs(definitions) do
		cloned[index] = cloneDefinition(definition)
	end

	return cloned
end

local function combineHashes(...): number
	local hash = 5381

	for index = 1, select("#", ...) do
		local valueHash = ResourceVisuals.getStringHash(select(index, ...))
		hash = ((hash * 33) + valueHash + index) % MAX_HASH_VALUE
	end

	return hash
end

local function hashToUnit(hash: number): number
	return (hash % 1000000) / 1000000
end

local function sampleUnit(seed: number, channel: string, index: number): number
	return hashToUnit(combineHashes(seed, channel, index))
end

local function sampleSigned(seed: number, channel: string, index: number, amplitude: number): number
	return ((sampleUnit(seed, channel, index) * 2) - 1) * amplitude
end

local function sampleRange(seed: number, channel: string, index: number, minValue: number, maxValue: number): number
	return minValue + ((maxValue - minValue) * sampleUnit(seed, channel, index))
end

local function resolveVariantDefinitions(variantId: string?): { [number]: any }
	local normalizedVariant = normalizeVisualKey(variantId)
	return STATIC_VARIANT_DEFINITIONS[normalizedVariant] or STATIC_VARIANT_DEFINITIONS.gemstone
end

local function getProceduralRules(variantId: string?): any
	local normalizedVariant = normalizeVisualKey(variantId)
	return VARIANT_PROCEDURAL_RULES[normalizedVariant] or VARIANT_PROCEDURAL_RULES.gemstone
end

local function getProfileOverride(resourceTypeId: string?): any?
	local resourceKey = normalizeVisualKey(resourceTypeId)
	return RESOURCE_PROFILE_OVERRIDES[resourceKey]
end

local function getSourceDefinitionForIndex(variantId: string, baseDefinitions: { [number]: any }, index: number): any
	if index <= #baseDefinitions then
		return baseDefinitions[index]
	end

	-- Extra ingot pieces should stay as trims so the silhouette remains a single grounded bar.
	if variantId == "ingot" then
		local edgeDefinitions = { baseDefinitions[3], baseDefinitions[4], baseDefinitions[2] }
		return edgeDefinitions[((index - #baseDefinitions - 1) % #edgeDefinitions) + 1]
	end

	-- Extra eldritch pieces should orbit around the center instead of duplicating the anchor shard.
	if variantId == "eldritch" then
		local orbitIndex = (((index - #baseDefinitions) - 1) % (#baseDefinitions - 1)) + 2
		return baseDefinitions[orbitIndex]
	end

	return baseDefinitions[((index - 1) % #baseDefinitions) + 1]
end

function ResourceVisuals.getStringHash(value: any): number
	local hash = 0
	local text = tostring(value or "")

	for index = 1, #text do
		hash = (hash * 33 + string.byte(text, index)) % MAX_HASH_VALUE
	end

	return hash
end

function ResourceVisuals.getRarityRank(rarity: string?): number
	return RESOURCE_RARITY_ORDER[rarity or "Common"] or 1
end

function ResourceVisuals.getResourceRarityScale(rarity: string?): number
	local rarityRank = ResourceVisuals.getRarityRank(rarity)
	return 0.92 + ((rarityRank - 1) * 0.14)
end

function ResourceVisuals.getResourceVariantShape(resourceTypeId: string?, resourceDefinition: any?): string
	local resourceKey = normalizeVisualKey(resourceTypeId)
	local rarity = if resourceDefinition ~= nil and resourceDefinition.rarity ~= nil then resourceDefinition.rarity else "Common"
	local rarityRank = ResourceVisuals.getRarityRank(rarity)
	local explicitVariant = if resourceDefinition ~= nil and type(resourceDefinition.visualVariant) == "string"
		then resourceDefinition.visualVariant
		else nil
	local variantId = explicitVariant or RESOURCE_TYPE_VARIANTS[resourceKey] or "gemstone"
	local override = getProfileOverride(resourceTypeId)
	if override ~= nil and type(override.variantId) == "string" then
		variantId = override.variantId
	end

	if variantId == "gemstone" then
		if resourceKey:find("cluster", 1, true) ~= nil or rarityRank == 3 then
			variantId = "cluster"
		end

		if resourceKey:find("core", 1, true) ~= nil
			or resourceKey:find("shard", 1, true) ~= nil
			or rarityRank >= 4
		then
			variantId = "artifact"
		end
	end

	return variantId
end

function ResourceVisuals.getOreCrystalDefinitions(variantId: string?): { [number]: any }
	return cloneDefinitions(resolveVariantDefinitions(variantId))
end

function ResourceVisuals.getProceduralSeed(stableVisualId: any, resourceTypeId: string?, variantId: string?): number
	local visualKey = stableVisualId
	local normalizedVariant = normalizeVisualKey(variantId)
	if STATIC_VARIANT_DEFINITIONS[normalizedVariant] == nil then
		normalizedVariant = "gemstone"
	end

	if visualKey == nil or tostring(visualKey) == "" then
		visualKey = resourceTypeId or normalizedVariant or "resource"
	end

	return combineHashes(visualKey, resourceTypeId or "resource", normalizedVariant)
end

function ResourceVisuals.getProceduralCrystalDefinitions(
	variantId: string?,
	stableVisualId: any,
	resourceTypeId: string?
): { [number]: any }
	local normalizedVariant = normalizeVisualKey(variantId)
	if normalizedVariant == "" or STATIC_VARIANT_DEFINITIONS[normalizedVariant] == nil then
		normalizedVariant = "gemstone"
	end

	local baseDefinitions = resolveVariantDefinitions(normalizedVariant)
	local proceduralRules = getProceduralRules(normalizedVariant)
	local proceduralSeed = ResourceVisuals.getProceduralSeed(stableVisualId, resourceTypeId, normalizedVariant)
	local countRange = proceduralRules.maxCount - proceduralRules.minCount
	local targetCount = proceduralRules.minCount + math.floor(sampleUnit(proceduralSeed, "count", 1) * (countRange + 1))
	local definitions = table.create(targetCount)

	for index = 1, targetCount do
		local source = cloneDefinition(getSourceDefinitionForIndex(normalizedVariant, baseDefinitions, index))
		local isPrimaryIngotPiece = normalizedVariant == "ingot" and (source.kind == "body" or source.kind == "top")
		local positionAmplitude = if isPrimaryIngotPiece then proceduralRules.positionJitter * 0.35 else proceduralRules.positionJitter
		local rotationAmplitude = if normalizedVariant == "ingot" then proceduralRules.rotationJitter * 0.35 else proceduralRules.rotationJitter

		-- We vary around the static family definitions instead of replacing them so each family keeps its readable silhouette.
		source.x = source.x + sampleSigned(proceduralSeed, "x", index, positionAmplitude)
		source.z = source.z + sampleSigned(proceduralSeed, "z", index, positionAmplitude)
		source.height = math.max(0.08, source.height * sampleRange(proceduralSeed, "height", index, 1 - proceduralRules.heightJitter, 1 + proceduralRules.heightJitter))
		source.width = math.max(0.08, source.width * sampleRange(proceduralSeed, "width", index, 1 - proceduralRules.widthJitter, 1 + proceduralRules.widthJitter))
		source.depth = math.max(0.08, source.depth * sampleRange(proceduralSeed, "depth", index, 1 - proceduralRules.depthJitter, 1 + proceduralRules.depthJitter))
		source.yaw = source.yaw + sampleSigned(proceduralSeed, "yaw", index, rotationAmplitude)
		source.pitch = (source.pitch or 0) + sampleSigned(proceduralSeed, "pitch", index, rotationAmplitude * 0.75)
		source.roll = (source.roll or 0) + sampleSigned(proceduralSeed, "roll", index, rotationAmplitude * 0.75)
		source.tint = math.clamp((source.tint or 0) + sampleSigned(proceduralSeed, "tint", index, proceduralRules.tintJitter), 0, 0.75)
		definitions[index] = source
	end

	return definitions
end

function ResourceVisuals.getPlacedPhysicalScale(sizeId: string?, sizeValue: number?): number
	return SizeRules.getResourceVisualScale(sizeId, sizeValue)
end

function ResourceVisuals.getPlacedRootSize(sizeId: string?, sizeValue: number?): Vector3
	return PLACED_RESOURCE_BASE_SIZE * ResourceVisuals.getPlacedPhysicalScale(sizeId, sizeValue)
end

function ResourceVisuals.getPlacedBaseHeight(sizeId: string?, sizeValue: number?): number
	return PLACED_RESOURCE_BASE_HEIGHT * ResourceVisuals.getPlacedPhysicalScale(sizeId, sizeValue)
end

function ResourceVisuals.resolvePlacedVisualProfile(
	resourceTypeId: string?,
	traitId: string?,
	sizeId: string?,
	sizeValue: number?,
	stableVisualId: any
)
	return ResourceVisuals.resolveRevealProfile(resourceTypeId, traitId, sizeId, sizeValue, stableVisualId)
end

function ResourceVisuals.resolveRevealProfile(
	resourceTypeId: string?,
	traitId: string?,
	sizeId: string?,
	sizeValue: number?,
	stableVisualId: any
)
	local resourceDefinition = if resourceTypeId ~= nil then Resources[resourceTypeId] else nil
	local rarity = if resourceDefinition ~= nil and resourceDefinition.rarity ~= nil then resourceDefinition.rarity else "Common"
	local baseColor = if resourceDefinition ~= nil and resourceDefinition.color ~= nil
		then resourceDefinition.color
		else RESOURCE_RARITY_ACCENTS[rarity] or Color3.fromRGB(240, 240, 255)
	local rarityRank = ResourceVisuals.getRarityRank(rarity)
	local accentColor = blendColor(baseColor, RESOURCE_RARITY_ACCENTS[rarity] or baseColor, math.clamp(0.15 + (rarityRank * 0.12), 0, 0.65))
	local glowColor = blendColor(accentColor, Color3.fromRGB(255, 255, 255), 0.25)
	local traitDefinition = if traitId ~= nil then Traits[traitId] else nil
	local override = getProfileOverride(resourceTypeId)
	if override ~= nil then
		if type(override.baseColor) == "Color3" then
			baseColor = override.baseColor
		end
		if type(override.accentColor) == "Color3" then
			accentColor = override.accentColor
		end
		if type(override.glowColor) == "Color3" then
			glowColor = override.glowColor
		end
	end
	local traitAccent = if traitDefinition ~= nil and traitDefinition.accentColor ~= nil then traitDefinition.accentColor else accentColor
	local traitGlow = if traitDefinition ~= nil and traitDefinition.glowColor ~= nil then traitDefinition.glowColor else glowColor
	local sizeFactor = SizeRules.getScaleValue(sizeId, sizeValue)
	local visualSizeFactor = SizeRules.getResourceVisualScale(sizeId, sizeValue)
	local burstScale = if traitDefinition ~= nil and type(traitDefinition.burstScale) == "number" then traitDefinition.burstScale else 1
	local shineStrength = if traitDefinition ~= nil and type(traitDefinition.shineStrength) == "number" then traitDefinition.shineStrength else 0.2
	local variantId = ResourceVisuals.getResourceVariantShape(resourceTypeId, resourceDefinition)
	local proceduralId = stableVisualId or resourceTypeId or "resource"
	local proceduralSeed = ResourceVisuals.getProceduralSeed(proceduralId, resourceTypeId, variantId)

	if override ~= nil then
		if type(override.scaleMultiplier) == "number" then
			visualSizeFactor *= override.scaleMultiplier
		end
		if type(override.minScale) == "number" then
			visualSizeFactor = math.max(override.minScale, visualSizeFactor)
		end
		if type(override.maxScale) == "number" then
			visualSizeFactor = math.min(override.maxScale, visualSizeFactor)
		end
		if traitDefinition == nil and type(override.shineStrength) == "number" then
			shineStrength = override.shineStrength
		end
	end

	return {
		resourceTypeId = resourceTypeId,
		displayName = if resourceDefinition ~= nil and resourceDefinition.displayName ~= nil then resourceDefinition.displayName else "Resource",
		rarity = rarity,
		rarityRank = rarityRank,
		variantId = variantId,
		baseColor = baseColor,
		accentColor = accentColor,
		glowColor = glowColor,
		traitAccentColor = traitAccent,
		traitGlowColor = traitGlow,
		sizeId = sizeId or "medium",
		sizeValue = sizeFactor,
		scale = ResourceVisuals.getResourceRarityScale(rarity) * visualSizeFactor,
		burstScale = burstScale,
		shineStrength = shineStrength,
		hash = ResourceVisuals.getStringHash(resourceTypeId or "resource"),
		proceduralId = proceduralId,
		proceduralSeed = proceduralSeed,
		crystalDefinitions = ResourceVisuals.getProceduralCrystalDefinitions(variantId, proceduralId, resourceTypeId),
	}
end

return ResourceVisuals
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="25">
          <Properties>
            <string name="Name">RewardPresentation</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Reward Presentation so gameplay behavior can be reused by the server, client presentation, and specs.

local RewardPresentation = {}

local RarityRanks = {
	Common = 0,
	Uncommon = 1,
	Rare = 2,
	Epic = 3,
	Legendary = 4,
	Mythic = 5,
}

local function getRarityRank(rarity: any): number
	if type(rarity) ~= "string" then
		return 0
	end

	return RarityRanks[rarity] or 0
end

local function getCelebrationTierFromRank(rank: number): number
	return math.max(0, rank)
end

local function getScaleFromTier(tier: number, growthStep: number): number
	if tier <= 0 then
		return 0
	end

	return 1 + (tier * growthStep)
end

function RewardPresentation.getResourceRarityRank(resourceDefinition: any): number
	if resourceDefinition == nil then
		return 0
	end

	return getRarityRank(resourceDefinition.rarity)
end

function RewardPresentation.getResourceCelebrationTier(resourceDefinition: any): number
	return getCelebrationTierFromRank(RewardPresentation.getResourceRarityRank(resourceDefinition))
end

function RewardPresentation.getResourceSlotMachineScale(resourceDefinition: any): number
	local tier = RewardPresentation.getResourceCelebrationTier(resourceDefinition)
	return getScaleFromTier(tier, 0.35)
end

function RewardPresentation.getTraitRarityRank(traitDefinition: any): number
	if traitDefinition == nil then
		return 0
	end

	if type(traitDefinition.rarityRank) == "number" then
		return traitDefinition.rarityRank
	end

	return getRarityRank(traitDefinition.rarity)
end

function RewardPresentation.getTraitCelebrationTier(traitDefinition: any): number
	return getCelebrationTierFromRank(RewardPresentation.getTraitRarityRank(traitDefinition))
end

function RewardPresentation.getTraitSlotMachineScale(traitDefinition: any): number
	local tier = RewardPresentation.getTraitCelebrationTier(traitDefinition)
	return getScaleFromTier(tier, 0.4)
end

function RewardPresentation.getRewardBurstScale(resourceDefinition: any, traitDefinition: any): number
	local resourceScale = RewardPresentation.getResourceSlotMachineScale(resourceDefinition)
	local traitScale = RewardPresentation.getTraitSlotMachineScale(traitDefinition)

	if resourceScale <= 0 and traitScale <= 0 then
		return 0
	end

	return 1 + (resourceScale * 0.6) + (traitScale * 0.4)
end

function RewardPresentation.shouldUseSlotMachineReveal(resourceDefinition: any, traitDefinition: any): boolean
	return RewardPresentation.getResourceCelebrationTier(resourceDefinition) > 0
		or RewardPresentation.getTraitCelebrationTier(traitDefinition) > 0
end

return RewardPresentation
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="26">
          <Properties>
            <string name="Name">ShopRotation</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Shop Rotation so gameplay behavior can be reused by the server, client presentation, and specs.

local ShopRotation = {}

function ShopRotation.getHourlyIndex(nowUnix: number, offerCount: number)
	if offerCount <= 0 then
		return 0
	end

	return (math.floor(nowUnix / 3600) % offerCount) + 1
end

function ShopRotation.getSecondsUntilNextRotation(nowUnix: number): number
	local currentHourStart = math.floor(nowUnix / 3600) * 3600
	local nextHourStart = currentHourStart + 3600
	return math.max(0, nextHourStart - nowUnix)
end

function ShopRotation.getHourlyState(nowUnix: number, offerCount: number)
	return {
		index = ShopRotation.getHourlyIndex(nowUnix, offerCount),
		secondsRemaining = ShopRotation.getSecondsUntilNextRotation(nowUnix),
	}
end

return ShopRotation
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="27">
          <Properties>
            <string name="Name">SizeRoller</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Size Roller so gameplay behavior can be reused by the server, client presentation, and specs.

local SizeRoller = {}

function SizeRoller.getTotalWeight(entries: { any }): number
	local totalWeight = 0

	for _, entry in ipairs(entries) do
		if type(entry) == "table" and type(entry.weight) == "number" and entry.weight > 0 then
			totalWeight += entry.weight
		end
	end

	return totalWeight
end

local function pickWeighted(entries: { any }, roll: number)
	local cursor = 0

	for _, entry in ipairs(entries) do
		local weight = if type(entry) == "table" and type(entry.weight) == "number" then entry.weight else 0
		if weight <= 0 then
			continue
		end

		cursor += weight
		if roll <= cursor then
			return entry
		end
	end

	return entries[#entries]
end

local function nextRandom(rng: Random?): number
	return if rng then rng:NextNumber() else math.random()
end

function SizeRoller.rollScaleValue(entry, rng: Random?): number
	if type(entry) ~= "table" then
		return 1.0
	end

	local minScale = if type(entry.minScale) == "number" then entry.minScale else entry.scaleFactor or 1.0
	local maxScale = if type(entry.maxScale) == "number" then entry.maxScale else entry.scaleFactor or minScale
	if maxScale <= minScale then
		return minScale
	end

	return minScale + (nextRandom(rng) * (maxScale - minScale))
end

function SizeRoller.rollSize(sizeDefinitions: { any }, rng: Random?)
	if #sizeDefinitions == 0 then
		return nil
	end

	local totalWeight = SizeRoller.getTotalWeight(sizeDefinitions)
	if totalWeight <= 0 then
		return nil
	end

	local roll = nextRandom(rng)
	local scaledRoll = math.max(0.000001, roll * totalWeight)
	local result = pickWeighted(sizeDefinitions, scaledRoll)
	if type(result) ~= "table" then
		return result
	end

	local rolled = {}
	for key, value in pairs(result) do
		rolled[key] = value
	end
	rolled.scaleValue = SizeRoller.rollScaleValue(result, rng)
	return rolled
end

return SizeRoller
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="28">
          <Properties>
            <string name="Name">SizeRules</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Size Rules so gameplay behavior can be reused by the server, client presentation, and specs.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Sizes = require(Shared.Config.Sizes)

local SizeRules = {}

local function getGlobalScaleBounds()
	local minScale = math.huge
	local maxScale = -math.huge

	for _, definition in ipairs(Sizes.order) do
		if type(definition.minScale) == "number" then
			minScale = math.min(minScale, definition.minScale)
		end
		if type(definition.maxScale) == "number" then
			maxScale = math.max(maxScale, definition.maxScale)
		end
	end

	if minScale == math.huge then
		minScale = 1.0
	end
	if maxScale == -math.huge then
		maxScale = 1.0
	end

	return minScale, maxScale
end

local GLOBAL_MIN_SCALE, GLOBAL_MAX_SCALE = getGlobalScaleBounds()

local function roundToPlaces(value: number, places: number): number
	local magnitude = 10 ^ places
	return math.floor((value * magnitude) + 0.5) / magnitude
end

function SizeRules.clampScale(scaleValue: number?): number
	if type(scaleValue) ~= "number" then
		return Sizes.medium.scaleFactor or 1.0
	end

	return math.clamp(scaleValue, GLOBAL_MIN_SCALE, GLOBAL_MAX_SCALE)
end

function SizeRules.getDefinitionById(sizeId: string?)
	if type(sizeId) ~= "string" then
		return nil
	end

	return Sizes[sizeId]
end

function SizeRules.getDefinitionForScale(scaleValue: number?)
	local resolvedScale = SizeRules.clampScale(scaleValue)

	for _, definition in ipairs(Sizes.order) do
		local minScale = if type(definition.minScale) == "number" then definition.minScale else definition.scaleFactor or 1.0
		local maxScale = if type(definition.maxScale) == "number" then definition.maxScale else definition.scaleFactor or 1.0
		if resolvedScale >= minScale and resolvedScale <= maxScale then
			return definition
		end
	end

	if resolvedScale <= GLOBAL_MIN_SCALE then
		return Sizes.order[1]
	end

	return Sizes.order[#Sizes.order] or Sizes.medium
end

function SizeRules.resolveDefinition(sizeId: string?, sizeValue: number?)
	if type(sizeValue) == "number" then
		return SizeRules.getDefinitionForScale(sizeValue)
	end

	local definition = SizeRules.getDefinitionById(sizeId)
	if definition ~= nil then
		return definition
	end

	return Sizes.medium
end

function SizeRules.getScaleValue(sizeId: string?, sizeValue: number?): number
	if type(sizeValue) == "number" then
		return SizeRules.clampScale(sizeValue)
	end

	local definition = SizeRules.resolveDefinition(sizeId, nil)
	if definition ~= nil and type(definition.scaleFactor) == "number" then
		return definition.scaleFactor
	end

	return 1.0
end

function SizeRules.getResourceVisualScale(sizeId: string?, sizeValue: number?): number
	local baseScale = SizeRules.getScaleValue(sizeId, sizeValue)
	local visualMultiplier = if type(Sizes.resourceVisualScaleMultiplier) == "number" then Sizes.resourceVisualScaleMultiplier else 1.0
	return baseScale * visualMultiplier
end

function SizeRules.getSellMultiplier(sizeId: string?, sizeValue: number?): number
	local definition = SizeRules.resolveDefinition(sizeId, sizeValue)
	if definition ~= nil and type(definition.sellMultiplier) == "number" then
		return definition.sellMultiplier
	end

	return 1.0
end

function SizeRules.getDisplayName(sizeId: string?, sizeValue: number?): string
	local definition = SizeRules.resolveDefinition(sizeId, sizeValue)
	return if definition ~= nil and type(definition.displayName) == "string" then definition.displayName else "Medium"
end

function SizeRules.getDisplayText(sizeId: string?, sizeValue: number?): string
	return string.format("%s (%.2fx)", SizeRules.getDisplayName(sizeId, sizeValue), roundToPlaces(SizeRules.getScaleValue(sizeId, sizeValue), 2))
end

return SizeRules
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="29">
          <Properties>
            <string name="Name">StationAssignment</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Station Assignment so gameplay behavior can be reused by the server, client presentation, and specs.

local StationAssignment = {}

local function getPlacementRecord(profile, stationId)
	for _, placement in pairs(profile.placedObjects) do
		if placement.objectType == "station" and placement.objectId == stationId then
			return placement
		end
	end

	return nil
end

local function compareStationOrder(left, right)
	if left.y ~= right.y then
		return left.y < right.y
	end

	if left.x ~= right.x then
		return left.x < right.x
	end

	return left.stationId < right.stationId
end

function StationAssignment.getPlacedStationOrder(profile)
	local ordered = {}

	for stationId, station in pairs(profile.stationsById) do
		if station.placement ~= nil then
			local placement = getPlacementRecord(profile, stationId) or station.placement
			table.insert(ordered, {
				stationId = stationId,
				x = placement.x,
				y = placement.y,
			})
		end
	end

	table.sort(ordered, compareStationOrder)
	return ordered
end

function StationAssignment.getAvailableStationId(profile, stationDefinitions)
	for _, entry in ipairs(StationAssignment.getPlacedStationOrder(profile)) do
		local station = profile.stationsById[entry.stationId]
		local stationDefinition = station and stationDefinitions[station.stationTypeId] or nil
		if station ~= nil and stationDefinition ~= nil and #station.occupantIds < stationDefinition.capacity then
			return station.id
		end
	end

	return nil, "no_station_capacity"
end

function StationAssignment.assignResourceToStation(profile, stationDefinitions, resourceId, stationId)
	local resource = profile.resourcesById[resourceId]
	if resource == nil then
		return false, "resource_not_found"
	end

	if resource.placement ~= nil then
		return false, "resource_already_placed"
	end

	local station = profile.stationsById[stationId]
	if station == nil then
		return false, "station_not_found"
	end

	if station.placement == nil then
		return false, "station_not_placed"
	end

	local stationDefinition = stationDefinitions[station.stationTypeId]
	if stationDefinition == nil then
		return false, "station_definition_missing"
	end

	if resource.stationId == stationId then
		return true
	end

	if #station.occupantIds >= stationDefinition.capacity then
		return false, "station_full"
	end

	if resource.stationId ~= nil then
		local previousStation = profile.stationsById[resource.stationId]
		if previousStation ~= nil then
			for index, occupantId in ipairs(previousStation.occupantIds) do
				if occupantId == resourceId then
					table.remove(previousStation.occupantIds, index)
					break
				end
			end
		end
	end

	resource.stationId = stationId
	table.insert(station.occupantIds, resourceId)
	return true
end

function StationAssignment.autoAssignResources(profile, stationDefinitions, resourceIds)
	local assignedResourceIds = {}
	local unassignedResourceIds = {}

	for _, resourceId in ipairs(resourceIds) do
		local stationId = StationAssignment.getAvailableStationId(profile, stationDefinitions)
		if stationId == nil then
			table.insert(unassignedResourceIds, resourceId)
		else
			local assigned = StationAssignment.assignResourceToStation(profile, stationDefinitions, resourceId, stationId)
			if assigned then
				table.insert(assignedResourceIds, resourceId)
			else
				table.insert(unassignedResourceIds, resourceId)
			end
		end
	end

	return {
		assignedResourceIds = assignedResourceIds,
		unassignedResourceIds = unassignedResourceIds,
	}
end

return StationAssignment
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="30">
          <Properties>
            <string name="Name">TraitRoller</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Trait Roller so gameplay behavior can be reused by the server, client presentation, and specs.

local TraitRoller = {}

function TraitRoller.getTotalWeight(entries: { any }): number
	local totalWeight = 0

	for _, entry in ipairs(entries) do
		if type(entry) == "table" and type(entry.weight) == "number" and entry.weight > 0 then
			totalWeight += entry.weight
		end
	end

	return totalWeight
end

local function pickWeighted(entries: { any }, roll: number)
	local cursor = 0

	for _, entry in ipairs(entries) do
		local weight = if type(entry) == "table" and type(entry.weight) == "number" then entry.weight else 0
		if weight <= 0 then
			continue
		end

		cursor += weight
		if roll <= cursor then
			return entry
		end
	end

	return entries[#entries]
end

function TraitRoller.rollTrait(traitDefinitions: { any }, rng: Random?)
	if #traitDefinitions == 0 then
		return nil
	end

	local totalWeight = TraitRoller.getTotalWeight(traitDefinitions)
	if totalWeight <= 0 then
		return nil
	end

	local roll = if rng then rng:NextNumber() else math.random()
	local scaledRoll = math.max(0.000001, roll * totalWeight)
	return pickWeighted(traitDefinitions, scaledRoll)
end

return TraitRoller

]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="31">
          <Properties>
            <string name="Name">VaultMath</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Vault Math so gameplay behavior can be reused by the server, client presentation, and specs.

local RewardPresentation = require(script.Parent.RewardPresentation)

local VaultMath = {}

function VaultMath.getResourceSellValue(resourceDefinition, traitDefinition, sizeDefinition): number
	if resourceDefinition == nil then
		return 0
	end

	local baseCoinRate = resourceDefinition.baseCoinRate or 0
	local traitMultiplier = if traitDefinition ~= nil then traitDefinition.sellMultiplier or traitDefinition.multiplier or 1 else 1
	local sizeMultiplier = if sizeDefinition ~= nil then sizeDefinition.sellMultiplier or 1 else 1
	return math.max(1, math.floor((baseCoinRate * 25 * traitMultiplier * sizeMultiplier) + 0.5))
end

function VaultMath.getGeodeSellValue(geodeDefinition): number
	if geodeDefinition == nil then
		return 0
	end

	local geodeSeconds = geodeDefinition.geodeSeconds or 0
	return math.max(1, math.floor((geodeSeconds * 3) + 0.5))
end

function VaultMath.getResourceRarityTier(resourceDefinition): number
	return RewardPresentation.getResourceCelebrationTier(resourceDefinition)
end

function VaultMath.getTraitRarityTier(traitDefinition): number
	return RewardPresentation.getTraitCelebrationTier(traitDefinition)
end

function VaultMath.getRewardPresentationScale(resourceDefinition, traitDefinition): number
	return RewardPresentation.getRewardBurstScale(resourceDefinition, traitDefinition)
end

return VaultMath
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="32">
          <Properties>
            <string name="Name">WorldLabelPresentation</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for World Label Presentation so gameplay behavior can be reused by the server, client presentation, and specs.

local WorldLabelPresentation = {}

local RESOURCE_RARITY_LABEL_COLORS = {
	Common = Color3.fromRGB(244, 249, 255),
	Uncommon = Color3.fromRGB(188, 145, 255),
	Rare = Color3.fromRGB(108, 228, 193),
	Epic = Color3.fromRGB(118, 213, 255),
	Legendary = Color3.fromRGB(255, 224, 117),
}

function WorldLabelPresentation.resolveHoveredResourceId(targetResourceId: string?, ancestorResourceId: string?): string?
	if type(targetResourceId) == "string" and targetResourceId ~= "" then
		return targetResourceId
	end

	if type(ancestorResourceId) == "string" and ancestorResourceId ~= "" then
		return ancestorResourceId
	end

	return nil
end

function WorldLabelPresentation.shouldShowPlacedResourceLabel(resourceId: string?, hoveredResourceId: string?): boolean
	if type(resourceId) ~= "string" or resourceId == "" then
		return false
	end

	return resourceId == hoveredResourceId
end

function WorldLabelPresentation.getPlacedResourceLabelAccentColor(rarityLabel: string?): Color3
	if type(rarityLabel) == "string" and RESOURCE_RARITY_LABEL_COLORS[rarityLabel] ~= nil then
		return RESOURCE_RARITY_LABEL_COLORS[rarityLabel]
	end

	return RESOURCE_RARITY_LABEL_COLORS.Common
end

function WorldLabelPresentation.getPlacedResourceLabelText(
	resourceDisplayName: string?,
	traitDisplayName: string?,
	sizeDisplayName: string?,
	rarityLabel: string?
): (string, string)
	local baseDisplayName = if type(resourceDisplayName) == "string" and resourceDisplayName ~= ""
		then resourceDisplayName
		else "Unknown Resource"
	local normalizedTraitDisplayName = if type(traitDisplayName) == "string" and traitDisplayName ~= "" and traitDisplayName ~= "None"
		then traitDisplayName
		else nil
	local normalizedSizeDisplayName = if type(sizeDisplayName) == "string" and sizeDisplayName ~= "" and sizeDisplayName ~= "Medium"
		then sizeDisplayName
		else nil
	local normalizedRarityLabel = if type(rarityLabel) == "string" and rarityLabel ~= ""
		then rarityLabel
		else "Common"

	local title = baseDisplayName
	if normalizedTraitDisplayName ~= nil then
		title = string.format("%s %s", normalizedTraitDisplayName, title)
	end
	if normalizedSizeDisplayName ~= nil then
		title = string.format("%s %s", normalizedSizeDisplayName, title)
	end

	local subtitle = normalizedRarityLabel
	if normalizedTraitDisplayName ~= nil then
		subtitle = string.format("%s - %s", subtitle, normalizedTraitDisplayName)
	end
	if normalizedSizeDisplayName ~= nil then
		subtitle = string.format("%s (%s)", subtitle, normalizedSizeDisplayName)
	end

	return title, subtitle
end

return WorldLabelPresentation
]]></string>
          </Properties>
        </Item>
      </Item>
