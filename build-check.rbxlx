			overlay = vaultOverlay,
			items = vaultItems,
			button = vaultButton,
			closeButton = vaultClose,
			coinLabel = coinLabel,
		},
		guide = {
			overlay = guideOverlay,
			button = guideButton,
			closeButton = guideClose,
			rows = guideRows,
			collectionFrame = guideCollectionFrame,
			collectionGrid = guideCollectionGrid,
