            <string name="Name">Geodes</string>
            <string name="Source"><![CDATA[--!strict

-- Static shared configuration for Geodes used by deterministic gameplay logic on both client and server.
-- Crack timers now start at a 30-second common baseline and widen in clean late-tier steps so progression stays easy to inspect.

local function makeRoll(resourceId: string, weight: number)
	return {
		resourceId = resourceId,
		weight = weight,
	}
end

local function makeGeode(
	id: string,
	displayName: string,
	geodeSeconds: number,
	displayColor: Color3,
	rolls: { { resourceId: string, weight: number } }
)
	return {
		id = id,
		displayName = displayName,
		geodeSeconds = geodeSeconds,
		gridSize = {
			width = 2,
			height = 2,
		},
		displayColor = displayColor,
		rolls = rolls,
	}
end

