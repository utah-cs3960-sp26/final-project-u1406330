          <Item class="ModuleScript" referent="72">
            <Properties>
              <string name="Name">MiningController</string>
              <string name="Source"><![CDATA[--!strict

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local Shared = ReplicatedStorage:WaitForChild("Shared")

local Pickaxes = require(Shared.Config.Pickaxes)
local RemoteNames = require(Shared.Net.RemoteNames)

local MiningController = {}
MiningController.__index = MiningController

local MINE_TARGET_ATTRIBUTE = "GemFactoryMineTarget"
local PICKAXE_TOOL_ATTRIBUTE = "GemFactoryPickaxeTool"
local MINE_COOLDOWN_SECONDS = 0.35
local MINE_REMOTE_NAME = (RemoteNames :: any).RequestMine or "RequestMine"

local function getPickaxeDisplayName(tool: Tool): string
	local pickaxeTypeId = tool:GetAttribute("PickaxeTypeId")
	if type(pickaxeTypeId) == "string" and pickaxeTypeId ~= "" then
		local definition = Pickaxes.catalog[pickaxeTypeId]
		return if definition ~= nil then definition.displayName else pickaxeTypeId
	end

	local pickaxeId = tool:GetAttribute("PickaxeId")
	if type(pickaxeId) == "string" and pickaxeId ~= "" then
		local definition = Pickaxes.catalog[pickaxeId]
		return if definition ~= nil then definition.displayName else pickaxeId
	end

	return tool.Name
end

local function isMineTarget(target: Instance?): BasePart?
	if target == nil or not target:IsA("BasePart") then
		return nil
	end

	if target:GetAttribute(MINE_TARGET_ATTRIBUTE) == true then
		return target
	end

	local ancestor = target.Parent
	while ancestor ~= nil do
		if ancestor:IsA("Model") and ancestor:GetAttribute("GemFactoryMine") == true then
			return target
		end
		ancestor = ancestor.Parent
	end

	return nil
end

function MiningController.new(context)
	return setmetatable({
		context = context or {},
	}, MiningController)
end

function MiningController:start()
	local app = self.context.app
	local screen = self.context.screen
	local mouse = Players.LocalPlayer:GetMouse()
	local lastMineClickAt = 0
	local lastEquippedPickaxeId: string? = nil

	local function getEquippedPickaxeTool()
		local character = Players.LocalPlayer.Character
		if character == nil then
			return nil
		end

		local tool = character:FindFirstChildWhichIsA("Tool")
		if tool == nil then
			return nil
		end

		if tool:GetAttribute(PICKAXE_TOOL_ATTRIBUTE) ~= true then
			return nil
		end

		local pickaxeTypeId = tool:GetAttribute("PickaxeTypeId")
		if type(pickaxeTypeId) ~= "string" or pickaxeTypeId == "" then
			pickaxeTypeId = tool.Name
		end

		return tool, tostring(pickaxeTypeId)
	end

	local function refreshEquippedStatus()
		local equippedTool, pickaxeId = getEquippedPickaxeTool()
		if equippedTool ~= nil and pickaxeId ~= nil and lastEquippedPickaxeId ~= pickaxeId then
			lastEquippedPickaxeId = pickaxeId
			app:setStatus(string.format("Equipped %s. Click the mine to dig.", getPickaxeDisplayName(equippedTool)))
		elseif equippedTool == nil then
			lastEquippedPickaxeId = nil
		end
	end

	RunService.RenderStepped:Connect(refreshEquippedStatus)

	local function handleMineClick()
		local now = os.clock()
		if now - lastMineClickAt < MINE_COOLDOWN_SECONDS then
			return
		end
		lastMineClickAt = now

		local equippedTool, pickaxeId = getEquippedPickaxeTool()
		if equippedTool == nil then
			app:setStatus("Equip a pickaxe before mining.")
			if screen ~= nil and screen.showMiningPopup ~= nil then
				screen:showMiningPopup("Equip a pickaxe")
			end
			return
		end

		local mineTarget = isMineTarget(mouse.Target)
		if mineTarget == nil then
			return
		end

		local ok, result = app:invokeRemote(MINE_REMOTE_NAME, pickaxeId, mineTarget)
		if ok and type(result) == "table" and result.ok == true then
			local rewardText = nil
			if type(result.coins) == "number" and result.coins > 0 then
				rewardText = string.format("Found %d coins in the mine.", math.floor(result.coins + 0.5))
			elseif type(result.geodeDisplayName) == "string" then
				rewardText = string.format("Unearthed %s.", tostring(result.geodeDisplayName))
			elseif type(result.geodeTypeId) == "string" then
				rewardText = string.format("Unearthed %s.", tostring(result.geodeTypeId))
			elseif type(result.rewardText) == "string" then
				rewardText = tostring(result.rewardText)
			end

			app:setStatus(rewardText or "Mining hit registered.")
			if screen ~= nil and screen.showMiningPopup ~= nil then
				screen:showMiningPopup(rewardText or "Mining hit registered")
			end
		else
			local errorText = type(result) == "table" and result.errorCode or result
			if errorText == "mine_cooldown" then
				return
			end
			if errorText == "not_inside_mine" then
				app:setStatus("Stand inside the mine to mine.")
				if screen ~= nil and screen.showMiningPopup ~= nil then
					screen:showMiningPopup("Stand inside the mine")
				end
				return
			end
			app:setStatus("Mining failed: " .. tostring(errorText))
		end
	end

	mouse.Button1Down:Connect(handleMineClick)
end

return MiningController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="73">
            <Properties>
              <string name="Name">NotificationsController</string>
              <string name="Source"><![CDATA[--!strict

local NotificationsController = {}
NotificationsController.__index = NotificationsController

local function formatNumber(value)
	local text = tostring(math.floor((value or 0) + 0.5))
	while true do
		local nextText = text:gsub("^(-?%d+)(%d%d%d)", "%1,%2")
		if nextText == text then
			break
		end
		text = nextText
	end
	return text
end

function NotificationsController.new(context)
	return setmetatable({
		context = context or {},
	}, NotificationsController)
end

function NotificationsController:start()
	local screen = self.context.screen
	local app = self.context.app

	local function formatDuration(seconds: number): string
		local safeSeconds = math.max(0, math.floor(seconds))
		local hours = math.floor(safeSeconds / 3600)
		local minutes = math.floor((safeSeconds % 3600) / 60)
		local remaining = safeSeconds % 60
		return string.format("%02d:%02d:%02d", hours, minutes, remaining)
	end

	local function formatAnnouncementList(announcements)
		if #announcements == 0 then
			return "No announcements yet."
		end

		local lines = {}
		for index, announcement in ipairs(announcements) do
			if index > 3 then
				table.insert(lines, string.format("...and %d more", #announcements - 3))
				break
			end
			table.insert(lines, tostring(announcement))
		end

		return table.concat(lines, "\n")
	end

	local function refresh(state)
		local profile = state.profile
		local offlineReward = profile.unclaimedOfflineRewards
		local offlineText = "No offline cache ready yet."
		local offlineButtonText = "Claim Offline Cache"
		local offlineEnabled = false

		if offlineReward ~= nil then
			offlineText = string.format(
				"Offline coins: %s\nElapsed: %s\nFinished geodes: %d",
				formatNumber(offlineReward.coins),
				formatDuration(offlineReward.elapsedSeconds),
				#offlineReward.finishedGeodes
			)
			offlineButtonText = string.format("Claim Offline Cache (%s coins)", formatNumber(offlineReward.coins))
			offlineEnabled = true
		end

		screen:setOfflineText(offlineText)
		screen:setOfflineButtonState(offlineEnabled, offlineButtonText)
		screen:setNotificationsText(formatAnnouncementList(state.announcements))
	end

	screen.buttons.claimOffline.Activated:Connect(function()
		app:requestCollectOfflineRewards()
	end)

	self.context.stateChanged:Connect(refresh)
	refresh(app:getState())
end

return NotificationsController


]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="74">
            <Properties>
              <string name="Name">PlacementController</string>
              <string name="Source"><![CDATA[--!strict

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Stations = require(Shared.Config.Stations)
local World = require(Shared.Config.World)

local PlacementController = {}
PlacementController.__index = PlacementController

function PlacementController.new(context)
	return setmetatable({
		context = context or {},
	}, PlacementController)
end

function PlacementController:start()
	local screen = self.context.screen
	local app = self.context.app
	local starterStation = Stations[World.starterStationTypeId]

	local function refresh(state)
		local plotId = state.profile.plotState.plotId or "Unassigned"
		local starterPlaced = false
		local placedStationCount = 0
		for _, station in pairs(state.profile.stationsById) do
			if station.placement ~= nil then
				placedStationCount += 1
				if station.stationTypeId == World.starterStationTypeId then
					starterPlaced = true
				end
			end
		end

		screen:setPlacementText(string.format(
			"Placement snaps to a %d x %d cavern grid.\nCurrent lot: %s\nPlaced stations: %d\nStarter station footprint: %dx%d",
			World.plotGridWidth,
			World.plotGridHeight,
			plotId,
			placedStationCount,
			starterStation and starterStation.gridSize.width or 0,
			starterStation and starterStation.gridSize.height or 0
		))

		screen:setPlaceStarterStationButton(
			not starterPlaced and plotId ~= "Unassigned",
			if starterPlaced then "Starter Station Placed" else "Place Starter Station"
		)
	end

	screen.buttons.placeStarterStation.Activated:Connect(function()
		app:requestPlaceStarterStation()
	end)

	self.context.stateChanged:Connect(refresh)
	refresh(app:getState())
end

return PlacementController

]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="75">
            <Properties>
              <string name="Name">PlotController</string>
              <string name="Source"><![CDATA[--!strict

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local World = require(Shared.Config.World)

local PlotController = {}
PlotController.__index = PlotController

function PlotController.new(context)
	return setmetatable({
		context = context or {},
	}, PlotController)
end

function PlotController:start()
	local screen = self.context.screen
	local app = self.context.app

	local function refresh(state)
		local profile = state.profile
		local plotId = profile.plotState.plotId or "Unassigned"
		local occupiedCells = 0
		local onPlotGeodes = 0
		local storedGeodes = 0
		local inventoryGeodes = profile.inventory and profile.inventory.geodes or nil

		for _, geode in pairs(profile.geodesById) do
			if geode.placement ~= nil then
				onPlotGeodes += 1
			end
		end

		if type(inventoryGeodes) == "table" then
			for _, amount in pairs(inventoryGeodes) do
				if type(amount) == "number" and amount > 0 then
					storedGeodes += amount
				end
			end
		end

		if storedGeodes == 0 then
			for _, geode in pairs(profile.geodesById) do
				if geode.placement == nil then
					storedGeodes += 1
				end
			end
		end

		for _ in pairs(profile.plotState.gridOccupancy) do
			occupiedCells += 1
		end

		screen:setPlotText(string.format(
			"Cavern Lot: %s\nGrid: %d x %d\nOccupied Cells: %d\nGeodes on plot: %d\nGeodes in inventory: %d\nClick a ready geode on the plot to crack it open.\nUnlocked Zones: %d",
			plotId,
			World.plotGridWidth,
			World.plotGridHeight,
			occupiedCells,
			onPlotGeodes,
			storedGeodes,
			#profile.progression.unlockedZones
		))
	end

	self.context.stateChanged:Connect(refresh)
	refresh(app:getState())
end

return PlotController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="76">
            <Properties>
              <string name="Name">ShopController</string>
              <string name="Source"><![CDATA[--!strict

local ProximityPromptService = game:GetService("ProximityPromptService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = ReplicatedStorage:WaitForChild("Shared")

local Pickaxes = require(Shared.Config.Pickaxes)
local RemoteNames = require(Shared.Net.RemoteNames)

local ShopController = {}
ShopController.__index = ShopController

local SHOP_PROMPT_ATTRIBUTE = "GemFactoryShopPrompt"
local SHOP_ROW_Z_INDEX = 62
local SHOP_TEXT_Z_INDEX = 63
local SHOP_BUTTON_Z_INDEX = 64

local function formatNumber(value: number): string
	local text = tostring(math.floor(value + 0.5))
	while true do
		local nextText = text:gsub("^(-?%d+)(%d%d%d)", "%1,%2")
		if nextText == text then
			break
		end
		text = nextText
	end
	return text
end

local function clearOfferRows(container: Instance)
	for _, child in ipairs(container:GetChildren()) do
		if child:IsA("UIListLayout") or child:IsA("UIPadding") or child:IsA("UIGridLayout") then
			continue
		end
		child:Destroy()
	end
end

local function collectOffers()
	local offers = {}
	for _, pickaxeId in ipairs(Pickaxes.order) do
		local definition = Pickaxes.catalog[pickaxeId]
		if definition ~= nil then
			table.insert(offers, definition)
		end
	end
	return offers
end

local function collectRarityLabels()
	local labels = {}
	for _, pickaxeId in ipairs(Pickaxes.order) do
		local definition = Pickaxes.catalog[pickaxeId]
		if definition ~= nil then
			table.insert(labels, definition.rarity)
		end
	end
	return labels
end

local function createOfferRow(parent: Instance, palette, offer, isOwned: boolean, isEquipped: boolean, canAfford: boolean, onBuy, onEquip)
	local row = Instance.new("Frame")
	row.Name = offer.displayName .. "Row"
	row.BackgroundColor3 = palette.background.panelAlt
	row.BorderSizePixel = 0
	row.Size = UDim2.new(1, 0, 0, 102)
	row.ZIndex = SHOP_ROW_Z_INDEX
	row.Parent = parent

	local rowCorner = Instance.new("UICorner")
	rowCorner.CornerRadius = UDim.new(0, 8)
	rowCorner.Parent = row

	local rowStroke = Instance.new("UIStroke")
	rowStroke.Color = palette.border
	rowStroke.Thickness = 1
	rowStroke.Transparency = 0.15
	rowStroke.Parent = row

	local padding = Instance.new("UIPadding")
	padding.PaddingTop = UDim.new(0, 10)
	padding.PaddingBottom = UDim.new(0, 10)
	padding.PaddingLeft = UDim.new(0, 12)
	padding.PaddingRight = UDim.new(0, 12)
	padding.Parent = row

	local title = Instance.new("TextLabel")
	title.BackgroundTransparency = 1
	title.Size = UDim2.new(1, -132, 0, 22)
	title.Font = Enum.Font.GothamBold
	title.Text = offer.displayName
	title.TextColor3 = palette.text
	title.TextSize = 18
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.ZIndex = SHOP_TEXT_Z_INDEX
	title.Parent = row

	local subtitle = Instance.new("TextLabel")
	subtitle.BackgroundTransparency = 1
	subtitle.Position = UDim2.new(0, 0, 0, 24)
	subtitle.Size = UDim2.new(1, -132, 0, 46)
	subtitle.Font = Enum.Font.Gotham
	subtitle.Text = string.format(
		"%s pickaxe\nCoins %d-%d | Geode chance %d%%",
		offer.rarity,
		offer.coinRewardMin,
		offer.coinRewardMax,
		offer.geodeChance
	)
	subtitle.TextColor3 = palette.muted
	subtitle.TextSize = 14
	subtitle.TextWrapped = true
	subtitle.TextXAlignment = Enum.TextXAlignment.Left
	subtitle.TextYAlignment = Enum.TextYAlignment.Top
	subtitle.ZIndex = SHOP_TEXT_Z_INDEX
	subtitle.Parent = row

	local price = Instance.new("TextLabel")
	price.BackgroundTransparency = 1
	price.Position = UDim2.new(0, 0, 0, 76)
	price.Size = UDim2.new(1, -132, 0, 16)
	price.Font = Enum.Font.Gotham
	price.Text = if isOwned then "Owned" else string.format("%s %s", formatNumber(offer.price), string.lower(offer.currency))
	price.TextColor3 = palette.accentSoft
	price.TextSize = 12
	price.TextXAlignment = Enum.TextXAlignment.Left
	price.ZIndex = SHOP_TEXT_Z_INDEX
	price.Parent = row

	local action = Instance.new("TextButton")
	action.Name = "ActionButton"
	action.AnchorPoint = Vector2.new(1, 0.5)
	action.AutoButtonColor = not isEquipped and (isOwned or canAfford)
	action.Active = not isEquipped and (isOwned or canAfford)
	action.BackgroundColor3 = if isEquipped then Color3.fromRGB(120, 120, 120) elseif isOwned or canAfford then palette.accent else Color3.fromRGB(110, 110, 110)
	action.BorderSizePixel = 0
	action.Position = UDim2.new(1, 0, 0.5, 0)
	action.Size = UDim2.new(0, 112, 0, 40)
	action.Font = Enum.Font.GothamBold
	action.Text = if isEquipped then "Equipped" elseif isOwned then "Equip" else if canAfford then "Buy" else "Need coins"
	action.TextColor3 = palette.shadow
	action.TextSize = 14
	action.ZIndex = SHOP_BUTTON_Z_INDEX
	action.Parent = row

	local actionCorner = Instance.new("UICorner")
	actionCorner.CornerRadius = UDim.new(0, 8)
	actionCorner.Parent = action

	action.Activated:Connect(function()
		if isEquipped then
			return
		end

		if isOwned then
			onEquip(offer)
		elseif canAfford then
			onBuy(offer)
		end
	end)
end

function ShopController.new(context)
	return setmetatable({
		context = context or {},
	}, ShopController)
end

function ShopController:_openShop()
	self.context.screen:setShopMenuVisible(true)
	self.context.app:setStatus("Pickaxe Shop opened.")
end

function ShopController:_refresh(state)
	local screen = self.context.screen
	local app = self.context.app
	local profile = state.profile or {}
	local currencies = profile.currencies or {}
	local inventory = profile.inventory or {}
	local ownedPickaxes = inventory.pickaxes or {}
	local equippedPickaxeId = profile.progression and profile.progression.equippedPickaxeId or "stone_pickaxe"
	local coinBalance = currencies.coins or 0

	screen:setShopText("Pickaxes are sold at the forge. Better pickaxes improve coin payouts and rare geode odds when mining.")
	screen:setShopMenuSubtitle("Press E at the forge to browse pickaxes.")
	screen:setShopMenuInfo(string.format("Coins: %s | Equipped: %s", formatNumber(coinBalance), equippedPickaxeId))
	screen:setShopMenuRarities(collectRarityLabels())

	local offerContainer = screen:getShopOfferContainer()
	clearOfferRows(offerContainer)

	for _, offer in ipairs(collectOffers()) do
		local isOwned = ownedPickaxes[offer.id] == true
		local isEquipped = equippedPickaxeId == offer.id
		createOfferRow(
			offerContainer,
			app.context.palette,
			offer,
			isOwned,
			isEquipped,
			coinBalance >= offer.price,
			function(selectedOffer)
				local ok, result = app:invokeRemote(RemoteNames.RequestBuyPickaxe, selectedOffer.id)
				if ok and type(result) == "table" and result.ok == true then
					app:setStatus(string.format("%s bought and added to your backpack.", selectedOffer.displayName))
				else
					local errorText = type(result) == "table" and result.errorCode or result
					app:setStatus("Pickaxe purchase failed: " .. tostring(errorText))
				end
			end,
			function(selectedOffer)
				local ok, result = app:invokeRemote(RemoteNames.RequestEquipPickaxe, selectedOffer.id)
				if ok and type(result) == "table" and result.ok == true then
					app:setStatus(string.format("Equipped %s.", selectedOffer.displayName))
				else
					local errorText = type(result) == "table" and result.errorCode or result
					app:setStatus("Pickaxe equip failed: " .. tostring(errorText))
				end
			end
		)
	end
end

function ShopController:start()
	local app = self.context.app

	self.context.stateChanged:Connect(function(state)
		self:_refresh(state)
	end)

	self.context.screen.shop.closeButton.Activated:Connect(function()
		self.context.screen:setShopMenuVisible(false)
	end)

	ProximityPromptService.PromptTriggered:Connect(function(prompt)
		if prompt ~= nil and prompt:IsA("ProximityPrompt") and prompt:GetAttribute(SHOP_PROMPT_ATTRIBUTE) == true then
			self:_openShop()
		end
	end)

	self.context.screen:setShopMenuVisible(false)
	self:_refresh(app:getState())
end

return ShopController
]]></string>
            </Properties>
          </Item>
        </Item>
        <Item class="Folder" referent="77">
