		chipStroke.Parent = rarityChip

		table.insert(rarityLabels, rarityChip)
	end

	applyGuiZIndex(shopPanel, SHOP_BASE_Z_INDEX + 2)
	shopPanel.ZIndex = SHOP_BASE_Z_INDEX + 1
	shopOverlay.ZIndex = SHOP_BASE_Z_INDEX
