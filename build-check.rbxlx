        <Item class="ModuleScript" referent="15">
          <Properties>
            <string name="Name">EconomyMath</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Economy Math so gameplay behavior can be reused by the server, client presentation, and specs.

local EconomyMath = {}

function EconomyMath.getPrestigeMultiplier(prestigeCount: number, step: number, baseMultiplier: number?): number
	return (baseMultiplier or 1) + (prestigeCount * step)
end

function EconomyMath.getResourceIncome(baseRate: number, traitMultiplier: number, stationMultiplier: number, prestigeMultiplier: number?, eventMultiplier: number?): number
	return baseRate * traitMultiplier * stationMultiplier * (prestigeMultiplier or 1) * (eventMultiplier or 1)
end

function EconomyMath.getPassiveIncomeForElapsedSeconds(passiveRate: number, elapsedSeconds: number): number
	return math.max(0, passiveRate) * math.max(0, elapsedSeconds)
end

function EconomyMath.resolvePassiveAccrual(passiveRate: number, elapsedSeconds: number, existingRemainder: number?): (number, number)
	local totalIncome = EconomyMath.getPassiveIncomeForElapsedSeconds(passiveRate, elapsedSeconds) + math.max(0, existingRemainder or 0)
	local awardedCoins = math.floor(totalIncome)
	return awardedCoins, totalIncome - awardedCoins
end

function EconomyMath.sumResourceIncome(entries: { { baseRate: number, traitMultiplier: number, stationMultiplier: number } }, prestigeMultiplier: number?): number
	local total = 0

	for _, entry in ipairs(entries) do
		total += EconomyMath.getResourceIncome(
			entry.baseRate,
			entry.traitMultiplier,
			entry.stationMultiplier,
			prestigeMultiplier,
			1
		)
	end

	return total
end

return EconomyMath

]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="16">
          <Properties>
            <string name="Name">GeodePresentation</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Geode Presentation so gameplay behavior can be reused by the server, client presentation, and specs.

local GeodePresentation = {}

function GeodePresentation.formatCountdown(remainingSeconds: number?): string
	local safeRemaining = math.max(0, math.floor(remainingSeconds or 0))
	local minutes = math.floor(safeRemaining / 60)
	local seconds = safeRemaining % 60
	return string.format("%d:%02d", minutes, seconds)
end

function GeodePresentation.getWorldLabelText(readyState: string?, endsAt: number?, nowUnix: number?): string
	local normalizedState = if type(readyState) == "string" then string.lower(readyState) else nil
	local currentUnix = if type(nowUnix) == "number" then nowUnix else 0

	if normalizedState == "ready" or normalizedState == "finished" then
		return "Ready!"
	end

	if type(endsAt) == "number" and endsAt <= currentUnix then
		return "Ready!"
	end

	if type(endsAt) == "number" then
		return string.format("Cracking %s", GeodePresentation.formatCountdown(endsAt - currentUnix))
	end

	return "Cracking..."
end

function GeodePresentation.shouldHideResolvedRevealText(
	kind: string?,
	showSlotMachine: boolean?,
	reelFinished: boolean?
): boolean
	if showSlotMachine ~= true or reelFinished == true then
		return false
	end

	return kind == "resource" or kind == "attribute"
end

function GeodePresentation.shouldAdvanceRevealOnInput(inputType: Enum.UserInputType?): boolean
	return inputType == Enum.UserInputType.MouseButton1 or inputType == Enum.UserInputType.Touch
end

function GeodePresentation.getRevealAnimationGraceSeconds(): number
	return 0.6
end

function GeodePresentation.shouldKeepRevealAnimationAlive(
	elapsedSeconds: number?,
	celebrationPlaying: boolean?,
	queuedCelebrationCount: number?
): boolean
	local elapsed = if type(elapsedSeconds) == "number" then math.max(0, elapsedSeconds) else 0
	if elapsed < GeodePresentation.getRevealAnimationGraceSeconds() then
		return true
	end

	if celebrationPlaying == true then
		return true
	end

	local queueCount = if type(queuedCelebrationCount) == "number" then queuedCelebrationCount else 0
	return queueCount > 0
end

return GeodePresentation
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="17">
          <Properties>
            <string name="Name">GeodeRoller</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Geode Roller so gameplay behavior can be reused by the server, client presentation, and specs.

local GeodeRoller = {}

function GeodeRoller.getTotalWeight(entries: { any }): number
	local totalWeight = 0

	for _, entry in ipairs(entries) do
		if type(entry.weight) == "number" and entry.weight > 0 then
			totalWeight += entry.weight
		end
	end

	return totalWeight
end

local function pickWeighted(entries: { any }, roll: number)
	local cursor = 0

	for _, entry in ipairs(entries) do
		local weight = if type(entry.weight) == "number" then entry.weight else 0
		if weight <= 0 then
			continue
		end

		cursor += weight
		if roll <= cursor then
			return entry
		end
	end

	return entries[#entries]
end

function GeodeRoller.rollGeode(geodeDefinition: any, rng: Random?)
	local rolls = geodeDefinition.rolls
	if type(rolls) ~= "table" or #rolls == 0 then
		return nil
	end

	local totalWeight = GeodeRoller.getTotalWeight(rolls)
	if totalWeight <= 0 then
		return nil
	end

	local roll = if rng then rng:NextNumber() else math.random()
	local scaledRoll = math.max(0.000001, roll * totalWeight)
	return pickWeighted(rolls, scaledRoll)
end

return GeodeRoller

]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="18">
          <Properties>
            <string name="Name">GeodeState</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Geode State so gameplay behavior can be reused by the server, client presentation, and specs.

local GeodeState = {}

export type GeodeInstance = {
	id: string,
	geodeTypeId: string,
	sizeId: string?,
	sizeValue: number?,
	status: string,
	startedAt: number,
	endsAt: number,
	obtainedAt: number,
	placement: {
		plotId: string?,
		x: number,
		y: number,
		width: number,
		height: number,
	}?,
}

export type GeodeQueueEntry = {
	id: string,
	geodeId: string,
	startedAt: number,
	endsAt: number,
	status: string,
}

local function resolveStatus(instance: GeodeInstance, nowUnix: number?)
	local status = instance.status or "queued"
	if status == "claimed" then
		return status
	end

	if nowUnix ~= nil and (instance.endsAt or nowUnix) <= nowUnix then
		return "finished"
	end

	if status == "finished" and nowUnix ~= nil and instance.endsAt > nowUnix then
		return "queued"
	end

	return status
end

function GeodeState.createInstance(id: string, geodeTypeId: string, nowUnix: number, geodeSeconds: number, sizeId: string?, sizeValue: number?): GeodeInstance
	return {
		id = id,
		geodeTypeId = geodeTypeId,
		sizeId = sizeId or nil,
		sizeValue = sizeValue or nil,
		status = "queued",
		startedAt = nowUnix,
		endsAt = nowUnix + geodeSeconds,
		obtainedAt = nowUnix,
		placement = nil,
	}
end

function GeodeState.refreshStatuses(geodesById: { [string]: GeodeInstance }, geodeOrder: { string }, nowUnix: number)
	for _, geodeInstanceId in ipairs(geodeOrder) do
		local instance = geodesById[geodeInstanceId]
		if instance ~= nil then
			instance.status = resolveStatus(instance, nowUnix)
		end
	end
end

function GeodeState.toQueueEntry(instance: GeodeInstance, nowUnix: number?): GeodeQueueEntry
	return {
		id = instance.id,
		geodeId = instance.geodeTypeId,
		startedAt = instance.startedAt,
		endsAt = instance.endsAt,
		status = resolveStatus(instance, nowUnix),
	}
end

function GeodeState.buildQueueEntries(geodesById: { [string]: GeodeInstance }, geodeOrder: { string }, nowUnix: number?): { GeodeQueueEntry }
	local entries = {}

	for _, geodeInstanceId in ipairs(geodeOrder) do
		local instance = geodesById[geodeInstanceId]
		if instance ~= nil then
			table.insert(entries, GeodeState.toQueueEntry(instance, nowUnix))
		end
	end

	return entries
end

function GeodeState.migrateLegacyQueue(profile)
	if next(profile.geodesById) ~= nil then
		return false
	end

	for _, legacyEntry in ipairs(profile.geodeQueue or {}) do
		local geodeInstanceId = legacyEntry.id
		if geodeInstanceId ~= nil and profile.geodesById[geodeInstanceId] == nil then
			profile.geodesById[geodeInstanceId] = {
				id = geodeInstanceId,
				geodeTypeId = legacyEntry.geodeId,
				sizeId = nil,
				sizeValue = nil,
				status = legacyEntry.status or "queued",
				startedAt = legacyEntry.startedAt or 0,
				endsAt = legacyEntry.endsAt or 0,
				obtainedAt = legacyEntry.startedAt or 0,
				placement = nil,
			}
			table.insert(profile.geodeOrder, geodeInstanceId)
		end
	end

	return #profile.geodeOrder > 0
end

function GeodeState.getClaimableIds(profile, nowUnix: number, requestedGeodeId: string?)
	GeodeState.refreshStatuses(profile.geodesById, profile.geodeOrder, nowUnix)

	local claimableIds = {}
	for _, geodeInstanceId in ipairs(profile.geodeOrder) do
		local instance = profile.geodesById[geodeInstanceId]
		if instance ~= nil and instance.placement ~= nil and instance.status == "finished" then
			if requestedGeodeId == nil or requestedGeodeId == geodeInstanceId then
				table.insert(claimableIds, geodeInstanceId)
			end
		end
	end

	return claimableIds
end

function GeodeState.removeGeode(geodesById: { [string]: GeodeInstance }, geodeOrder: { string }, geodeInstanceId: string)
	geodesById[geodeInstanceId] = nil

	for index, existingId in ipairs(geodeOrder) do
		if existingId == geodeInstanceId then
			table.remove(geodeOrder, index)
			break
		end
	end
end

return GeodeState
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="19">
          <Properties>
            <string name="Name">MiningRewards</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Mining Rewards so gameplay behavior can be reused by the server, client presentation, and specs.

local MiningRewards = {}

local function rollNumber(rng: any): number
	if rng ~= nil then
		return rng:NextNumber()
	end

	return math.random()
end

local function rollInteger(rng: any, minValue: number, maxValue: number): number
	if rng ~= nil then
		return rng:NextInteger(minValue, maxValue)
	end

	return math.random(minValue, maxValue)
end

local function getGeodeWeights(pickaxeDefinition: any)
	if type(pickaxeDefinition) ~= "table" then
		return nil
	end

	local geodeWeights = pickaxeDefinition.geodeWeights
	if type(geodeWeights) ~= "table" then
		return nil
	end

	return geodeWeights
end

local function pickWeightedEntry(entries: { any }, roll: number)
	local cursor = 0

	for _, entry in ipairs(entries) do
		local weight = if type(entry.weight) == "number" then entry.weight else 0
		if weight <= 0 then
			continue
		end

		cursor += weight
		if roll <= cursor then
			return entry
		end
	end

	return nil
end

function MiningRewards.getTotalGeodeWeight(pickaxeDefinition: any): number
	local geodeWeights = getGeodeWeights(pickaxeDefinition)
	if geodeWeights == nil then
		return 0
	end

	local totalWeight = 0

	for _, entry in ipairs(geodeWeights) do
		if type(entry.weight) == "number" and entry.weight > 0 then
			totalWeight += entry.weight
		end
	end

	return totalWeight
end

function MiningRewards.rollCoins(pickaxeDefinition: any, rng: any)
	if type(pickaxeDefinition) ~= "table" or type(pickaxeDefinition.id) ~= "string" then
		return nil, "invalid_pickaxe"
	end

	local minCoins = pickaxeDefinition.coinRewardMin
	local maxCoins = pickaxeDefinition.coinRewardMax

	if type(minCoins) ~= "number" or type(maxCoins) ~= "number" or minCoins > maxCoins then
		return nil, "invalid_pickaxe"
	end

	local coins = rollInteger(rng, minCoins, maxCoins)
	return {
		rewardType = "coins",
		pickaxeId = pickaxeDefinition.id,
		displayName = pickaxeDefinition.displayName,
		rarity = pickaxeDefinition.rarity,
		coins = coins,
		geodeId = nil,
	}
end

function MiningRewards.rollGeode(pickaxeDefinition: any, rng: any)
	if type(pickaxeDefinition) ~= "table" or type(pickaxeDefinition.id) ~= "string" then
		return nil, "invalid_pickaxe"
	end

	local geodeWeights = getGeodeWeights(pickaxeDefinition)
	local totalWeight = MiningRewards.getTotalGeodeWeight(pickaxeDefinition)

	if geodeWeights == nil or totalWeight <= 0 then
		return nil, "invalid_pickaxe"
	end

	local roll = rollInteger(rng, 1, totalWeight)
	local entry = pickWeightedEntry(geodeWeights, roll)
	if entry == nil or type(entry.geodeId) ~= "string" then
		return nil, "invalid_pickaxe"
	end

	return {
		rewardType = "geode",
		pickaxeId = pickaxeDefinition.id,
		displayName = pickaxeDefinition.displayName,
		rarity = pickaxeDefinition.rarity,
		coins = nil,
		geodeId = entry.geodeId,
	}
end

function MiningRewards.rollReward(pickaxeDefinition: any, rng: any)
	if type(pickaxeDefinition) ~= "table" or type(pickaxeDefinition.id) ~= "string" then
		return nil, "unknown_pickaxe"
	end

	if type(pickaxeDefinition.geodeChance) ~= "number" then
		return nil, "invalid_pickaxe"
	end

	local chanceRoll = rollNumber(rng)
	if chanceRoll <= (pickaxeDefinition.geodeChance / 100) then
		return MiningRewards.rollGeode(pickaxeDefinition, rng)
	end

	return MiningRewards.rollCoins(pickaxeDefinition, rng)
end

return MiningRewards
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="20">
          <Properties>
            <string name="Name">OfflineMath</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Offline Math so gameplay behavior can be reused by the server, client presentation, and specs.

local EconomyMath = require(script.Parent.EconomyMath)

local OfflineMath = {}

function OfflineMath.clampElapsedSeconds(elapsedSeconds: number, capSeconds: number)
	return math.clamp(elapsedSeconds, 0, capSeconds)
end

function OfflineMath.buildSummary(lastLogoutUnix: number?, nowUnix: number, passiveRate: number, capSeconds: number)
	if lastLogoutUnix == nil then
		return nil
	end

	local elapsedSeconds = math.max(0, nowUnix - lastLogoutUnix)
	local clampedSeconds = OfflineMath.clampElapsedSeconds(elapsedSeconds, capSeconds)

	return {
		elapsedSeconds = clampedSeconds,
		coins = EconomyMath.getPassiveIncomeForElapsedSeconds(passiveRate, clampedSeconds),
		calculatedAt = nowUnix,
	}
end

return OfflineMath

]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="21">
          <Properties>
            <string name="Name">PickaxeRules</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Pickaxe Rules so gameplay behavior can be reused by the server, client presentation, and specs.

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = ReplicatedStorage:WaitForChild("Shared")
local Pickaxes = require(Shared.Config.Pickaxes)

local PickaxeRules = {}

local tierIndexById = {}

for index, pickaxeId in ipairs(Pickaxes.order) do
	tierIndexById[pickaxeId] = index
end

function PickaxeRules.getTierIndex(pickaxeId: string?): number?
	if type(pickaxeId) ~= "string" or pickaxeId == "" then
		return nil
	end

	return tierIndexById[pickaxeId]
end

function PickaxeRules.getHighestOwnedPickaxeId(ownedPickaxes: { [string]: boolean }?, equippedPickaxeId: string?): string
	local highestOwnedPickaxeId = nil

	for _, pickaxeId in ipairs(Pickaxes.order) do
		if ownedPickaxes ~= nil and ownedPickaxes[pickaxeId] == true then
			highestOwnedPickaxeId = pickaxeId
		end
	end

	if highestOwnedPickaxeId == nil then
		local equippedTierIndex = PickaxeRules.getTierIndex(equippedPickaxeId)
		if equippedTierIndex ~= nil then
			return equippedPickaxeId :: string
		end
	end

	return highestOwnedPickaxeId or "stone_pickaxe"
end

function PickaxeRules.normalizeOwnedPickaxes(ownedPickaxes: { [string]: boolean }?, equippedPickaxeId: string?): ({ [string]: boolean }, string)
	local resolvedPickaxeId = PickaxeRules.getHighestOwnedPickaxeId(ownedPickaxes, equippedPickaxeId)
	return {
		[resolvedPickaxeId] = true,
	}, resolvedPickaxeId
end

function PickaxeRules.isStrictUpgrade(currentPickaxeId: string?, candidatePickaxeId: string?): boolean
	local currentTierIndex = PickaxeRules.getTierIndex(currentPickaxeId)
	local candidateTierIndex = PickaxeRules.getTierIndex(candidatePickaxeId)
	if candidateTierIndex == nil then
		return false
	end

	if currentTierIndex == nil then
		return true
	end

	return candidateTierIndex > currentTierIndex
end

return PickaxeRules
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="22">
          <Properties>
            <string name="Name">PlacementRules</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Placement Rules so gameplay behavior can be reused by the server, client presentation, and specs.

local PlacementRules = {}

local function cellKey(x: number, y: number)
	-- Occupancy is stored as a flat dictionary because it is cheap to serialize, clone, and
	-- diff compared with nested grid tables keyed by row and column.
	return tostring(x) .. ":" .. tostring(y)
end

function PlacementRules.canPlace(plotSize: { width: number, height: number }, occupancy: { [string]: string }, x: number, y: number, width: number, height: number)
	if width <= 0 or height <= 0 then
		return false, "invalid_size"
	end

	if x < 1 or y < 1 then
		return false, "out_of_bounds"
	end

	if x + width - 1 > plotSize.width or y + height - 1 > plotSize.height then
		return false, "out_of_bounds"
	end

	for dx = 0, width - 1 do
		for dy = 0, height - 1 do
			if occupancy[cellKey(x + dx, y + dy)] ~= nil then
				return false, "occupied"
			end
		end
	end

	return true, nil
end

function PlacementRules.clearFootprint(occupancy: { [string]: string }, placement: { x: number, y: number, width: number, height: number })
	for dx = 0, placement.width - 1 do
		for dy = 0, placement.height - 1 do
			local key = cellKey(placement.x + dx, placement.y + dy)
			occupancy[key] = nil
		end
	end
end

function PlacementRules.getFootprintKeys(x: number, y: number, width: number, height: number): { string }
	local keys = {}

	for dx = 0, width - 1 do
		for dy = 0, height - 1 do
			table.insert(keys, cellKey(x + dx, y + dy))
		end
	end

	return keys
end

function PlacementRules.findFirstPlacement(plotSize: { width: number, height: number }, occupancy: { [string]: string }, width: number, height: number)
	-- First-fit scanning keeps starter placements deterministic, which makes tests and
	-- reconnect behavior much easier to reason about than randomized placement choices.
	for y = 1, plotSize.height do
		for x = 1, plotSize.width do
			local canPlace = PlacementRules.canPlace(plotSize, occupancy, x, y, width, height)
			if canPlace then
				return {
					x = x,
					y = y,
				}
			end
		end
	end

	return nil, "no_open_space"
end

function PlacementRules.buildOccupancyKey(x: number, y: number)
	return cellKey(x, y)
end

function PlacementRules.getCenterCell(x: number, y: number, width: number, height: number)
	return x + ((width - 1) / 2), y + ((height - 1) / 2)
end

return PlacementRules
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="23">
          <Properties>
            <string name="Name">ResourceGuide</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for the Resource Guide so the HUD can present rarity chart data from the shared resource catalog.

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = ReplicatedStorage:WaitForChild("Shared")

local Geodes = require(Shared.Config.Geodes)
local Pickaxes = require(Shared.Config.Pickaxes)
local Resources = require(Shared.Config.Resources)
local ResourceVisuals = require(Shared.Domain.ResourceVisuals)
local Traits = require(Shared.Config.Traits)

local ResourceGuide = {}

local RARITY_ORDER = {
	"Common",
	"Uncommon",
	"Rare",
	"Epic",
	"Legendary",
}

local RARITY_ACCENTS = {
	Common = Color3.fromRGB(255, 226, 122),
	Uncommon = Color3.fromRGB(196, 155, 255),
	Rare = Color3.fromRGB(101, 236, 199),
	Epic = Color3.fromRGB(119, 214, 255),
	Legendary = Color3.fromRGB(255, 189, 101),
}

local DEFAULT_PICKAXE_ID = "stone_pickaxe"

local TRAIT_SORT_INDEX = {}

for index, traitDefinition in ipairs(Traits.order or {}) do
	if traitDefinition ~= nil and type(traitDefinition.id) == "string" then
		TRAIT_SORT_INDEX[traitDefinition.id] = index
	end
end

local function compareCatalogEntries(leftEntry, rightEntry)
	if leftEntry.rank ~= rightEntry.rank then
		return leftEntry.rank < rightEntry.rank
	end

	if leftEntry.displayName ~= rightEntry.displayName then
		return leftEntry.displayName < rightEntry.displayName
	end

	return leftEntry.resourceId < rightEntry.resourceId
end

local function buildCatalogEntries()
	local entries = {}

	for resourceId, resourceDefinition in pairs(Resources) do
		if type(resourceDefinition) ~= "table" then
			continue
		end

		table.insert(entries, {
			resourceId = resourceId,
			displayName = tostring(resourceDefinition.displayName or resourceId),
			rarity = tostring(resourceDefinition.rarity or "Common"),
			rank = ResourceVisuals.getRarityRank(resourceDefinition.rarity),
			color = resourceDefinition.color,
			variantId = ResourceVisuals.getResourceVariantShape(resourceId, resourceDefinition),
		})
	end

	table.sort(entries, compareCatalogEntries)
	return entries
end

local CATALOG_ENTRIES = buildCatalogEntries()

local function roundToPlaces(value: number, places: number): number
	local scalar = 10 ^ places
	return math.floor((value * scalar) + 0.5) / scalar
end

local function formatPercent(percentValue: number): string
	if percentValue <= 0 then
		return "0.0%"
	end

	local places = 1
	if percentValue < 10 then
		places = 2
	end
	if percentValue < 1 then
		places = 3
	end

	return string.format("%." .. tostring(places) .. "f%%", roundToPlaces(percentValue, places))
end

local function getResolvedPickaxe(pickaxeId: string?)
	if type(pickaxeId) == "string" and Pickaxes.catalog[pickaxeId] ~= nil then
		return Pickaxes.catalog[pickaxeId]
	end

	return Pickaxes.catalog[DEFAULT_PICKAXE_ID]
end

local function getTotalWeight(entries: { any }?): number
	if type(entries) ~= "table" then
		return 0
	end

	local totalWeight = 0

	for _, entry in ipairs(entries) do
		local weight = if type(entry.weight) == "number" then entry.weight else 0
		if weight > 0 then
			totalWeight += weight
		end
	end

	return totalWeight
end

local function buildRarityChances(pickaxeDefinition: any)
	local rarityChances = {}

	for _, rarity in ipairs(RARITY_ORDER) do
		rarityChances[rarity] = 0
	end

	if type(pickaxeDefinition) ~= "table" then
		return rarityChances, 0
	end

	local geodeChance = math.max(0, tonumber(pickaxeDefinition.geodeChance) or 0) / 100
	local geodeWeights = pickaxeDefinition.geodeWeights
	local totalGeodeWeight = getTotalWeight(geodeWeights)

	if geodeChance <= 0 or totalGeodeWeight <= 0 then
		return rarityChances, 0
	end

	for _, geodeEntry in ipairs(geodeWeights) do
		local geodeId = geodeEntry.geodeId
		local geodeWeight = if type(geodeEntry.weight) == "number" then geodeEntry.weight else 0
		local geodeDefinition = if type(geodeId) == "string" then Geodes[geodeId] else nil
		if geodeWeight <= 0 or geodeDefinition == nil then
			continue
		end

		local totalResourceWeight = getTotalWeight(geodeDefinition.rolls)
		if totalResourceWeight <= 0 then
			continue
		end

		local geodeShare = geodeChance * (geodeWeight / totalGeodeWeight)

		for _, roll in ipairs(geodeDefinition.rolls) do
			local resourceId = roll.resourceId
			local resourceWeight = if type(roll.weight) == "number" then roll.weight else 0
			local resourceDefinition = if type(resourceId) == "string" then Resources[resourceId] else nil
			if resourceWeight <= 0 or resourceDefinition == nil then
				continue
			end

			local rarity = if type(resourceDefinition.rarity) == "string" then resourceDefinition.rarity else "Common"
			rarityChances[rarity] = (rarityChances[rarity] or 0) + (geodeShare * (resourceWeight / totalResourceWeight))
		end
	end

	local totalChance = 0
	for _, rarity in ipairs(RARITY_ORDER) do
		totalChance += rarityChances[rarity] or 0
	end

	return rarityChances, totalChance
end

function ResourceGuide.getRarityOrder(): { string }
	local order = table.clone(RARITY_ORDER)
	return order
end

function ResourceGuide.getDefaultPickaxeId(): string
	return DEFAULT_PICKAXE_ID
end

function ResourceGuide.ensureCollectionState(resourceGuideState: any): { discoveredResources: { [string]: any } }
	if type(resourceGuideState) ~= "table" then
		return {
			discoveredResources = {},
		}
	end

	if type(resourceGuideState.discoveredResources) ~= "table" then
		resourceGuideState.discoveredResources = {}
	end

	return resourceGuideState
end

function ResourceGuide.recordDiscovery(profile: any, resourceTypeId: string?, traitId: string?): boolean
	if type(profile) ~= "table" or type(resourceTypeId) ~= "string" or Resources[resourceTypeId] == nil then
		return false
	end

	-- Keep collection progress attached to the authoritative profile so all grant paths write the same persisted state.
	local collectionState = ResourceGuide.ensureCollectionState(profile.resourceGuide)
	profile.resourceGuide = collectionState

	local discoveredResources = collectionState.discoveredResources
	local resourceEntry = discoveredResources[resourceTypeId]
	if type(resourceEntry) ~= "table" then
		resourceEntry = {
			found = true,
			discoveredTraits = {},
		}
		discoveredResources[resourceTypeId] = resourceEntry
	else
		resourceEntry.found = true
		if type(resourceEntry.discoveredTraits) ~= "table" then
			resourceEntry.discoveredTraits = {}
		end
	end

	local resolvedTraitId = if type(traitId) == "string" and Traits[traitId] ~= nil then traitId else "none"
	resourceEntry.discoveredTraits[resolvedTraitId] = true
	return true
end

local function sortDiscoveredTraitNames(leftName: string, rightName: string): boolean
	local leftDefinition = nil
	local rightDefinition = nil

	for _, traitDefinition in ipairs(Traits.order or {}) do
		if traitDefinition.displayName == leftName then
			leftDefinition = traitDefinition
		end
		if traitDefinition.displayName == rightName then
			rightDefinition = traitDefinition
		end
	end

	local leftIndex = if leftDefinition ~= nil then TRAIT_SORT_INDEX[leftDefinition.id] or 999 else 999
	local rightIndex = if rightDefinition ~= nil then TRAIT_SORT_INDEX[rightDefinition.id] or 999 else 999
	if leftIndex ~= rightIndex then
		return leftIndex < rightIndex
	end

	return leftName < rightName
end

function ResourceGuide.getCollectionSlots(resourceGuideState: any): { any }
	local collectionState = ResourceGuide.ensureCollectionState(resourceGuideState)
	local slots = table.create(#CATALOG_ENTRIES)

	for layoutOrder, catalogEntry in ipairs(CATALOG_ENTRIES) do
		local discoveredEntry = collectionState.discoveredResources[catalogEntry.resourceId]
		local isFound = type(discoveredEntry) == "table" and discoveredEntry.found == true
		local discoveredTraitNames = {}

		if isFound and type(discoveredEntry.discoveredTraits) == "table" then
			for traitId in pairs(discoveredEntry.discoveredTraits) do
				if traitId ~= "none" then
					local traitDefinition = Traits[traitId]
					if traitDefinition ~= nil then
						table.insert(discoveredTraitNames, traitDefinition.displayName or traitId)
					end
				end
			end
		end

		table.sort(discoveredTraitNames, sortDiscoveredTraitNames)

		table.insert(slots, {
			layoutOrder = layoutOrder,
			resourceId = catalogEntry.resourceId,
			displayName = if isFound then catalogEntry.displayName else "???",
			realDisplayName = catalogEntry.displayName,
			rarity = catalogEntry.rarity,
			rank = catalogEntry.rank,
			color = catalogEntry.color,
			variantId = catalogEntry.variantId,
			isFound = isFound,
			discoveredTraitNames = discoveredTraitNames,
			hoverTitle = if isFound then catalogEntry.displayName else "???",
			hoverAttributesText = if isFound
				then if #discoveredTraitNames > 0 then table.concat(discoveredTraitNames, ", ") else "No attributes found yet"
				else "???",
		})
	end

	return slots
end

function ResourceGuide.getGuideSummary(pickaxeId: string?): any
	local pickaxeDefinition = getResolvedPickaxe(pickaxeId)
	local _, totalChance = buildRarityChances(pickaxeDefinition)

	return {
		pickaxeId = pickaxeDefinition.id,
		pickaxeDisplayName = pickaxeDefinition.displayName,
		totalResourceChance = totalChance,
		totalResourceChanceText = formatPercent(totalChance * 100),
		subtitleText = string.format("Per mine swing with %s equipped.", pickaxeDefinition.displayName),
		hintText = string.format(
			"Resource drops total %s per swing. Better pickaxes raise geode chance and shift weight toward rarer geodes.",
			formatPercent(totalChance * 100)
		),
	}
end

function ResourceGuide.getGuideRows(pickaxeId: string?): { any }
	local pickaxeDefinition = getResolvedPickaxe(pickaxeId)
	local rarityChances, totalChance = buildRarityChances(pickaxeDefinition)
	local rows = {}
	local maxChance = 0

	for _, rarity in ipairs(RARITY_ORDER) do
		maxChance = math.max(maxChance, rarityChances[rarity] or 0)
	end

	for index, rarity in ipairs(RARITY_ORDER) do
		local chance = rarityChances[rarity] or 0
		local share = if totalChance > 0 then chance / totalChance else 0
		local percent = chance * 100
		local accentColor = RARITY_ACCENTS[rarity] or Color3.fromRGB(255, 226, 122)
		local backgroundColor = accentColor:Lerp(Color3.fromRGB(255, 255, 255), 0.68)
		local highlightColor = accentColor:Lerp(Color3.fromRGB(255, 255, 255), 0.36)
		local rank = ResourceVisuals.getRarityRank(rarity)

		table.insert(rows, {
			layoutOrder = index,
			rarity = rarity,
			rank = rank,
			pickaxeId = pickaxeDefinition.id,
			pickaxeDisplayName = pickaxeDefinition.displayName,
			chance = chance,
			share = share,
			barFillShare = if maxChance > 0 then chance / maxChance else 0,
			percentage = percent,
			percentageText = formatPercent(percent),
			countText = string.format("Drop share %s", formatPercent(share * 100)),
			accentColor = accentColor,
			backgroundColor = backgroundColor,
			highlightColor = highlightColor,
		})
	end

	return rows
end

return ResourceGuide
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="24">
          <Properties>
            <string name="Name">ResourceVisuals</string>
            <string name="Source"><![CDATA[--!strict

-- Deterministic shared rules for Resource Visuals so gameplay behavior can be reused by the server, client presentation, and specs.

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = ReplicatedStorage:WaitForChild("Shared")

local Resources = require(Shared.Config.Resources)
local SizeRules = require(Shared.Domain.SizeRules)
local Traits = require(Shared.Config.Traits)

local ResourceVisuals = {}
local MAX_HASH_VALUE = 2147483647

local RESOURCE_RARITY_ORDER = {
	Common = 1,
	Uncommon = 2,
	Rare = 3,
	Epic = 4,
	Legendary = 5,
}

local RESOURCE_RARITY_ACCENTS = {
	Common = Color3.fromRGB(244, 249, 255),
	Uncommon = Color3.fromRGB(188, 145, 255),
	Rare = Color3.fromRGB(108, 228, 193),
	Epic = Color3.fromRGB(118, 213, 255),
	Legendary = Color3.fromRGB(255, 224, 117),
}

