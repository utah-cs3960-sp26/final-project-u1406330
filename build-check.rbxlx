                <string name="Source"><![CDATA[--!strict

local Palette = {
	background = {
		page = Color3.fromRGB(14, 12, 24),
		panel = Color3.fromRGB(24, 20, 39),
		panelAlt = Color3.fromRGB(33, 28, 53),
	},
	accent = Color3.fromRGB(109, 230, 255),
	accentSoft = Color3.fromRGB(201, 175, 255),
	text = Color3.fromRGB(242, 244, 255),
	muted = Color3.fromRGB(167, 171, 201),
	success = Color3.fromRGB(102, 224, 186),
	danger = Color3.fromRGB(235, 111, 146),
	border = Color3.fromRGB(73, 72, 114),
	shadow = Color3.fromRGB(6, 6, 12),
}

return Palette
]]></string>
