        <Item class="ModuleScript" referent="30">
          <Properties>
            <string name="Name">StationTypes</string>
            <string name="Source"><![CDATA[--!strict

export type GridPlacement = {
	plotId: string?,
	x: number,
	y: number,
	width: number,
	height: number,
}

export type StationInstance = {
	id: string,
	stationTypeId: string,
	level: number,
	occupantIds: { string },
	placement: GridPlacement?,
}

export type PlacementRecord = {
	id: string,
	plotId: string?,
	objectType: string,
	objectId: string,
	x: number,
	y: number,
	width: number,
	height: number,
}

return {}

]]></string>
          </Properties>
        </Item>
      </Item>
      <Item class="Folder" referent="31">
        <Properties>
          <string name="Name">Util</string>
        </Properties>
        <Item class="ModuleScript" referent="32">
          <Properties>
            <string name="Name">Id</string>
            <string name="Source"><![CDATA[--!strict

local HttpService = game:GetService("HttpService")

local Id = {}

function Id.new(prefix: string?)
	local guid = HttpService:GenerateGUID(false)
	if prefix == nil or prefix == "" then
		return guid
	end

	return prefix .. "_" .. guid
end

return Id
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="33">
          <Properties>
            <string name="Name">Result</string>
            <string name="Source"><![CDATA[--!strict

export type Result<T, E> = {
	ok: true,
	value: T,
} | {
	ok: false,
	error: E,
}

local Result = {}

function Result.ok<T, E>(value: T): Result<T, E>
	return {
		ok = true,
		value = value,
	}
end

function Result.err<T, E>(errorValue: E): Result<T, E>
	return {
		ok = false,
		error = errorValue,
	}
end

function Result.isOk<T, E>(result: Result<T, E>): boolean
	return result.ok
end

return Result
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="34">
          <Properties>
            <string name="Name">Signal</string>
            <string name="Source"><![CDATA[--!strict

local Signal = {}
Signal.__index = Signal

export type Connection = {
	Disconnect: () -> (),
}

function Signal.new()
	return setmetatable({
		_listeners = {},
	}, Signal)
end

function Signal:Connect(callback: (...any) -> ())
	local listeners = self._listeners
	local connection = {
		Disconnect = function()
			local index = table.find(listeners, callback)
			if index ~= nil then
				table.remove(listeners, index)
			end
		end,
	}

	table.insert(listeners, callback)
	return connection :: Connection
end

function Signal:Fire(...)
	for _, callback in ipairs(self._listeners) do
		callback(...)
	end
end

function Signal:Destroy()
	table.clear(self._listeners)
end

return Signal
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="35">
          <Properties>
            <string name="Name">TableUtil</string>
            <string name="Source"><![CDATA[--!strict

local TableUtil = {}

function TableUtil.shallowCopy<T>(input: T): T
	local copy = {} :: any
	for key, value in pairs(input :: any) do
		copy[key] = value
	end
	return copy
end

function TableUtil.deepCopy<T>(input: T): T
	if type(input) ~= "table" then
		return input
	end

	local copy = {}
	for key, value in pairs(input :: any) do
		copy[TableUtil.deepCopy(key)] = TableUtil.deepCopy(value)
	end
	return copy :: any
end

function TableUtil.reconcile<T>(template: T, value: any): T
	if type(template) ~= "table" then
		if value == nil then
			return template
		end

		return value
	end

	local resolved = {}
	local source = if type(value) == "table" then value else {}

	for key, templateValue in pairs(template :: any) do
		resolved[key] = TableUtil.reconcile(templateValue, source[key])
	end

	for key, sourceValue in pairs(source :: any) do
		if resolved[key] == nil then
			resolved[key] = TableUtil.deepCopy(sourceValue)
		end
	end

	return resolved :: any
end

function TableUtil.merge<T>(base: T, override: T): T
	local result = TableUtil.deepCopy(base)
	for key, value in pairs(override :: any) do
		result[key] = value
	end
	return result
end

return TableUtil
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="36">
          <Properties>
            <string name="Name">Time</string>
            <string name="Source"><![CDATA[--!strict

local Time = {}

function Time.nowUnix()
	return DateTime.now().UnixTimestamp
end

function Time.elapsedSeconds(startUnix: number, endUnix: number?)
	local currentUnix = endUnix or Time.nowUnix()
	return math.max(0, currentUnix - startUnix)
end

function Time.clampSeconds(seconds: number, capSeconds: number)
	return math.clamp(seconds, 0, capSeconds)
end

return Time
]]></string>
          </Properties>
        </Item>
      </Item>
    </Item>
  </Item>
  <Item class="ServerScriptService" referent="37">
    <Properties>
      <string name="Name">ServerScriptService</string>
    </Properties>
    <Item class="Script" referent="38">
      <Properties>
        <string name="Name">Server</string>
        <token name="RunContext">0</token>
        <string name="Source"><![CDATA[local ServerBootstrap = require(script.Bootstrap.ServerBootstrap)

ServerBootstrap.start()
]]></string>
      </Properties>
      <Item class="Folder" referent="39">
        <Properties>
          <string name="Name">Bootstrap</string>
        </Properties>
        <Item class="ModuleScript" referent="40">
          <Properties>
            <string name="Name">ServerBootstrap</string>
            <string name="Source"><![CDATA[--!strict

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")
local Geodes = require(Shared.Config.Geodes)
local RemoteNames = require(Shared.Net.RemoteNames)
local Time = require(Shared.Util.Time)

local function ensureRemotes()
	local Remotes = require(Shared.Net.Remotes)
	local remotes = {}

	local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
	if remotesFolder == nil then
		remotesFolder = Instance.new("Folder")
		remotesFolder.Name = "Remotes"
		remotesFolder.Parent = ReplicatedStorage
	end

	for remoteName, className in pairs(Remotes.definitions) do
		local remote = remotesFolder:FindFirstChild(remoteName)
		if remote == nil then
			remote = Instance.new(className)
			remote.Name = remoteName
			remote.Parent = remotesFolder
		end
		remotes[remoteName] = remote
	end

	return remotes
end

local ServerBootstrap = {}

local function isValidMineTarget(instance)
	if instance == nil or not instance:IsA("BasePart") then
		return false
	end

	if instance:GetAttribute("GemFactoryMineTarget") == true then
		return true
	end

	local current = instance.Parent
	while current ~= nil do
		if current:IsA("Model") and current:GetAttribute("GemFactoryMine") == true then
			return true
		end
		current = current.Parent
	end

	return false
end

local function findMineModel(instance)
	local current = instance
	while current ~= nil do
		if current:IsA("Model") and current:GetAttribute("GemFactoryMine") == true then
			return current
		end
		current = current.Parent
	end

	return nil
end

local function isPositionInsidePart(position, part)
	local localPosition = part.CFrame:PointToObjectSpace(position)
	local halfSize = part.Size / 2
	return math.abs(localPosition.X) <= halfSize.X
		and math.abs(localPosition.Y) <= halfSize.Y
		and math.abs(localPosition.Z) <= halfSize.Z
end

local function isPlayerInsideMine(player, mineTarget)
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if root == nil or not root:IsA("BasePart") then
		return false
	end

	local mineModel = findMineModel(mineTarget)
	if mineModel == nil then
		return false
	end

	for _, descendant in ipairs(mineModel:GetDescendants()) do
		if descendant:IsA("BasePart") and descendant:GetAttribute("GemFactoryMineZone") == true then
			return isPositionInsidePart(root.Position, descendant)
		end
	end

	return false
end

local function resolveServices(remotes)
	local servicesFolder = script.Parent.Parent.Services

	local MockPersistenceService = require(servicesFolder.MockPersistenceService)
	local PlayerDataService = require(servicesFolder.PlayerDataService)
	local PlotService = require(servicesFolder.PlotService)
	local ShopService = require(servicesFolder.ShopService)
	local StationService = require(servicesFolder.StationService)
	local PlacementService = require(servicesFolder.PlacementService)
	local EconomyService = require(servicesFolder.EconomyService)
	local GeodeService = require(servicesFolder.GeodeService)
	local GeodeToolService = require(servicesFolder.GeodeToolService)
	local MiningService = require(servicesFolder.MiningService)
	local PickaxeToolService = require(servicesFolder.PickaxeToolService)
	local GeodeQueueService = require(servicesFolder.GeodeQueueService)
	local DailyRewardsService = require(servicesFolder.DailyRewardsService)
	local OfflineProgressService = require(servicesFolder.OfflineProgressService)
	local WorldReplicaService = require(servicesFolder.WorldReplicaService)
	local RareAnnouncementSystem = require(script.Parent.Parent.Systems.RareAnnouncementSystem)

	local persistence = MockPersistenceService.new()
	local playerData = PlayerDataService.new(persistence)
	local shop = ShopService.new()
	local stations = StationService.new()
	local plot = PlotService.new()
	local placement = PlacementService.new({
		stationService = stations,
	})
	local economy = EconomyService.new({
		playerData = playerData,
		stationService = stations,
	})
	local rareAnnouncements = RareAnnouncementSystem.new(remotes[RemoteNames.RareRevealAnnounced])
	local geode = GeodeService.new({
		playerData = playerData,
		shopService = shop,
		placementService = placement,
	})
	local geodeTools = GeodeToolService.new({
		playerData = playerData,
	})
	local pickaxeTools = PickaxeToolService.new({
		playerData = playerData,
	})
	local mining = MiningService.new({
		playerData = playerData,
		geodeService = geode,
	})
	local geodeQueue = GeodeQueueService.new({
		playerData = playerData,
		geodeService = geode,
		stationService = stations,
		placementService = placement,
		rareAnnouncementService = rareAnnouncements,
	})
	geode.dependencies.geodeQueueService = geodeQueue
	local dailyRewards = DailyRewardsService.new({
		playerData = playerData,
	})
	local offlineProgress = OfflineProgressService.new({
		playerData = playerData,
		economyService = economy,
		geodeQueueService = geodeQueue,
	})
	local worldReplica = WorldReplicaService.new({
		plotService = plot,
		placementService = placement,
		stationService = stations,
		playerDataService = playerData,
	})

	return {
		persistence = persistence,
		playerData = playerData,
		shop = shop,
		stations = stations,
		plot = plot,
		placement = placement,
		economy = economy,
		geode = geode,
		geodeTools = geodeTools,
		mining = mining,
		pickaxeTools = pickaxeTools,
		geodeQueue = geodeQueue,
		dailyRewards = dailyRewards,
		offlineProgress = offlineProgress,
		worldReplica = worldReplica,
		rareAnnouncements = rareAnnouncements,
	}
end

function ServerBootstrap.start()
	local remotes = ensureRemotes()
	local services = resolveServices(remotes)
	local running = true

	local function publishState(userId)
		local player = Players:GetPlayerByUserId(userId)
		if player == nil then
			return
		end

		local state = services.playerData:getPublicState(userId, Time.nowUnix())
		remotes.StateUpdated:FireClient(player, state)
	end

	local function publishShopState()
		local shopState = services.shop:getShopState(Time.nowUnix())
		remotes.ShopRotationUpdated:FireAllClients(shopState)
	end

	services.playerData.onProfileChanged = function(userId)
		publishState(userId)
		services.geodeTools:syncPlayerByUserId(userId)
		services.pickaxeTools:syncPlayerByUserId(userId)
	end

	local function callAction(actionName, action)
		local ok, result = pcall(action)
		if not ok then
			warn("[GemFactory] " .. actionName .. " failed:", result)
			return {
				ok = false,
				errorCode = "internal_error",
			}
		end

		return result
	end

	remotes.GetInitialState.OnServerInvoke = function(player)
		return {
			ok = true,
			state = services.playerData:getPublicState(player.UserId, Time.nowUnix()),
		}
	end

	remotes.RequestBuyGeode.OnServerInvoke = function(player, geodeId)
		return {
			ok = false,
			errorCode = "geode_shop_removed",
		}
	end

	remotes.RequestBuyPickaxe.OnServerInvoke = function(player, pickaxeId)
		return callAction("RequestBuyPickaxe", function()
			local result, errorCode = services.mining:buyPickaxe(player.UserId, pickaxeId)
			if result == nil then
				return {
					ok = false,
					errorCode = errorCode or "purchase_failed",
				}
			end

			return {
				ok = true,
				purchase = result,
			}
		end)
	end

	remotes.RequestEquipPickaxe.OnServerInvoke = function(player, pickaxeId)
		return callAction("RequestEquipPickaxe", function()
			local result, errorCode = services.mining:equipPickaxe(player.UserId, pickaxeId)
			if result == nil then
				return {
					ok = false,
					errorCode = errorCode or "equip_failed",
				}
			end

			return {
				ok = true,
				equip = result,
			}
		end)
	end

	remotes.RequestMine.OnServerInvoke = function(player, pickaxeId, mineTarget)
		return callAction("RequestMine", function()
			if not isValidMineTarget(mineTarget) or not isPlayerInsideMine(player, mineTarget) then
				return {
					ok = false,
					errorCode = "not_inside_mine",
				}
			end

			local mineResult, errorCode = services.mining:mine(player.UserId, pickaxeId, Time.nowUnix())
			if mineResult == nil then
				return {
					ok = false,
					errorCode = errorCode or "mine_failed",
				}
			end

			local reward = mineResult.reward
			return {
				ok = true,
				reward = reward,
				rewardType = reward.rewardType,
				coins = reward.coins,
				geodeId = reward.geodeId,
				geodeTypeId = reward.geodeId,
				geodeDisplayName = reward.geodeId ~= nil and Geodes[reward.geodeId] ~= nil and Geodes[reward.geodeId].displayName or nil,
				geodeInstance = reward.geodeInstance,
				pickaxeId = mineResult.pickaxeId,
			}
		end)
	end

	local function handleOpenGeode(player, geodeId)
		return callAction("RequestCrackGeode", function()
			local openResult, errorCode = services.geode:openGeode(player.UserId, geodeId, Time.nowUnix(), nil, player.Name)
			if openResult == nil then
				return {
					ok = false,
					errorCode = errorCode or "open_failed",
				}
			end

			return {
				ok = true,
				open = openResult,
			}
		end)
	end

	remotes.RequestCrackGeode.OnServerInvoke = handleOpenGeode
	remotes.RequestClaimFinishedGeode.OnServerInvoke = handleOpenGeode

	remotes.RequestPlaceGeode.OnServerInvoke = function(player, geodeInstanceId, x, y)
		return callAction("RequestPlaceGeode", function()
			local placeResult, errorCode = services.geode:placeGeode(player.UserId, geodeInstanceId, x, y)
			if placeResult == nil then
				return {
					ok = false,
					errorCode = errorCode or "placement_failed",
				}
			end

			return {
				ok = true,
				placement = placeResult.placement,
				geode = placeResult.geodeInstance,
			}
		end)
	end

	remotes.RequestClaimDailyReward.OnServerInvoke = function(player)
		return callAction("RequestClaimDailyReward", function()
			local result, errorCode = services.dailyRewards:claimReward(player.UserId, Time.nowUnix())
			if result == nil then
				return {
					ok = false,
					errorCode = errorCode or "reward_failed",
				}
			end

			return {
				ok = true,
				claim = result,
			}
		end)
	end

	remotes.RequestCollectOfflineRewards.OnServerInvoke = function(player)
		return callAction("RequestCollectOfflineRewards", function()
			local result, errorCode = services.offlineProgress:claimOfflineRewards(player.UserId, Time.nowUnix(), nil, player.Name)
			if result == nil then
				return {
					ok = false,
					errorCode = errorCode or "offline_reward_failed",
				}
			end

			return {
				ok = true,
				claim = result,
			}
		end)
	end

	remotes.RequestPlaceStation.OnServerInvoke = function(player, stationTypeId, x, y)
		return callAction("RequestPlaceStation", function()
			local profile = services.playerData:getOrLoadProfile(player.UserId)
			if profile == nil then
				return {
					ok = false,
					errorCode = "profile_not_loaded",
				}
			end

			local requestedStationTypeId = stationTypeId or services.stations:getStarterStationTypeId()
			local station, placementOrReason = services.placement:placeStation(profile, requestedStationTypeId, x, y)
			if station == nil or placementOrReason == nil then
				return {
					ok = false,
					errorCode = placementOrReason or "station_placement_failed",
				}
			end
			local placement = placementOrReason

			local resourceIds = {}
			for _, resourceId in ipairs(profile.resourceOrder) do
				local resource = profile.resourcesById[resourceId]
				if resource ~= nil and resource.stationId == nil then
					table.insert(resourceIds, resourceId)
				end
			end

			local autoAssignment = services.stations:autoAssignResources(profile, resourceIds)
			services.playerData:notifyProfileChanged(player.UserId)

			return {
				ok = true,
				station = station,
				placement = placement,
				autoAssignment = autoAssignment,
			}
		end)
	end

	remotes.RequestMovePlacedObject.OnServerInvoke = function()
		return {
			ok = false,
			errorCode = "not_implemented",
		}
	end

	remotes.RequestUpgradeStation.OnServerInvoke = function()
		return {
			ok = false,
			errorCode = "not_implemented",
		}
	end

	task.spawn(function()
		while running do
			publishShopState()
			task.wait(15)
		end
	end)

	local startOrder = {
		services.persistence,
		services.playerData,
		services.shop,
		services.stations,
		services.plot,
		services.placement,
		services.economy,
		services.geode,
		services.geodeTools,
		services.mining,
		services.pickaxeTools,
		services.geodeQueue,
		services.dailyRewards,
		services.offlineProgress,
		services.worldReplica,
		services.rareAnnouncements,
	}

	for _, service in ipairs(startOrder) do
		if type(service) == "table" and service.start ~= nil then
			service:start(services)
		end
	end

	print("[GemFactory] Server bootstrap started")
	return services
end

return ServerBootstrap


]]></string>
          </Properties>
        </Item>
      </Item>
      <Item class="Folder" referent="41">
        <Properties>
          <string name="Name">Services</string>
        </Properties>
        <Item class="ModuleScript" referent="42">
          <Properties>
            <string name="Name">DailyRewardsService</string>
            <string name="Source"><![CDATA[--!strict

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Resources = require(Shared.Config.Resources)
local DailyRewardsConfig = require(Shared.Config.DailyRewards)
local Id = require(Shared.Util.Id)
local Time = require(Shared.Util.Time)

local DailyRewardsService = {}
DailyRewardsService.__index = DailyRewardsService

function DailyRewardsService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
	}, DailyRewardsService)
end

local function addInventoryCount(container, key, amount)
	container[key] = (container[key] or 0) + amount
end

local function applyReward(profile, reward, nowUnix)
	if reward.rewardType == "coins" then
		profile.currencies.coins += reward.amount
	elseif reward.rewardType == "gems" then
		profile.currencies.gems += reward.amount
	elseif reward.rewardType == "token" then
		profile.currencies.eventTokens += reward.amount
	elseif reward.rewardType == "geode" then
		addInventoryCount(profile.inventory.geodes, reward.rewardId or "unknown_geode", reward.amount)
	elseif reward.rewardType == "boost" then
		addInventoryCount(profile.inventory.items, reward.rewardId or "unknown_boost", reward.amount)
	elseif reward.rewardType == "resource" then
		local resourceDefinition = Resources[reward.rewardId]
		if resourceDefinition ~= nil then
			for _ = 1, reward.amount do
				local resourceId = Id.new("daily_resource")
				profile.resourcesById[resourceId] = {
					id = resourceId,
					resourceTypeId = resourceDefinition.id,
					traitId = "none",
					level = 1,
					stationId = nil,
					obtainedAt = nowUnix,
				}
				table.insert(profile.resourceOrder, resourceId)
			end
		end
	end
end

function DailyRewardsService:getClaimState(profile, nowUnix)
	local rewards = DailyRewardsConfig.days
	local currentDay = math.clamp(profile.dailyRewards.currentDay, 1, #rewards)
	local lastClaimUnix = profile.dailyRewards.lastClaimUnix
	local currentUnix = nowUnix or Time.nowUnix()
	local cooldownSeconds = 24 * 60 * 60
	local resetSeconds = DailyRewardsConfig.streakResetHours * 60 * 60
	local streakExpired = lastClaimUnix ~= nil and (currentUnix - lastClaimUnix) >= resetSeconds
	if streakExpired then
		currentDay = 1
	end

	local canClaim = lastClaimUnix == nil or (currentUnix - lastClaimUnix) >= cooldownSeconds
	local nextClaimUnix = currentUnix
	if not canClaim and lastClaimUnix ~= nil then
		nextClaimUnix = lastClaimUnix + cooldownSeconds
	end

	return {
		canClaim = canClaim,
		currentDay = currentDay,
		nextClaimUnix = nextClaimUnix,
		reward = rewards[currentDay],
		streakExpired = streakExpired,
	}
end

function DailyRewardsService:claimReward(userId, nowUnix)
	local playerData = self.dependencies.playerData
	local profile = playerData:getOrLoadProfile(userId)
	if profile == nil then
		return nil, "profile_not_loaded"
	end

	local state = self:getClaimState(profile, nowUnix)
	if not state.canClaim then
		return nil, "reward_on_cooldown"
	end

	local reward = state.reward
	local currentUnix = nowUnix or Time.nowUnix()
	local result

	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		applyReward(currentProfile, reward, currentUnix)

		currentProfile.dailyRewards.lastClaimUnix = currentUnix
		currentProfile.dailyRewards.currentDay = (state.currentDay % #DailyRewardsConfig.days) + 1
		if state.streakExpired or currentProfile.dailyRewards.streakCount == 0 then
			currentProfile.dailyRewards.streakCount = 1
		else
			currentProfile.dailyRewards.streakCount += 1
		end

		result = {
			reward = reward,
			state = self:getClaimState(currentProfile, currentUnix),
		}

		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function DailyRewardsService:start()
	print("[GemFactory] DailyRewardsService ready")
end

return DailyRewardsService


]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="43">
          <Properties>
            <string name="Name">EconomyService</string>
            <string name="Source"><![CDATA[--!strict

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Resources = require(Shared.Config.Resources)
local EconomyConfig = require(Shared.Config.Economy)
local Stations = require(Shared.Config.Stations)
local Traits = require(Shared.Config.Traits)
local EconomyMath = require(Shared.Domain.EconomyMath)
local Time = require(Shared.Util.Time)

local EconomyService = {}
EconomyService.__index = EconomyService

function EconomyService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
	}, EconomyService)
end

function EconomyService:getPassiveRate(profile)
	local total = 0

	for _, resource in pairs(profile.resourcesById) do
		local resourceDefinition = Resources[resource.resourceTypeId]
		if resourceDefinition ~= nil and resource.stationId ~= nil then
			local traitDefinition = resource.traitId and Traits[resource.traitId] or Traits.none
			local stationInstance = resource.stationId and profile.stationsById[resource.stationId] or nil
			local stationDefinition = stationInstance and Stations[stationInstance.stationTypeId] or nil
			local stationMultiplier = stationDefinition and stationDefinition.incomeMultiplier or 1
			local traitMultiplier = traitDefinition and traitDefinition.multiplier or 1
			local prestigeMultiplier = EconomyMath.getPrestigeMultiplier(
				profile.progression.prestigeCount,
				EconomyConfig.prestigeStep,
				EconomyConfig.basePrestigeMultiplier
			)

			total += EconomyMath.getResourceIncome(resourceDefinition.baseCoinRate, traitMultiplier, stationMultiplier, prestigeMultiplier, 1)
		end
	end

	return total
end

function EconomyService:getCavernValue(profile)
	local resourceValue = 0
	local stationValue = 0

	for _, resource in pairs(profile.resourcesById) do
		local resourceDefinition = Resources[resource.resourceTypeId]
		if resourceDefinition ~= nil then
			resourceValue += resourceDefinition.baseCoinRate * 100
		end
	end

	for _, station in pairs(profile.stationsById) do
		local stationDefinition = Stations[station.stationTypeId]
		if stationDefinition ~= nil then
			stationValue += stationDefinition.capacity * 50
		end
	end

	return math.floor(profile.currencies.coins + (profile.currencies.gems * 100) + resourceValue + stationValue + (self:getPassiveRate(profile) * 120))
end

function EconomyService:getEconomyState(profile)
	return {
		passiveRate = self:getPassiveRate(profile),
		cavernValue = self:getCavernValue(profile),
		prestigeMultiplier = EconomyMath.getPrestigeMultiplier(
			profile.progression.prestigeCount,
			EconomyConfig.prestigeStep,
			EconomyConfig.basePrestigeMultiplier
		),
	}
end

function EconomyService:tickPlayer(userId, profile, nowUnix)
	local currentUnix = nowUnix or Time.nowUnix()
	local lastTickUnix = profile.session.lastPassiveTickUnix or currentUnix
	local elapsedSeconds = math.max(0, currentUnix - lastTickUnix)
	local passiveRate = self:getPassiveRate(profile)
	local awardedCoins, remainder = EconomyMath.resolvePassiveAccrual(
		passiveRate,
		elapsedSeconds,
		profile.session.passiveCoinRemainder
	)

	profile.session.lastPassiveTickUnix = currentUnix
	profile.session.passiveCoinRemainder = remainder

	if awardedCoins <= 0 then
		return 0
	end

	profile.currencies.coins += awardedCoins
	local playerData = self.dependencies.playerData
	if playerData ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	return awardedCoins
end

function EconomyService:flushPlayer(userId, profile, nowUnix)
	return self:tickPlayer(userId, profile, nowUnix)
end

function EconomyService:start(services)
	self.dependencies.playerData = self.dependencies.playerData or services.playerData
	print("[GemFactory] EconomyService ready")

	task.spawn(function()
		while true do
			task.wait(1)

			local playerData = self.dependencies.playerData
			if playerData ~= nil then
				local nowUnix = Time.nowUnix()
				for userKey, profile in pairs(playerData:getActiveProfiles()) do
					local userId = tonumber(userKey)
					if userId ~= nil then
						self:tickPlayer(userId, profile, nowUnix)
					end
				end
			end
		end
	end)
end

return EconomyService


]]></string>
