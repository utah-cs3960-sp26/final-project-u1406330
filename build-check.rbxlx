          <Item class="ModuleScript" referent="85">
            <Properties>
              <string name="Name">MiningController</string>
              <string name="Source"><![CDATA[--!strict

-- Client controller for Mining Controller that coordinates UI, local input, and app-state updates for this slice.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local Shared = ReplicatedStorage:WaitForChild("Shared")

local Geodes = require(Shared.Config.Geodes)
local Pickaxes = require(Shared.Config.Pickaxes)
local RemoteNames = require(Shared.Net.RemoteNames)

local MiningController = {}
MiningController.__index = MiningController

local MINE_TARGET_ATTRIBUTE = "GemFactoryMineTarget"
local PICKAXE_TOOL_ATTRIBUTE = "GemFactoryPickaxeTool"
local MINE_COOLDOWN_SECONDS = 0.35
local MINE_REMOTE_NAME = (RemoteNames :: any).RequestMine or "RequestMine"
local SWING_WINDUP_TIME = 0.07
local SWING_STRIKE_TIME = 0.11
local SWING_RECOVER_TIME = 0.16
local SWING_WINDUP_OFFSET = CFrame.new(0.02, -0.05, 0.04) * CFrame.Angles(math.rad(-18), math.rad(-8), math.rad(20))
local SWING_STRIKE_OFFSET = CFrame.new(-0.04, 0.08, -0.1) * CFrame.Angles(math.rad(42), math.rad(10), math.rad(-34))

local activeSwingByTool = setmetatable({}, { __mode = "k" })
local GEODE_RARITY_BY_ID = {
	starter_geode = "Common",
	crystal_cavern_geode = "Uncommon",
	moonlit_geode = "Rare",
	ember_glass_geode = "Epic",
	verdant_rift_geode = "Mythic",
	aurora_shard_geode = "Legendary",
	thunder_core_geode = "Storm",
	fossil_vault_geode = "Ancient",
	prism_sun_geode = "Prismatic",
	sovereign_nova_geode = "Sovereign",
}
local GEODE_RARITY_ORDER = {
	"Common",
	"Uncommon",
	"Rare",
	"Epic",
	"Mythic",
	"Legendary",
	"Storm",
	"Ancient",
	"Prismatic",
	"Sovereign",
}

local GEODE_RARITY_INDEX_BY_NAME = {}
for index, rarityName in ipairs(GEODE_RARITY_ORDER) do
	GEODE_RARITY_INDEX_BY_NAME[rarityName] = index
end

local function getPickaxeDisplayName(tool: Tool): string
	local pickaxeTypeId = tool:GetAttribute("PickaxeTypeId")
	if type(pickaxeTypeId) == "string" and pickaxeTypeId ~= "" then
		local definition = Pickaxes.catalog[pickaxeTypeId]
		return if definition ~= nil then definition.displayName else pickaxeTypeId
	end

	local pickaxeId = tool:GetAttribute("PickaxeId")
	if type(pickaxeId) == "string" and pickaxeId ~= "" then
		local definition = Pickaxes.catalog[pickaxeId]
		return if definition ~= nil then definition.displayName else pickaxeId
	end

	return tool.Name
end

local function getGeodeCelebrationInfo(geodeTypeId: string?, geodeDisplayName: string?)
	local rarityName = if geodeTypeId ~= nil then GEODE_RARITY_BY_ID[geodeTypeId] else nil
	local geodeDefinition = if geodeTypeId ~= nil then Geodes[geodeTypeId] else nil
	local displayName
	if type(geodeDisplayName) == "string" then
		displayName = geodeDisplayName
	elseif geodeDefinition ~= nil and geodeDefinition.displayName ~= nil then
		displayName = geodeDefinition.displayName
	elseif geodeTypeId ~= nil then
		displayName = geodeTypeId
	else
		displayName = "Geode"
	end
	local rarityIndex = if type(rarityName) == "string" then GEODE_RARITY_INDEX_BY_NAME[rarityName] or 1 else 1

	return {
		geodeTypeId = geodeTypeId,
		geodeDisplayName = displayName,
		rarityLabel = rarityName or "Common",
		rarityIndex = rarityIndex,
		accentColor = if geodeDefinition ~= nil then geodeDefinition.displayColor else nil,
	}
end

local function isMineTarget(target: Instance?): BasePart?
	if target == nil or not target:IsA("BasePart") then
		return nil
	end

	if target:GetAttribute(MINE_TARGET_ATTRIBUTE) == true then
		return target
	end

	local ancestor = target.Parent
	while ancestor ~= nil do
		if ancestor:IsA("Model") and ancestor:GetAttribute("GemFactoryMine") == true then
			return target
		end
		ancestor = ancestor.Parent
	end

	return nil
end

local function playPickaxeSwing(tool: Tool)
	local baseGrip = tool:GetAttribute("GemFactoryBaseGrip")
	if typeof(baseGrip) ~= "CFrame" then
		baseGrip = tool.Grip
		tool:SetAttribute("GemFactoryBaseGrip", baseGrip)
	end

	local activeSwing = activeSwingByTool[tool]
	if activeSwing ~= nil then
		for _, tween in ipairs(activeSwing.tweens) do
			tween:Cancel()
		end
	end

	local swingToken = {}
	local windupGrip = baseGrip * SWING_WINDUP_OFFSET
	local strikeGrip = baseGrip * SWING_STRIKE_OFFSET
	local windupTween = TweenService:Create(
		tool,
		TweenInfo.new(SWING_WINDUP_TIME, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Grip = windupGrip }
	)
	local strikeTween = TweenService:Create(
		tool,
		TweenInfo.new(SWING_STRIKE_TIME, Enum.EasingStyle.Back, Enum.EasingDirection.In),
		{ Grip = strikeGrip }
	)
	local recoverTween = TweenService:Create(
		tool,
		TweenInfo.new(SWING_RECOVER_TIME, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Grip = baseGrip }
	)

	activeSwingByTool[tool] = {
		token = swingToken,
		tweens = { windupTween, strikeTween, recoverTween },
	}

	windupTween.Completed:Connect(function(playbackState)
		local currentSwing = activeSwingByTool[tool]
		if playbackState == Enum.PlaybackState.Completed and currentSwing ~= nil and currentSwing.token == swingToken then
			strikeTween:Play()
		end
	end)

	strikeTween.Completed:Connect(function(playbackState)
		local currentSwing = activeSwingByTool[tool]
		if playbackState == Enum.PlaybackState.Completed and currentSwing ~= nil and currentSwing.token == swingToken then
			recoverTween:Play()
		end
	end)

	recoverTween.Completed:Connect(function()
		local currentSwing = activeSwingByTool[tool]
		if currentSwing ~= nil and currentSwing.token == swingToken then
			activeSwingByTool[tool] = nil
			tool.Grip = baseGrip
		end
	end)

	tool.Grip = baseGrip
	windupTween:Play()
end

function MiningController.new(context)
	return setmetatable({
		context = context or {},
	}, MiningController)
end

function MiningController:start()
	local app = self.context.app
	local screen = self.context.screen
	local mouse = Players.LocalPlayer:GetMouse()
	local lastMineClickAt = 0
	local lastEquippedPickaxeId: string? = nil

	local function getEquippedPickaxeTool()
		local character = Players.LocalPlayer.Character
		if character == nil then
			return nil
		end

		local tool = character:FindFirstChildWhichIsA("Tool")
		if tool == nil then
			return nil
		end

		if tool:GetAttribute(PICKAXE_TOOL_ATTRIBUTE) ~= true then
			return nil
		end

		local pickaxeTypeId = tool:GetAttribute("PickaxeTypeId")
		if type(pickaxeTypeId) ~= "string" or pickaxeTypeId == "" then
			pickaxeTypeId = tool.Name
		end

		return tool, tostring(pickaxeTypeId)
	end

	local function refreshEquippedStatus()
		local equippedTool, pickaxeId = getEquippedPickaxeTool()
		if equippedTool ~= nil and pickaxeId ~= nil and lastEquippedPickaxeId ~= pickaxeId then
			lastEquippedPickaxeId = pickaxeId
			app:setStatus(string.format("Equipped %s. Click the mine to dig.", getPickaxeDisplayName(equippedTool)))
		elseif equippedTool == nil then
			lastEquippedPickaxeId = nil
		end
	end

	RunService.RenderStepped:Connect(refreshEquippedStatus)

	local function handleMineClick()
		local now = os.clock()
		if now - lastMineClickAt < MINE_COOLDOWN_SECONDS then
			return
		end
		lastMineClickAt = now

		local equippedTool, pickaxeId = getEquippedPickaxeTool()
		if equippedTool == nil then
			return
		end
		playPickaxeSwing(equippedTool)

		local mineTarget = isMineTarget(mouse.Target)
		if mineTarget == nil then
			return
		end

		local ok, result = app:invokeRemote(MINE_REMOTE_NAME, pickaxeId, mineTarget)
		if ok and type(result) == "table" and result.ok == true then
			local rewardText = nil
			local rewardPopup = nil
			if type(result.coins) == "number" and result.coins > 0 then
				local coinAmount = math.floor(result.coins + 0.5)
				rewardText = string.format("+%d Coins", coinAmount)
				rewardPopup = {
					kind = "coin",
					headline = rewardText,
					primary = rewardText,
					duration = 0.8,
					compact = true,
				}
			elseif type(result.geodeDisplayName) == "string" or type(result.geodeTypeId) == "string" then
				local displayName = result.geodeDisplayName or result.geodeTypeId
				rewardText = string.format("Unearthed %s.", tostring(displayName))
				rewardPopup = getGeodeCelebrationInfo(result.geodeTypeId, result.geodeDisplayName)
				rewardPopup.kind = "geode_discovery"
				rewardPopup.headline = "GEODE FOUND!"
				rewardPopup.primary = rewardPopup.geodeDisplayName
				rewardPopup.showSlotMachine = false
				rewardPopup.detail = rewardPopup.rarityLabel
			elseif type(result.rewardText) == "string" then
				rewardText = tostring(result.rewardText)
			end

			app:setStatus(rewardText or "Mining hit registered.")
			if screen ~= nil and screen.showMiningPopup ~= nil then
				screen:showMiningPopup(rewardPopup or rewardText or "Mining hit registered")
			end
		else
			local errorText = type(result) == "table" and result.errorCode or result
			if errorText == "mine_cooldown" then
				return
			end
			if errorText == "not_inside_mine" then
				app:setStatus("Stand inside the mine to mine.")
				if screen ~= nil and screen.showMiningPopup ~= nil then
					screen:showMiningPopup("Stand inside the mine")
				end
				return
			end
			app:setStatus("Mining failed: " .. tostring(errorText))
		end
	end

	mouse.Button1Down:Connect(handleMineClick)
end

return MiningController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="86">
            <Properties>
              <string name="Name">NotificationsController</string>
              <string name="Source"><![CDATA[--!strict

-- Client controller for Notifications Controller that coordinates UI, local input, and app-state updates for this slice.

local NotificationsController = {}
NotificationsController.__index = NotificationsController

local function formatNumber(value)
	local text = tostring(math.floor((value or 0) + 0.5))
	while true do
		local nextText = text:gsub("^(-?%d+)(%d%d%d)", "%1,%2")
		if nextText == text then
			break
		end
		text = nextText
	end
	return text
end

function NotificationsController.new(context)
	return setmetatable({
		context = context or {},
	}, NotificationsController)
end

function NotificationsController:start()
	local screen = self.context.screen
	local app = self.context.app

	local function formatDuration(seconds: number): string
		local safeSeconds = math.max(0, math.floor(seconds))
		local hours = math.floor(safeSeconds / 3600)
		local minutes = math.floor((safeSeconds % 3600) / 60)
		local remaining = safeSeconds % 60
		return string.format("%02d:%02d:%02d", hours, minutes, remaining)
	end

	local function formatAnnouncementList(announcements)
		if #announcements == 0 then
			return "No announcements yet."
		end

		local lines = {}
		for index, announcement in ipairs(announcements) do
			if index > 3 then
				table.insert(lines, string.format("...and %d more", #announcements - 3))
				break
			end
			table.insert(lines, tostring(announcement))
		end

		return table.concat(lines, "\n")
	end

	local function refresh(state)
		local profile = state.profile
		local offlineReward = profile.unclaimedOfflineRewards
		local offlineText = "No offline cache ready yet."
		local offlineButtonText = "Claim Offline Cache"
		local offlineEnabled = false

		if offlineReward ~= nil then
			offlineText = string.format(
				"Offline coins: %s\nElapsed: %s\nFinished geodes: %d",
				formatNumber(offlineReward.coins),
				formatDuration(offlineReward.elapsedSeconds),
				#offlineReward.finishedGeodes
			)
			offlineButtonText = string.format("Claim Offline Cache (%s coins)", formatNumber(offlineReward.coins))
			offlineEnabled = true
		end

		screen:setOfflineText(offlineText)
		screen:setOfflineButtonState(offlineEnabled, offlineButtonText)
		screen:setNotificationsText(formatAnnouncementList(state.announcements))
	end

	screen.buttons.claimOffline.Activated:Connect(function()
		app:requestCollectOfflineRewards()
	end)

	self.context.stateChanged:Connect(refresh)
	refresh(app:getState())
end

return NotificationsController


]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="87">
            <Properties>
              <string name="Name">PlacementController</string>
              <string name="Source"><![CDATA[--!strict

-- Client controller for Placement Controller that coordinates UI, local input, and app-state updates for this slice.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Stations = require(Shared.Config.Stations)
local World = require(Shared.Config.World)

local PlacementController = {}
PlacementController.__index = PlacementController

function PlacementController.new(context)
	return setmetatable({
		context = context or {},
	}, PlacementController)
end

function PlacementController:start()
	local screen = self.context.screen
	local app = self.context.app
	local starterStation = Stations[World.starterStationTypeId]

	local function refresh(state)
		local plotId = state.profile.plotState.plotId or "Unassigned"
		local starterPlaced = false
		local placedStationCount = 0
		for _, station in pairs(state.profile.stationsById) do
			if station.placement ~= nil then
				placedStationCount += 1
				if station.stationTypeId == World.starterStationTypeId then
					starterPlaced = true
				end
			end
		end

		screen:setPlacementText(string.format(
			"Placement snaps to a %d x %d cavern grid.\nCurrent lot: %s\nPlaced stations: %d\nStarter station footprint: %dx%d",
			World.plotGridWidth,
			World.plotGridHeight,
			plotId,
			placedStationCount,
			starterStation and starterStation.gridSize.width or 0,
			starterStation and starterStation.gridSize.height or 0
		))

		screen:setPlaceStarterStationButton(
			not starterPlaced and plotId ~= "Unassigned",
			if starterPlaced then "Starter Station Placed" else "Place Starter Station"
		)
	end

	screen.buttons.placeStarterStation.Activated:Connect(function()
		app:requestPlaceStarterStation()
	end)

	self.context.stateChanged:Connect(refresh)
	refresh(app:getState())
end

return PlacementController

]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="88">
            <Properties>
              <string name="Name">PlotController</string>
              <string name="Source"><![CDATA[--!strict

-- Client controller for Plot Controller that coordinates UI, local input, and app-state updates for this slice.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local World = require(Shared.Config.World)

local PlotController = {}
PlotController.__index = PlotController

function PlotController.new(context)
	return setmetatable({
		context = context or {},
	}, PlotController)
end

function PlotController:start()
	local screen = self.context.screen
	local app = self.context.app

	local function refresh(state)
		local profile = state.profile
		local plotId = profile.plotState.plotId or "Unassigned"
		local occupiedCells = 0
		local onPlotGeodes = 0
		local storedGeodes = 0
		local inventoryGeodes = profile.inventory and profile.inventory.geodes or nil

		for _, geode in pairs(profile.geodesById) do
			if geode.placement ~= nil then
				onPlotGeodes += 1
			end
		end

		if type(inventoryGeodes) == "table" then
			for _, amount in pairs(inventoryGeodes) do
				if type(amount) == "number" and amount > 0 then
					storedGeodes += amount
				end
			end
		end

		if storedGeodes == 0 then
			for _, geode in pairs(profile.geodesById) do
				if geode.placement == nil then
					storedGeodes += 1
				end
			end
		end

		for _ in pairs(profile.plotState.gridOccupancy) do
			occupiedCells += 1
		end

		screen:setPlotText(string.format(
			"Cavern Lot: %s\nGrid: %d x %d\nOccupied Cells: %d\nGeodes on plot: %d\nGeodes in inventory: %d\nClick a ready geode on the plot to crack it open.\nUnlocked Zones: %d",
			plotId,
			World.plotGridWidth,
			World.plotGridHeight,
			occupiedCells,
			onPlotGeodes,
			storedGeodes,
			#profile.progression.unlockedZones
		))
	end

	self.context.stateChanged:Connect(refresh)
	refresh(app:getState())
end

return PlotController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="89">
            <Properties>
              <string name="Name">ResourcePlacementGhost</string>
              <string name="Source"><![CDATA[--!strict

-- Client controller for Resource Placement Ghost that coordinates UI, local input, and app-state updates for this slice.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local Shared = ReplicatedStorage:WaitForChild("Shared")

local Resources = require(Shared.Config.Resources)
local ResourceVisuals = require(Shared.Domain.ResourceVisuals)
local SizeRules = require(Shared.Domain.SizeRules)
local World = require(Shared.Config.World)

local ResourcePlacementGhost = {}
ResourcePlacementGhost.__index = ResourcePlacementGhost

local function getPlotBase(plotModel: Model): BasePart?
	local plotBase = plotModel:FindFirstChild("PlotBase")
	if plotBase ~= nil and plotBase:IsA("BasePart") then
		return plotBase
	end

	return nil
end

local function getPlotSurfacePart(plotModel: Model): BasePart?
	local surfaceCollider = plotModel:FindFirstChild("PlotSurfaceCollider")
	if surfaceCollider ~= nil and surfaceCollider:IsA("BasePart") then
		return surfaceCollider
	end

	local trim = plotModel:FindFirstChild("PlotTrim")
	if trim ~= nil and trim:IsA("BasePart") then
		return trim
	end

	return getPlotBase(plotModel)
end

local function getPlotSurfaceTopY(plotModel: Model): number?
	local surfacePart = getPlotSurfacePart(plotModel)
	if surfacePart == nil then
		return nil
	end

	return surfacePart.Position.Y + (surfacePart.Size.Y / 2)
end

local function createGhostPart(parent: Instance, className: "Part" | "WedgePart", name: string, size: Vector3, color: Color3, material: Enum.Material, transparency: number): BasePart
	local part: BasePart = Instance.new(className)
	part.Name = name
	part.Anchored = true
	part.CanCollide = false
	part.CanQuery = false
	part.CanTouch = false
	part.CastShadow = false
	part.Size = size
	part.Color = color
	part.Material = material
	part.Transparency = transparency
	part.Parent = parent
	return part
end

local function blendColor(baseColor: Color3, targetColor: Color3, alpha: number): Color3
	return baseColor:Lerp(targetColor, alpha)
end

local function resolvePlacedVisualProfile(resourceTypeId: string?, sizeId: string?, sizeValue: number?, stableVisualId: any)
	local resolvePlacedProfile = ResourceVisuals.resolvePlacedVisualProfile
	if type(resolvePlacedProfile) == "function" then
		local ok, profile = pcall(resolvePlacedProfile, resourceTypeId, nil, sizeId, sizeValue, stableVisualId)
		if ok and type(profile) == "table" then
			return profile
		end
	end

	return ResourceVisuals.resolveRevealProfile(resourceTypeId, nil, sizeId, sizeValue, stableVisualId)
end

local function normalizeLayoutCandidate(layout, fallbackVariantId: string): { variantId: string, pieces: { [number]: any } }?
	if type(layout) ~= "table" then
		return nil
	end

	local pieces = nil
	if #layout > 0 then
		pieces = layout
	elseif type(layout.pieces) == "table" then
		pieces = layout.pieces
	elseif type(layout.shards) == "table" then
		pieces = layout.shards
	elseif type(layout.crystals) == "table" then
		pieces = layout.crystals
	end

	if pieces == nil then
		return nil
	end

	local variantId = if type(layout.variantId) == "string" then layout.variantId else fallbackVariantId
	return {
		variantId = variantId,
		pieces = pieces,
	}
end

local function resolveProceduralLayout(profile, seedKey: string): { variantId: string, pieces: { [number]: any } }
	local fallbackVariantId = profile.variantId or "gemstone"
	local profileCandidates = {
		profile.crystalDefinitions,
		profile.proceduralLayout,
		profile.placedLayout,
		profile.visualLayout,
		profile.shapeLayout,
	}

	for _, candidate in ipairs(profileCandidates) do
		local normalized = normalizeLayoutCandidate(candidate, fallbackVariantId)
		if normalized ~= nil then
			return normalized
		end
	end

	local resolver = ResourceVisuals.resolvePlacedLayout or ResourceVisuals.resolveProceduralLayout
	if type(resolver) == "function" then
		local ok, layout = pcall(resolver, profile, seedKey)
		local normalized = if ok then normalizeLayoutCandidate(layout, fallbackVariantId) else nil
		if normalized ~= nil then
			return normalized
		end
	end

	return {
		variantId = fallbackVariantId,
		pieces = ResourceVisuals.getOreCrystalDefinitions(fallbackVariantId),
	}
end

local function getPartVerticalBounds(part: BasePart): (number, number)
	local halfHeight = (math.abs(part.CFrame.XVector.Y) * part.Size.X * 0.5)
		+ (math.abs(part.CFrame.YVector.Y) * part.Size.Y * 0.5)
		+ (math.abs(part.CFrame.ZVector.Y) * part.Size.Z * 0.5)
	return part.Position.Y - halfHeight, part.Position.Y + halfHeight
end

local function clearGhostGeometry(model: Model, root: BasePart)
	for _, child in ipairs(model:GetChildren()) do
		if child ~= root then
			child:Destroy()
		end
	end
end

local function groundGhostGeometry(model: Model, root: BasePart): number
	local minY = math.huge
	local maxY = -math.huge
	local parts = {}

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant:IsA("BasePart") and descendant ~= root then
			local partMinY, partMaxY = getPartVerticalBounds(descendant)
			minY = math.min(minY, partMinY)
			maxY = math.max(maxY, partMaxY)
			table.insert(parts, descendant)
		end
	end

	if #parts == 0 then
		return 0
	end

	if minY ~= 0 then
		local lift = -minY
		for _, part in ipairs(parts) do
			part.CFrame += Vector3.new(0, lift, 0)
		end
		maxY += lift
	end

	return maxY
end

local function addCrystalShard(parent: Instance, rootCFrame: CFrame, definition, scale: number, baseHeight: number, baseColor: Color3, glowColor: Color3, index: number)
	local height = definition.height * scale
	local width = definition.width * scale
	local depth = definition.depth * scale
	local shardColor = blendColor(baseColor, glowColor, definition.tint or 0.18)
	local shardCFrame = rootCFrame
		* CFrame.new((definition.x or 0) * scale, baseHeight + (height * 0.5), (definition.z or 0) * scale)
		* CFrame.Angles(math.rad(definition.pitch or 0), math.rad(definition.yaw or 0), math.rad(definition.roll or 0))

	local body = createGhostPart(parent, "Part", string.format("Shard_%d", index), Vector3.new(width, height, depth), shardColor, Enum.Material.Glass, 0.65)
	body.CFrame = shardCFrame

	local capHeight = math.max(0.16, height * 0.2)
	local cap = createGhostPart(
		parent,
		"WedgePart",
		string.format("ShardCap_%d", index),
		Vector3.new(width * 1.04, capHeight, depth * 1.06),
		blendColor(shardColor, glowColor, 0.28),
		Enum.Material.Glass,
		0.52
	)
	cap.CFrame = shardCFrame * CFrame.new(0, (height * 0.5) + (capHeight * 0.28), 0)
end

local function buildCrystalGhost(model: Model, profile, layout)
	local rootCFrame = CFrame.new() * CFrame.Angles(0, math.rad((profile.hash % 360) - 180), 0)
	local baseSize = Vector3.new(2.1, 0.32, 1.64) * profile.scale
	local base = createGhostPart(
		model,
		"Part",
		"OreBase",
		baseSize,
		blendColor(profile.baseColor, Color3.fromRGB(28, 26, 34), 0.72),
		Enum.Material.Slate,
		0.48
	)
	base.CFrame = rootCFrame * CFrame.new(0, -0.42 * profile.scale, 0)

	for index, shard in ipairs(layout.pieces) do
		addCrystalShard(model, rootCFrame, shard, profile.scale, -0.24 * profile.scale, profile.baseColor, profile.glowColor, index)
	end
end

local function buildIngotGhost(model: Model, profile, layout)
	local rootCFrame = CFrame.new() * CFrame.Angles(0, math.rad((profile.hash % 360) - 180), 0)
	for index, shard in ipairs(layout.pieces) do
		local part = createGhostPart(
			model,
			"Part",
			string.format("Ingot_%d", index),
			Vector3.new(shard.width, shard.height, shard.depth) * profile.scale,
			blendColor(profile.baseColor, profile.glowColor, shard.tint or 0.15),
			if index == 1 then Enum.Material.Metal else Enum.Material.SmoothPlastic,
			if index == 1 then 0.5 else 0.58
		)
		part.CFrame = rootCFrame * CFrame.new((shard.x or 0) * profile.scale, ((shard.height or 0.5) * profile.scale * 0.5) - (0.32 * profile.scale), (shard.z or 0) * profile.scale)
	end
end

local function buildEldritchGhost(model: Model, profile, layout)
	local rootCFrame = CFrame.new() * CFrame.Angles(0, math.rad((profile.hash % 360) - 180), 0)
	local core = createGhostPart(
		model,
		"Part",
		"EldritchCore",
		Vector3.new(1.12, 1.6, 1.12) * profile.scale,
		blendColor(profile.baseColor, profile.glowColor, 0.2),
		Enum.Material.Glass,
		0.62
	)
	core.CFrame = rootCFrame * CFrame.new(0, 0.46 * profile.scale, 0)

	local halo = createGhostPart(
		model,
		"Part",
		"EldritchHalo",
		Vector3.new(0.12, 1.6, 1.6) * profile.scale,
		blendColor(profile.accentColor, profile.glowColor, 0.28),
		Enum.Material.Neon,
		0.7
	)
	halo.Shape = Enum.PartType.Cylinder
	halo.CFrame = rootCFrame * CFrame.new(0, 0.86 * profile.scale, 0) * CFrame.Angles(0, 0, math.rad(90))

	for index, shard in ipairs(layout.pieces) do
		addCrystalShard(model, rootCFrame, shard, profile.scale * 0.92, 0.02 * profile.scale, profile.baseColor, profile.glowColor, index)
	end
end

function ResourcePlacementGhost.new()
	local model = Instance.new("Model")
	model.Name = "ResourcePlacementGhost"

	local root = Instance.new("Part")
	root.Name = "Root"
	root.Anchored = true
	root.CanCollide = false
	root.CanQuery = false
	root.CanTouch = false
	root.CastShadow = false
	root.Transparency = 1
	root.Size = Vector3.new(0.25, 0.25, 0.25)
	root.Parent = model
	model.PrimaryPart = root

	local prompt = Instance.new("BillboardGui")
	prompt.Name = "Label"
	prompt.AlwaysOnTop = true
	prompt.Size = UDim2.fromOffset(140, 24)
	prompt.StudsOffset = Vector3.new(0, 2.6, 0)
	prompt.Parent = root

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Size = UDim2.fromScale(1, 1)
	label.Font = Enum.Font.GothamBold
	label.Text = "Treasure"
	label.TextColor3 = Color3.fromRGB(245, 247, 255)
	label.TextSize = 14
	label.TextWrapped = true
	label.Parent = prompt

	return setmetatable({
		model = model,
		root = root,
		prompt = prompt,
		label = label,
		resourceTypeId = nil,
		sizeId = nil,
		sizeValue = nil,
		footprintWidth = 1,
		footprintHeight = 1,
		visible = false,
	}, ResourcePlacementGhost)
end

function ResourcePlacementGhost:setResourceTypeId(resourceTypeId: string?, sizeId: string?, sizeValue: number?)
	if self.resourceTypeId == resourceTypeId and self.sizeId == sizeId and self.sizeValue == sizeValue then
		return
	end

	self.resourceTypeId = resourceTypeId
	self.sizeId = sizeId
	self.sizeValue = sizeValue
	local definition = if resourceTypeId ~= nil then Resources[resourceTypeId] else nil
	local rootSize = ResourceVisuals.getPlacedRootSize(sizeId, sizeValue)
	local stableVisualId = string.format("%s:%s:%s", resourceTypeId or "resource", sizeId or "medium", tostring(sizeValue))
	local profile = resolvePlacedVisualProfile(resourceTypeId, sizeId, sizeValue, stableVisualId)
	local layout = resolveProceduralLayout(profile, stableVisualId)
	if definition ~= nil then
		self.footprintWidth = definition.gridSize and definition.gridSize.width or 1
		self.footprintHeight = definition.gridSize and definition.gridSize.height or 1
		self.label.Text = string.format("%s %s", SizeRules.getDisplayName(sizeId, sizeValue), definition.displayName or "Treasure")
	else
		self.footprintWidth = 1
		self.footprintHeight = 1
		self.label.Text = "Treasure"
	end

	clearGhostGeometry(self.model, self.root)
	if layout.variantId == "ingot" then
		buildIngotGhost(self.model, profile, layout)
	elseif layout.variantId == "eldritch" then
		buildEldritchGhost(self.model, profile, layout)
	else
		buildCrystalGhost(self.model, profile, layout)
	end
	local visualTopY = groundGhostGeometry(self.model, self.root)

	self.root.Size = rootSize
	-- Ground the actual ghost parts first, then place the label from the real visual top
	-- so future procedural layouts can change silhouette without breaking floor alignment.
	self.prompt.StudsOffset = Vector3.new(0, math.max(2.6, visualTopY + 1.2), 0)
end

function ResourcePlacementGhost:getSnappedCell(plotModel: Model, hitPosition: Vector3): (number?, number?, Vector3?)
	local plotBase = getPlotBase(plotModel)
	local plotSurfaceTopY = getPlotSurfaceTopY(plotModel)
	if plotBase == nil or plotSurfaceTopY == nil then
		return nil, nil, nil
	end

	local maxX = World.plotGridWidth - self.footprintWidth + 1
	local maxY = World.plotGridHeight - self.footprintHeight + 1
	if maxX < 1 or maxY < 1 then
		return nil, nil, nil
	end

	local minX = plotBase.Position.X - ((World.plotGridWidth * World.cellSize) / 2)
	local minZ = plotBase.Position.Z - ((World.plotGridHeight * World.cellSize) / 2)
	local cellX = math.floor((hitPosition.X - minX) / World.cellSize) + 1
	local cellY = math.floor((hitPosition.Z - minZ) / World.cellSize) + 1

	if cellX < 1 or cellY < 1 or cellX > maxX or cellY > maxY then
		return nil, nil, nil
	end

	local gridOriginX = plotBase.Position.X - ((World.plotGridWidth * World.cellSize) / 2) + (World.cellSize / 2)
	local gridOriginZ = plotBase.Position.Z - ((World.plotGridHeight * World.cellSize) / 2) + (World.cellSize / 2)
	local worldPosition = Vector3.new(
		gridOriginX + ((cellX - 1) * World.cellSize) + (((self.footprintWidth - 1) * World.cellSize) / 2),
		plotSurfaceTopY,
		gridOriginZ + ((cellY - 1) * World.cellSize) + (((self.footprintHeight - 1) * World.cellSize) / 2)
	)

	return cellX, cellY, worldPosition
end

function ResourcePlacementGhost:showAt(plotModel: Model, hitPosition: Vector3): (number?, number?, Vector3?)
	local cellX, cellY, worldPosition = self:getSnappedCell(plotModel, hitPosition)
	if cellX == nil or cellY == nil or worldPosition == nil then
		self:hide()
		return nil, nil, nil
	end

	self.model.Parent = Workspace
	self.model:PivotTo(CFrame.new(worldPosition))
	self.visible = true
	return cellX, cellY, worldPosition
end

function ResourcePlacementGhost:hide()
	if not self.visible then
		return
	end

	self.visible = false
	self.model.Parent = nil
end

function ResourcePlacementGhost:destroy()
	self.model:Destroy()
end

return ResourcePlacementGhost
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="90">
            <Properties>
              <string name="Name">ShopController</string>
              <string name="Source"><![CDATA[--!strict

-- Client controller for Shop Controller that coordinates UI, local input, and app-state updates for this slice.

local ProximityPromptService = game:GetService("ProximityPromptService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = ReplicatedStorage:WaitForChild("Shared")

local Pickaxes = require(Shared.Config.Pickaxes)
local PickaxeRules = require(Shared.Domain.PickaxeRules)
local RemoteNames = require(Shared.Net.RemoteNames)

local ShopController = {}
ShopController.__index = ShopController

local SHOP_PROMPT_ATTRIBUTE = "GemFactoryShopPrompt"
local SHOP_ROW_Z_INDEX = 62
local SHOP_TEXT_Z_INDEX = 63
local SHOP_BUTTON_Z_INDEX = 64
local SHOP_BADGE_Z_INDEX = 65

local function formatNumber(value: number): string
	local text = tostring(math.floor(value + 0.5))
	while true do
		local nextText = text:gsub("^(-?%d+)(%d%d%d)", "%1,%2")
		if nextText == text then
			break
		end
		text = nextText
	end
	return text
end

local function clearOfferRows(container: Instance)
	for _, child in ipairs(container:GetChildren()) do
		if child:IsA("UIListLayout") or child:IsA("UIPadding") or child:IsA("UIGridLayout") then
			continue
		end
		child:Destroy()
	end
end

local function collectOffers()
	local offers = {}
	for _, pickaxeId in ipairs(Pickaxes.order) do
		local definition = Pickaxes.catalog[pickaxeId]
		if definition ~= nil then
			table.insert(offers, definition)
		end
	end
	return offers
end

local function collectRarityLabels()
	local labels = {}
	for _, pickaxeId in ipairs(Pickaxes.order) do
		local definition = Pickaxes.catalog[pickaxeId]
		if definition ~= nil then
			table.insert(labels, definition.rarity)
		end
	end
	return labels
end

local function getOfferTone(offer)
	local accent = if typeof(offer.displayColor) == "Color3" then offer.displayColor else Color3.fromRGB(255, 190, 97)
	local warmAccent = accent:Lerp(Color3.fromRGB(255, 214, 128), 0.42)
	return {
		card = accent:Lerp(Color3.fromRGB(255, 248, 226), 0.8),
		cardBorder = accent:Lerp(Color3.fromRGB(255, 255, 255), 0.2),
		header = warmAccent,
		headerText = Color3.fromRGB(97, 61, 18),
		bodyText = Color3.fromRGB(105, 71, 29),
		secondaryText = Color3.fromRGB(132, 95, 49),
		button = accent:Lerp(Color3.fromRGB(255, 223, 134), 0.16),
		buttonText = Color3.fromRGB(78, 47, 16),
		statBubble = accent:Lerp(Color3.fromRGB(255, 255, 255), 0.56),
		iconBubble = accent:Lerp(Color3.fromRGB(255, 255, 255), 0.7),
	}
end

local function getActionColors(offerTone, isEquipped: boolean, canPress: boolean)
	if isEquipped then
		return Color3.fromRGB(181, 227, 170), Color3.fromRGB(54, 97, 48), Color3.fromRGB(231, 255, 223)
	end

	if canPress then
		return offerTone.button, offerTone.buttonText, offerTone.cardBorder
	end

	return Color3.fromRGB(207, 188, 167), Color3.fromRGB(114, 88, 66), Color3.fromRGB(244, 233, 223)
end

local function buildOfferSummary(offer)
	return {
		string.format("%d-%d coins", offer.coinRewardMin, offer.coinRewardMax),
		string.format("%d%% geode luck", offer.geodeChance),
		string.format("%.2fs swing", offer.cooldownSeconds),
	}
end

local PICKAXE_TIER_MARKS = {
	stone_pickaxe = "STN",
	copper_pickaxe = "CPR",
	iron_pickaxe = "IRN",
	steel_pickaxe = "STL",
	gold_pickaxe = "GLD",
	platinum_pickaxe = "PLT",
	emerald_pickaxe = "EMR",
	obsidian_pickaxe = "OBS",
	lunar_pickaxe = "LUN",
	crown_pickaxe = "CRN",
}

local function getTierMark(offer)
	return PICKAXE_TIER_MARKS[offer.id] or string.upper(string.sub(offer.displayName, 1, 3))
end

local function createOfferRow(parent: Instance, offer, isOwned: boolean, isEquipped: boolean, canBuy: boolean, actionText: string, onBuy, onEquip)
	local offerTone = getOfferTone(offer)
	local canPress = not isEquipped and (isOwned or canBuy)
	local actionBackground, actionTextColor, actionStrokeColor = getActionColors(offerTone, isEquipped, canPress)

	local row = Instance.new("Frame")
	row.Name = offer.displayName .. "Row"
	row.BackgroundColor3 = offerTone.card
	row.BorderSizePixel = 0
	row.Size = UDim2.new(1, -4, 0, 158)
	row.ZIndex = SHOP_ROW_Z_INDEX
	row.Parent = parent

	local rowCorner = Instance.new("UICorner")
	rowCorner.CornerRadius = UDim.new(0, 24)
	rowCorner.Parent = row

	local rowStroke = Instance.new("UIStroke")
	rowStroke.Color = offerTone.cardBorder
	rowStroke.Thickness = 3
	rowStroke.Transparency = 0.02
	rowStroke.Parent = row

	local rowGradient = Instance.new("UIGradient")
	rowGradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, offerTone.card:Lerp(Color3.fromRGB(255, 255, 255), 0.16)),
		ColorSequenceKeypoint.new(1, offerTone.card:Lerp(Color3.fromRGB(255, 229, 185), 0.06)),
	})
	rowGradient.Rotation = 90
	rowGradient.Parent = row

	local padding = Instance.new("UIPadding")
	padding.PaddingTop = UDim.new(0, 14)
	padding.PaddingBottom = UDim.new(0, 12)
	padding.PaddingLeft = UDim.new(0, 14)
	padding.PaddingRight = UDim.new(0, 14)
	padding.Parent = row

	local body = Instance.new("Frame")
	body.Name = "Body"
	body.BackgroundTransparency = 1
	body.Size = UDim2.fromScale(1, 1)
	body.ZIndex = SHOP_ROW_Z_INDEX
	body.Parent = row

	local bodyLayout = Instance.new("UIListLayout")
	bodyLayout.FillDirection = Enum.FillDirection.Horizontal
	bodyLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
	bodyLayout.SortOrder = Enum.SortOrder.LayoutOrder
	bodyLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	bodyLayout.Padding = UDim.new(0, 12)
	bodyLayout.Parent = body

	local iconBubble = Instance.new("Frame")
	iconBubble.Name = "IconBubble"
	iconBubble.BackgroundColor3 = offerTone.iconBubble
	iconBubble.BorderSizePixel = 0
	iconBubble.LayoutOrder = 1
	iconBubble.Size = UDim2.new(0, 78, 0, 78)
	iconBubble.ZIndex = SHOP_ROW_Z_INDEX
	iconBubble.Parent = body

	local iconCorner = Instance.new("UICorner")
	iconCorner.CornerRadius = UDim.new(1, 0)
	iconCorner.Parent = iconBubble

	local iconStroke = Instance.new("UIStroke")
	iconStroke.Color = offerTone.cardBorder
	iconStroke.Thickness = 3
	iconStroke.Parent = iconBubble

	local iconLabel = Instance.new("TextLabel")
	iconLabel.BackgroundTransparency = 1
	iconLabel.Size = UDim2.fromScale(1, 1)
	iconLabel.Font = Enum.Font.FredokaOne
	-- Short tier marks make the shop easier to scan at a glance without relying on repeated placeholder text.
	iconLabel.Text = getTierMark(offer)
	iconLabel.TextColor3 = offerTone.headerText
	iconLabel.TextSize = 24
	iconLabel.ZIndex = SHOP_TEXT_Z_INDEX
	iconLabel.Parent = iconBubble

	local content = Instance.new("Frame")
	content.Name = "Content"
	content.BackgroundTransparency = 1
	content.LayoutOrder = 2
	content.Size = UDim2.new(1, -226, 1, 0)
	content.ZIndex = SHOP_ROW_Z_INDEX
	content.Parent = body

	local contentLayout = Instance.new("UIListLayout")
	contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
	contentLayout.Padding = UDim.new(0, 6)
	contentLayout.Parent = content

	local rarityChip = Instance.new("TextLabel")
	rarityChip.BackgroundColor3 = offerTone.header
	rarityChip.BorderSizePixel = 0
	rarityChip.LayoutOrder = 1
	rarityChip.Size = UDim2.new(0, 120, 0, 28)
	rarityChip.Font = Enum.Font.FredokaOne
	rarityChip.Text = string.upper(offer.rarity)
	rarityChip.TextColor3 = offerTone.headerText
	rarityChip.TextSize = 14
	rarityChip.ZIndex = SHOP_BADGE_Z_INDEX
	rarityChip.Parent = content

	local rarityCorner = Instance.new("UICorner")
	rarityCorner.CornerRadius = UDim.new(0, 13)
	rarityCorner.Parent = rarityChip

	local rarityStroke = Instance.new("UIStroke")
	rarityStroke.Color = offerTone.cardBorder
	rarityStroke.Thickness = 2
	rarityStroke.Parent = rarityChip

	local title = Instance.new("TextLabel")
	title.BackgroundTransparency = 1
	title.LayoutOrder = 2
	title.Size = UDim2.new(1, 0, 0, 28)
	title.Font = Enum.Font.FredokaOne
	title.Text = offer.displayName
	title.TextColor3 = offerTone.headerText
	title.TextSize = 26
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.ZIndex = SHOP_TEXT_Z_INDEX
	title.Parent = content

	local statsRow = Instance.new("Frame")
	statsRow.Name = "StatsRow"
	statsRow.BackgroundTransparency = 1
	statsRow.LayoutOrder = 3
	statsRow.Size = UDim2.new(1, 0, 0, 32)
	statsRow.ZIndex = SHOP_ROW_Z_INDEX
	statsRow.Parent = content

	local statsLayout = Instance.new("UIListLayout")
	statsLayout.FillDirection = Enum.FillDirection.Horizontal
	statsLayout.SortOrder = Enum.SortOrder.LayoutOrder
	statsLayout.Padding = UDim.new(0, 6)
	statsLayout.Parent = statsRow

	-- Keep the stat chips fixed-height and wrapped in a horizontal row so narrow/mobile panels stay readable without overlapping the action button.
	for index, summaryText in ipairs(buildOfferSummary(offer)) do
		local statBubble = Instance.new("TextLabel")
		statBubble.Name = string.format("Stat%d", index)
		statBubble.BackgroundColor3 = offerTone.statBubble
		statBubble.BorderSizePixel = 0
		statBubble.LayoutOrder = index
		statBubble.Size = UDim2.new(0, if index == 1 then 102 else 92, 0, 30)
		statBubble.Font = Enum.Font.GothamBold
		statBubble.Text = summaryText
		statBubble.TextColor3 = offerTone.secondaryText
		statBubble.TextSize = 12
		statBubble.TextScaled = true
		statBubble.ZIndex = SHOP_TEXT_Z_INDEX
		statBubble.Parent = statsRow

		local statCorner = Instance.new("UICorner")
		statCorner.CornerRadius = UDim.new(0, 12)
		statCorner.Parent = statBubble

		local statStroke = Instance.new("UIStroke")
		statStroke.Color = offerTone.cardBorder
		statStroke.Thickness = 2
		statStroke.Parent = statBubble

		local statConstraint = Instance.new("UITextSizeConstraint")
		statConstraint.MaxTextSize = 12
		statConstraint.MinTextSize = 9
		statConstraint.Parent = statBubble
	end

	local price = Instance.new("TextLabel")
	price.BackgroundTransparency = 1
	price.LayoutOrder = 4
	price.Size = UDim2.new(1, 0, 0, 30)
	price.Font = Enum.Font.GothamBold
	price.Text = if isOwned
		then "Already riding with your tool belt."
		else string.format("%s %s to unlock", formatNumber(offer.price), string.lower(offer.currency))
	price.TextColor3 = offerTone.bodyText
	price.TextSize = 14
	price.TextWrapped = true
	price.TextXAlignment = Enum.TextXAlignment.Left
	price.TextYAlignment = Enum.TextYAlignment.Top
	price.ZIndex = SHOP_TEXT_Z_INDEX
	price.Parent = content

	local actionColumn = Instance.new("Frame")
	actionColumn.Name = "ActionColumn"
	actionColumn.BackgroundTransparency = 1
	actionColumn.LayoutOrder = 3
	actionColumn.Size = UDim2.new(0, 110, 1, 0)
	actionColumn.ZIndex = SHOP_ROW_Z_INDEX
	actionColumn.Parent = body

	local actionBadge = Instance.new("TextLabel")
	actionBadge.BackgroundTransparency = 1
	actionBadge.Position = UDim2.new(0, 0, 0, 14)
	actionBadge.Size = UDim2.new(1, 0, 0, 18)
	actionBadge.Font = Enum.Font.GothamBold
	actionBadge.Text = if isEquipped then "Current" elseif isOwned then "Owned" elseif canBuy then "Ready" else "Locked"
	actionBadge.TextColor3 = offerTone.secondaryText
	actionBadge.TextSize = 12
	actionBadge.TextXAlignment = Enum.TextXAlignment.Center
	actionBadge.ZIndex = SHOP_TEXT_Z_INDEX
	actionBadge.Parent = actionColumn

	local action = Instance.new("TextButton")
	action.Name = "ActionButton"
	action.AnchorPoint = Vector2.new(0.5, 0.5)
	action.AutoButtonColor = canPress
	action.Active = canPress
	action.BackgroundColor3 = actionBackground
	action.BorderSizePixel = 0
	action.Position = UDim2.new(0.5, 0, 0.5, 10)
	action.Size = UDim2.new(1, 0, 0, 62)
	action.Font = Enum.Font.FredokaOne
	action.Text = actionText
	action.TextColor3 = actionTextColor
	action.TextSize = 21
	action.TextWrapped = true
	action.ZIndex = SHOP_BUTTON_Z_INDEX
	action.Parent = actionColumn

	local actionCorner = Instance.new("UICorner")
	actionCorner.CornerRadius = UDim.new(0, 18)
	actionCorner.Parent = action

	local actionStroke = Instance.new("UIStroke")
	actionStroke.Color = actionStrokeColor
	actionStroke.Thickness = 3
	actionStroke.Transparency = 0.02
	actionStroke.Parent = action

	local actionGradient = Instance.new("UIGradient")
	actionGradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, actionBackground:Lerp(Color3.fromRGB(255, 255, 255), 0.1)),
		ColorSequenceKeypoint.new(1, actionBackground:Lerp(Color3.fromRGB(255, 221, 169), 0.08)),
	})
	actionGradient.Rotation = 90
	actionGradient.Parent = action

	action.Activated:Connect(function()
		if isEquipped then
			return
		end

		if isOwned then
			onEquip(offer)
		elseif canBuy then
			onBuy(offer)
		end
	end)
end

function ShopController.new(context)
	return setmetatable({
		context = context or {},
	}, ShopController)
end

function ShopController:_openShop()
	self.context.screen:setShopMenuVisible(true)
	self.context.app:setStatus("Pickaxe Shop opened.")
end

function ShopController:_refresh(state)
	local screen = self.context.screen
	local app = self.context.app
	local profile = state.profile or {}
	local currencies = profile.currencies or {}
	local inventory = profile.inventory or {}
	local ownedPickaxes = inventory.pickaxes or {}
	local equippedPickaxeId = profile.progression and profile.progression.equippedPickaxeId or "stone_pickaxe"
	local equippedPickaxe = Pickaxes.catalog[equippedPickaxeId]
	local coinBalance = currencies.coins or 0

	screen:setShopText("Buy pickaxes at the forge. Better tiers swing faster, pull in more coins, and boost geode luck.")
	screen:setShopMenuSubtitle("Pick a bubbly upgrade and send your mining luck climbing.")
	screen:setShopMenuInfo(string.format(
		"Coin Pouch: %s\nCurrent Pickaxe Pal: %s",
		formatNumber(coinBalance),
		if equippedPickaxe ~= nil then equippedPickaxe.displayName else equippedPickaxeId
	))
	screen:setShopMenuRarities(collectRarityLabels())

	local offerContainer = screen:getShopOfferContainer()
	clearOfferRows(offerContainer)

	for _, offer in ipairs(collectOffers()) do
		local isOwned = ownedPickaxes[offer.id] == true
		local isEquipped = equippedPickaxeId == offer.id
		local isUpgrade = PickaxeRules.isStrictUpgrade(equippedPickaxeId, offer.id)
		local canBuy = not isOwned and isUpgrade and coinBalance >= offer.price
		local actionText = "Need coins"
		if isEquipped then
			actionText = "Equipped"
		elseif isOwned then
			actionText = "Equip"
		elseif not isUpgrade then
			actionText = "Old tier"
		elseif coinBalance >= offer.price then
			actionText = "Buy"
		end
		createOfferRow(
			offerContainer,
			offer,
			isOwned,
			isEquipped,
			canBuy,
			actionText,
			function(selectedOffer)
				local ok, result = app:invokeRemote(RemoteNames.RequestBuyPickaxe, selectedOffer.id)
				if ok and type(result) == "table" and result.ok == true then
					app:setStatus(string.format("%s bought and replaced your current pickaxe.", selectedOffer.displayName))
				else
					local errorText = type(result) == "table" and result.errorCode or result
					app:setStatus("Pickaxe purchase failed: " .. tostring(errorText))
				end
			end,
			function(selectedOffer)
				local ok, result = app:invokeRemote(RemoteNames.RequestEquipPickaxe, selectedOffer.id)
				if ok and type(result) == "table" and result.ok == true then
					app:setStatus(string.format("Equipped %s.", selectedOffer.displayName))
				else
					local errorText = type(result) == "table" and result.errorCode or result
					app:setStatus("Pickaxe equip failed: " .. tostring(errorText))
				end
			end
		)
	end
end

function ShopController:start()
	local app = self.context.app

	self.context.stateChanged:Connect(function(state)
		self:_refresh(state)
	end)

	self.context.screen.shop.closeButton.Activated:Connect(function()
		self.context.screen:setShopMenuVisible(false)
	end)

	ProximityPromptService.PromptTriggered:Connect(function(prompt)
		if prompt ~= nil and prompt:IsA("ProximityPrompt") and prompt:GetAttribute(SHOP_PROMPT_ATTRIBUTE) == true then
			self:_openShop()
		end
	end)

	self.context.screen:setShopMenuVisible(false)
	self:_refresh(app:getState())
end

return ShopController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="91">
            <Properties>
              <string name="Name">SprintController</string>
              <string name="Source"><![CDATA[--!strict

-- Client controller for Sprint Controller that coordinates UI, local input, and app-state updates for this slice.

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local SprintController = {}
SprintController.__index = SprintController

local DEFAULT_WALK_SPEED = 16
local SPRINT_WALK_SPEED = 28

function SprintController.new(context)
	return setmetatable({
		context = context or {},
	}, SprintController)
end

function SprintController:start()
	local function setSpeed(sprinting: boolean)
		local character = Players.LocalPlayer.Character
		if character == nil then
			return
		end
		local humanoid = character:FindFirstChildWhichIsA("Humanoid")
		if humanoid == nil then
			return
		end
		humanoid.WalkSpeed = if sprinting then SPRINT_WALK_SPEED else DEFAULT_WALK_SPEED
	end

	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then
			return
		end
		if input.KeyCode == Enum.KeyCode.LeftShift then
			setSpeed(true)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.KeyCode == Enum.KeyCode.LeftShift then
			setSpeed(false)
		end
	end)

	-- Reset speed on respawn
	Players.LocalPlayer.CharacterAdded:Connect(function(character)
		local humanoid = character:WaitForChild("Humanoid", 5)
		if humanoid then
			(humanoid :: Humanoid).WalkSpeed = DEFAULT_WALK_SPEED
		end
	end)
end

return SprintController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="92">
            <Properties>
              <string name="Name">VaultController</string>
              <string name="Source"><![CDATA[--!strict

-- Client controller for Vault Controller that coordinates UI, local input, and app-state updates for this slice.

local ProximityPromptService = game:GetService("ProximityPromptService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Geodes = require(Shared.Config.Geodes)
local Resources = require(Shared.Config.Resources)
local Traits = require(Shared.Config.Traits)
local SizeRules = require(Shared.Domain.SizeRules)
local VaultMath = require(Shared.Domain.VaultMath)

local VaultController = {}
VaultController.__index = VaultController

local VAULT_PROMPT_ATTRIBUTE = "GemFactoryVaultPrompt"

local RESOURCE_SWATCH_COLORS = {
	quartz = Color3.fromRGB(230, 238, 245),
	amethyst = Color3.fromRGB(160, 100, 230),
	emerald_cluster = Color3.fromRGB(50, 190, 130),
	diamond_core = Color3.fromRGB(120, 220, 255),
	star_shard = Color3.fromRGB(255, 200, 60),
}

local function createRow(parent, titleText, detailText, tint, layoutOrder, itemKind, resourceTypeId)
	local isResource = itemKind == "resource"
	local bgColor = if isResource then Color3.fromRGB(248, 255, 250) else Color3.fromRGB(250, 248, 255)

	local row = Instance.new("Frame")
	row.Name = titleText .. "Row"
	row.BackgroundColor3 = bgColor
	row.BorderSizePixel = 0
	row.LayoutOrder = layoutOrder
	row.Size = UDim2.new(1, -8, 0, 92)
	row.ZIndex = 58
	row.Parent = parent

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 14)
	corner.Parent = row

	local stroke = Instance.new("UIStroke")
	stroke.Color = tint
	stroke.Thickness = 3
	stroke.Parent = row

	local swatchColor = tint
	if isResource and resourceTypeId ~= nil and RESOURCE_SWATCH_COLORS[resourceTypeId] ~= nil then
		swatchColor = RESOURCE_SWATCH_COLORS[resourceTypeId]
	end

	local swatch = Instance.new("Frame")
	swatch.Name = "Swatch"
	swatch.BackgroundColor3 = swatchColor
	swatch.BorderSizePixel = 0
	swatch.Position = UDim2.new(0, 12, 0.5, -24)
	swatch.Size = UDim2.new(0, 48, 0, 48)
	swatch.ZIndex = 59
	swatch.Parent = row

	if isResource then
		local swatchCorner = Instance.new("UICorner")
		swatchCorner.CornerRadius = UDim.new(0, 6)
		swatchCorner.Parent = swatch
		swatch.Rotation = 45

		local innerGem = Instance.new("Frame")
		innerGem.BackgroundColor3 = swatchColor:Lerp(Color3.fromRGB(255, 255, 255), 0.4)
		innerGem.BorderSizePixel = 0
		innerGem.AnchorPoint = Vector2.new(0.5, 0.5)
		innerGem.Position = UDim2.fromScale(0.5, 0.5)
		innerGem.Size = UDim2.new(0, 22, 0, 22)
		innerGem.ZIndex = 60
		innerGem.Parent = swatch

		local innerCorner = Instance.new("UICorner")
		innerCorner.CornerRadius = UDim.new(0, 4)
		innerCorner.Parent = innerGem
	else
		local swatchCorner = Instance.new("UICorner")
		swatchCorner.CornerRadius = UDim.new(0.5, 0)
		swatchCorner.Parent = swatch

		local innerCircle = Instance.new("Frame")
		innerCircle.BackgroundColor3 = swatchColor:Lerp(Color3.fromRGB(255, 255, 255), 0.35)
		innerCircle.BorderSizePixel = 0
		innerCircle.AnchorPoint = Vector2.new(0.5, 0.5)
		innerCircle.Position = UDim2.fromScale(0.5, 0.5)
		innerCircle.Size = UDim2.new(0, 24, 0, 24)
		innerCircle.ZIndex = 60
		innerCircle.Parent = swatch

		local innerCircleCorner = Instance.new("UICorner")
		innerCircleCorner.CornerRadius = UDim.new(0.5, 0)
		innerCircleCorner.Parent = innerCircle
	end

	local typeBadge = Instance.new("TextLabel")
	typeBadge.BackgroundColor3 = if isResource then Color3.fromRGB(210, 245, 225) else Color3.fromRGB(220, 215, 240)
	typeBadge.BorderSizePixel = 0
	typeBadge.Position = UDim2.new(0, 72, 0, 8)
	typeBadge.Size = UDim2.new(0, if isResource then 66 else 54, 0, 18)
	typeBadge.Font = Enum.Font.GothamBold
	typeBadge.Text = if isResource then "RESOURCE" else "GEODE"
	typeBadge.TextColor3 = if isResource then Color3.fromRGB(36, 100, 60) else Color3.fromRGB(70, 50, 110)
	typeBadge.TextSize = 10
	typeBadge.ZIndex = 59
	typeBadge.Parent = row

	local typeBadgeCorner = Instance.new("UICorner")
	typeBadgeCorner.CornerRadius = UDim.new(0, 6)
	typeBadgeCorner.Parent = typeBadge

	local title = Instance.new("TextLabel")
	title.BackgroundTransparency = 1
	title.Position = UDim2.new(0, 72, 0, 28)
	title.Size = UDim2.new(1, -220, 0, 24)
	title.Font = Enum.Font.FredokaOne
	title.Text = titleText
	title.TextColor3 = Color3.fromRGB(71, 48, 20)
	title.TextSize = 20
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.TextTruncate = Enum.TextTruncate.AtEnd
	title.ZIndex = 59
	title.Parent = row

	local detail = Instance.new("TextLabel")
	detail.BackgroundTransparency = 1
	detail.Position = UDim2.new(0, 72, 0, 53)
	detail.Size = UDim2.new(1, -220, 0, 30)
	detail.Font = Enum.Font.GothamBold
	detail.Text = detailText
	detail.TextColor3 = Color3.fromRGB(112, 84, 45)
	detail.TextSize = 13
	detail.TextWrapped = true
	detail.TextXAlignment = Enum.TextXAlignment.Left
	detail.ZIndex = 59
	detail.Parent = row

	return row
end

local function createActionButton(parent, text, color, xOffset)
	local button = Instance.new("TextButton")
	button.BackgroundColor3 = color
	button.BorderSizePixel = 0
	button.Position = UDim2.new(1, xOffset, 0.5, -17)
	button.Size = UDim2.new(0, 78, 0, 34)
	button.Font = Enum.Font.FredokaOne
	button.Text = text
	button.TextColor3 = Color3.fromRGB(48, 34, 14)
	button.TextSize = 16
	button.ZIndex = 60
	button.Parent = parent

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = button

	return button
end

local function getGeodeLabel(geode)
	local definition = geode ~= nil and Geodes[geode.geodeTypeId] or nil
	return definition and definition.displayName or "Geode"
end

local function getResourceLabel(resource)
	local definition = resource ~= nil and Resources[resource.resourceTypeId] or nil
	local trait = resource ~= nil and Traits[resource.traitId or "none"] or nil
	local displayName = definition and definition.displayName or "Treasure"
	if trait ~= nil and trait.id ~= "none" then
		return trait.displayName .. " " .. displayName
	end
	return displayName
end

local function getSizeDetail(item)
	if type(item) ~= "table" then
		return "Size: Medium (1.00x)"
	end

	return "Size: " .. SizeRules.getDisplayText(item.sizeId, item.sizeValue)
end

function VaultController.new(context)
	return setmetatable({
		context = context or {},
	}, VaultController)
end

function VaultController:_openVault()
	self.context.screen:setVaultVisible(true)
	self.context.app:setStatus("Vault opened.")
end

function VaultController:start()
	local screen = self.context.screen
	local app = self.context.app

	local function refresh(state)
		local profile = state.profile
		screen:clearVaultRows()

		local rows = {}
		for _, geodeId in ipairs(profile.geodeOrder or {}) do
			local geode = profile.geodesById[geodeId]
			if geode ~= nil then
				local definition = Geodes[geode.geodeTypeId]
				table.insert(rows, {
					kind = "geode",
					id = geode.id,
					title = getGeodeLabel(geode),
					detail = string.format(
						"%s %s",
						getSizeDetail(geode),
						if geode.placement ~= nil then "On plot. Crack it when ready or sell it." else "In Vault. Place it or sell it."
					),
					tint = definition and definition.displayColor or Color3.fromRGB(180, 190, 210),
					actionText = "Place",
					canPrimaryAction = geode.placement == nil,
					picksUp = false,
					sellValue = VaultMath.getGeodeSellValue(definition),
					resourceTypeId = nil,
				})
			end
		end

		for _, resourceId in ipairs(profile.resourceOrder or {}) do
			local resource = profile.resourcesById[resourceId]
			if resource ~= nil then
				local definition = Resources[resource.resourceTypeId]
				local trait = Traits[resource.traitId or "none"] or Traits.none
				local sizeDefinition = SizeRules.resolveDefinition(resource.sizeId, resource.sizeValue)
				local isPlaced = resource.placement ~= nil
				local isStationAssigned = resource.stationId ~= nil
				local detailSuffix = if isStationAssigned
					then "In a station. Manage it there or sell it."
					elseif isPlaced
					then "On plot. Pick it up or sell it anytime."
					else "In Vault. Place it or sell it."
				table.insert(rows, {
					kind = "resource",
					id = resource.id,
					title = getResourceLabel(resource),
					detail = string.format("%s %s", getSizeDetail(resource), detailSuffix),
					tint = definition and definition.color or Color3.fromRGB(240, 240, 255),
					actionText = if isPlaced then "Pick Up" else "Place",
					canPrimaryAction = not isStationAssigned,
					picksUp = isPlaced,
					sellValue = VaultMath.getResourceSellValue(definition, trait, sizeDefinition),
					resourceTypeId = resource.resourceTypeId,
				})
			end
		end

		table.sort(rows, function(a, b)
			if a.kind == b.kind then
				return a.title < b.title
			end
			return a.kind < b.kind
		end)

		if #rows == 0 then
			local empty = Instance.new("TextLabel")
			empty.BackgroundTransparency = 1
			empty.Size = UDim2.new(1, -8, 0, 120)
			empty.Font = Enum.Font.FredokaOne
			empty.Text = "Mine geodes to fill this Vault."
			empty.TextColor3 = Color3.fromRGB(82, 52, 18)
			empty.TextSize = 26
			empty.TextWrapped = true
			empty.ZIndex = 58
			empty.Parent = screen:getVaultItemContainer()
			return
		end

		for index, rowData in ipairs(rows) do
			local row = createRow(
				screen:getVaultItemContainer(),
				rowData.title,
				string.format("%s Sell: %d coins", rowData.detail, rowData.sellValue),
				rowData.tint,
				index,
				rowData.kind,
				rowData.resourceTypeId
			)

			local place = createActionButton(row, rowData.actionText or "Place", Color3.fromRGB(122, 231, 184), -174)
			place.Active = rowData.canPrimaryAction
			place.AutoButtonColor = rowData.canPrimaryAction
			place.BackgroundColor3 = if rowData.canPrimaryAction then Color3.fromRGB(122, 231, 184) else Color3.fromRGB(180, 180, 180)
			place.Activated:Connect(function()
				if not rowData.canPrimaryAction then
					return
				end

				if rowData.kind == "resource" and rowData.picksUp == true then
					app:requestPickupResource(rowData.id)
				else
					screen:setVaultVisible(false)
					if rowData.kind == "geode" then
						app:beginGeodePlacement(rowData.id)
					else
						app:beginResourcePlacement(rowData.id)
					end
				end
			end)

			local sell = createActionButton(row, "Sell", Color3.fromRGB(255, 195, 91), -88)
			sell.Activated:Connect(function()
				app:requestSellVaultItem(rowData.kind, rowData.id)
			end)
		end
	end

	self.context.stateChanged:Connect(refresh)
	ProximityPromptService.PromptTriggered:Connect(function(prompt)
		if prompt ~= nil and prompt:IsA("ProximityPrompt") and prompt:GetAttribute(VAULT_PROMPT_ATTRIBUTE) == true then
			self:_openVault()
		end
	end)
	screen:setVaultVisible(false)
	refresh(app:getState())
end

return VaultController
]]></string>
            </Properties>
          </Item>
        </Item>
        <Item class="Folder" referent="93">
          <Properties>
            <string name="Name">UI</string>
          </Properties>
          <Item class="Folder" referent="94">
            <Properties>
              <string name="Name">Components</string>
            </Properties>
            <Item class="ModuleScript" referent="95">
              <Properties>
                <string name="Name">Panel</string>
                <string name="Source"><![CDATA[--!strict

-- Reusable UI component module for Panel used by the HUD and screen layer.

local Panel = {}

local function applyStroke(parent: Instance, palette)
	local stroke = Instance.new("UIStroke")
	stroke.Color = palette.border
	stroke.Thickness = 1
	stroke.Transparency = 0.15
	stroke.Parent = parent
	return stroke
end

function Panel.createCard(parent: Instance, title: string, palette, layoutOrder: number?)
	local card = Instance.new("Frame")
	card.Name = title .. "Card"
	card.BackgroundColor3 = palette.background.panel
	card.BorderSizePixel = 0
	card.AutomaticSize = Enum.AutomaticSize.Y
	card.Size = UDim2.new(1, 0, 0, 0)
	card.LayoutOrder = layoutOrder or 0
	card.Parent = parent

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 14)
	corner.Parent = card

	applyStroke(card, palette)

	local padding = Instance.new("UIPadding")
	padding.PaddingTop = UDim.new(0, 14)
	padding.PaddingBottom = UDim.new(0, 14)
	padding.PaddingLeft = UDim.new(0, 14)
	padding.PaddingRight = UDim.new(0, 14)
	padding.Parent = card

	local titleLabel = Instance.new("TextLabel")
	titleLabel.BackgroundTransparency = 1
	titleLabel.Size = UDim2.new(1, 0, 0, 24)
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.Text = title
	titleLabel.TextColor3 = palette.accentSoft
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.TextSize = 18
	titleLabel.Parent = card

	local body = Instance.new("Frame")
	body.Name = "Body"
	body.BackgroundTransparency = 1
	body.AutomaticSize = Enum.AutomaticSize.Y
	body.Position = UDim2.new(0, 0, 0, 30)
	body.Size = UDim2.new(1, 0, 0, 0)
	body.Parent = card

	local bodyLayout = Instance.new("UIListLayout")
	bodyLayout.Padding = UDim.new(0, 10)
	bodyLayout.SortOrder = Enum.SortOrder.LayoutOrder
	bodyLayout.Parent = body

	return {
		frame = card,
		body = body,
		title = titleLabel,
	}
end

function Panel.createLabel(parent: Instance, text: string, palette, layoutOrder: number?)
	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.AutomaticSize = Enum.AutomaticSize.Y
	label.Size = UDim2.new(1, 0, 0, 0)
	label.LayoutOrder = layoutOrder or 0
	label.Font = Enum.Font.Gotham
	label.Text = text
	label.TextColor3 = palette.text
	label.TextSize = 15
	label.TextWrapped = true
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Top
	label.Parent = parent
	return label
end

function Panel.createButton(parent: Instance, text: string, palette, layoutOrder: number?)
	local button = Instance.new("TextButton")
	button.BackgroundColor3 = palette.accent
	button.BorderSizePixel = 0
	button.AutoButtonColor = true
	button.AutomaticSize = Enum.AutomaticSize.Y
	button.Size = UDim2.new(1, 0, 0, 36)
	button.LayoutOrder = layoutOrder or 0
	button.Font = Enum.Font.GothamBold
	button.Text = text
	button.TextColor3 = palette.shadow
	button.TextSize = 15
	button.TextWrapped = true
	button.Parent = parent

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = button

	return button
end

return Panel
]]></string>
              </Properties>
