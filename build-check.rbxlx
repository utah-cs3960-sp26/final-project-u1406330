          <Item class="ModuleScript" referent="63">
            <Properties>
              <string name="Name">GeodeController</string>
              <string name="Source"><![CDATA[--!strict

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Geodes = require(Shared.Config.Geodes)
local Time = require(Shared.Util.Time)

local GeodeController = {}
GeodeController.__index = GeodeController

local function getGeodeDisplayName(geodeTypeId: string?): string
	local geodeDefinition = geodeTypeId ~= nil and Geodes[geodeTypeId] or nil
	if geodeDefinition ~= nil and geodeDefinition.displayName ~= nil then
		return geodeDefinition.displayName
	end

	return geodeTypeId or "Unknown Geode"
end

local function getInventoryCounts(profile: any): { [string]: number }
	local counts = {}
	local inventory = profile.inventory
	local inventoryGeodes = type(inventory) == "table" and inventory.geodes or nil
	local foundInventoryData = false

	if type(inventoryGeodes) == "table" then
		for geodeTypeId, amount in pairs(inventoryGeodes) do
			if type(geodeTypeId) == "string" and type(amount) == "number" and amount > 0 then
				counts[geodeTypeId] = amount
				foundInventoryData = true
			end
		end
	end

	if foundInventoryData then
		return counts
	end

	for _, geodeId in ipairs(profile.geodeOrder or {}) do
		local geode = profile.geodesById[geodeId]
		if type(geode) == "table" and geode.placement == nil then
			local geodeTypeId = geode.geodeTypeId
			if type(geodeTypeId) == "string" then
				counts[geodeTypeId] = (counts[geodeTypeId] or 0) + 1
			end
		end
	end

	return counts
end

local function getGeodeSummary(profile: any, nowUnix: number)
	local geodesById = profile.geodesById or {}
	local geodeOrder = profile.geodeOrder or {}
	local summary = {
		totalCount = 0,
		onPlotCount = 0,
		inventoryCount = 0,
		readyCount = 0,
		crackingCount = 0,
		firstUnplacedGeodeId = nil,
		firstReadyGeodeId = nil,
		inventoryCounts = getInventoryCounts(profile),
	} :: any

	for _, geodeId in ipairs(geodeOrder) do
		local geode = geodesById[geodeId]
		if type(geode) == "table" then
			local endsAt = geode.endsAt or nowUnix
			local isReady = geode.status == "ready" or geode.status == "finished" or endsAt <= nowUnix
			local isPlaced = geode.placement ~= nil

			summary.totalCount += 1
			if isPlaced then
				summary.onPlotCount += 1
				if isReady and summary.firstReadyGeodeId == nil then
					summary.firstReadyGeodeId = geode.id
				end
			else
				summary.inventoryCount += 1
				if summary.firstUnplacedGeodeId == nil then
					summary.firstUnplacedGeodeId = geode.id
				end
			end

			if isReady then
				summary.readyCount += 1
			else
				summary.crackingCount += 1
			end
		end
	end

	if summary.totalCount == 0 then
		for _, amount in pairs(summary.inventoryCounts) do
			summary.totalCount += amount
		end
		summary.inventoryCount = summary.totalCount
	end

	return summary
end

local function buildInventoryLines(summary)
	local entries = {}
	for geodeTypeId, amount in pairs(summary.inventoryCounts) do
		table.insert(entries, {
			geodeTypeId = geodeTypeId,
			amount = amount,
		})
	end

	table.sort(entries, function(a, b)
		return getGeodeDisplayName(a.geodeTypeId) < getGeodeDisplayName(b.geodeTypeId)
	end)

	local lines = {}
	for index, entry in ipairs(entries) do
		if index > 3 then
			table.insert(lines, string.format("...and %d more geode type%s", #entries - 3, if #entries - 3 == 1 then "" else "s"))
			break
		end

		table.insert(lines, string.format("%s x%d", getGeodeDisplayName(entry.geodeTypeId), entry.amount))
	end

	return lines
end

local function getGeodeDisplayNameFromProfile(profile: any, geodeId: string?): string
	if geodeId == nil then
		return "Geode"
	end

	local geode = profile.geodesById ~= nil and profile.geodesById[geodeId] or nil
	if type(geode) == "table" then
		return getGeodeDisplayName(geode.geodeTypeId)
	end

	return "Geode"
end

function GeodeController.new(context)
	return setmetatable({
		context = context or {},
	}, GeodeController)
end

function GeodeController:start()
	local screen = self.context.screen
	local app = self.context.app
	local latestPlaceGeodeId: string? = nil
	local latestOpenGeodeId: string? = nil
	local latestCanPlaceGeode: boolean = false
	local latestCanOpenGeode: boolean = false

	local function refresh(state, nowUnix)
		local profileAny = state.profile :: any
		local plotAssigned = profileAny.plotState ~= nil and profileAny.plotState.plotId ~= nil
		local summary = getGeodeSummary(profileAny, nowUnix)
		local lines = {
			string.format(
				"Inventory: %d | On plot: %d | Cracking: %d | Ready: %d",
				summary.inventoryCount,
				summary.onPlotCount,
				summary.crackingCount,
				summary.readyCount
			),
			"Bought geodes stay in your inventory until you place them.",
			"Click a ready geode on the plot to crack it open.",
		}

		local inventoryLines = buildInventoryLines(summary)
		if #inventoryLines > 0 then
			table.insert(lines, "Stored geodes:")
			for _, inventoryLine in ipairs(inventoryLines) do
				table.insert(lines, inventoryLine)
			end
		end

		if summary.totalCount == 0 then
			screen:setGeodeText("No geodes are active yet.\nBuy a geode from the shop and it will stay in your inventory until you place it.")
			latestPlaceGeodeId = nil
			latestOpenGeodeId = nil
			latestCanPlaceGeode = false
			latestCanOpenGeode = false
			screen:setPlaceGeodeButton(false, "Place Next Geode")
			screen:setOpenReadyGeodeButton(false, "Open Ready Geode")
			return
		end

		screen:setGeodeText(table.concat(lines, "\n"))
		latestPlaceGeodeId = if plotAssigned then summary.firstUnplacedGeodeId else nil
		latestOpenGeodeId = summary.firstReadyGeodeId
		latestCanPlaceGeode = latestPlaceGeodeId ~= nil
		latestCanOpenGeode = latestOpenGeodeId ~= nil

		local placeLabel = "Place Next Geode"
		if latestPlaceGeodeId ~= nil then
			placeLabel = string.format("Place %s", getGeodeDisplayNameFromProfile(profileAny, latestPlaceGeodeId))
		end
		local openLabel = "Open Ready Geode"
		if latestOpenGeodeId ~= nil then
			openLabel = string.format("Open %s", getGeodeDisplayNameFromProfile(profileAny, latestOpenGeodeId))
		end

		screen:setPlaceGeodeButton(latestCanPlaceGeode, placeLabel)
		screen:setOpenReadyGeodeButton(
			latestCanOpenGeode,
			if latestCanOpenGeode then openLabel else "Open Ready Geode"
		)
	end

	screen.buttons.placeGeode.Activated:Connect(function()
		if latestCanPlaceGeode and latestPlaceGeodeId ~= nil then
			app:beginGeodePlacement(latestPlaceGeodeId)
		end
	end)

	screen.buttons.openReadyGeodes.Activated:Connect(function()
		if latestCanOpenGeode and latestOpenGeodeId ~= nil then
			app:requestOpenReadyGeode(latestOpenGeodeId)
		end
	end)

	self.context.stateChanged:Connect(refresh)
	refresh(app:getState(), Time.nowUnix())
end

return GeodeController


]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="64">
            <Properties>
              <string name="Name">GeodeInteractionController</string>
              <string name="Source"><![CDATA[--!strict

local Debris = game:GetService("Debris")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")

local Shared = ReplicatedStorage:WaitForChild("Shared")

local Resources = require(Shared.Config.Resources)
local World = require(Shared.Config.World)

local GeodeInteractionController = {}
GeodeInteractionController.__index = GeodeInteractionController

local CLICK_COOLDOWN_SECONDS = 0.35
local REVEAL_DURATION_SECONDS = 2.4

local function resolveGeodePart(target: BasePart?): BasePart?
	if target == nil then
		return nil
	end

	if string.sub(target.Name, -6) == "_Shell" then
		local parent = target.Parent
		if parent ~= nil then
			local siblingName = string.sub(target.Name, 1, -7)
			local sibling = parent:FindFirstChild(siblingName)
			if sibling ~= nil and sibling:IsA("BasePart") then
				return sibling
			end
		end
	end

	return target
end

local function findPlotModel(instance: Instance?): Model?
	local current: Instance? = instance
	while current ~= nil do
		if current:IsA("Model") and current:GetAttribute("PlotId") ~= nil then
			return current
		end
		current = current.Parent
	end

	return nil
end

local function getReadyStateLabel(geodePart: BasePart): string?
	local readyState = geodePart:GetAttribute("ReadyState")
	if readyState ~= nil then
		return tostring(readyState)
	end

	local geodeState = geodePart:GetAttribute("GeodeState")
	if geodeState ~= nil then
		return tostring(geodeState)
	end

	local marker = geodePart:FindFirstChildWhichIsA("BillboardGui")
	if marker ~= nil then
		local label = marker:FindFirstChildWhichIsA("TextLabel", true)
		if label ~= nil then
			return label.Text
		end
	end

	return nil
end

local function getPlotBase(plotModel: Model): BasePart?
	local plotBase = plotModel:FindFirstChild("PlotBase")
	if plotBase ~= nil and plotBase:IsA("BasePart") then
		return plotBase
	end

	return nil
end

local function getGridCellFromHit(plotModel: Model, hitPosition: Vector3): (number?, number?)
	local plotBase = getPlotBase(plotModel)
	if plotBase == nil then
		return nil
	end

	local minX = plotBase.Position.X - ((World.plotGridWidth * World.cellSize) / 2)
	local minZ = plotBase.Position.Z - ((World.plotGridHeight * World.cellSize) / 2)
	local x = math.floor((hitPosition.X - minX) / World.cellSize) + 1
	local y = math.floor((hitPosition.Z - minZ) / World.cellSize) + 1

	if x < 1 or x > World.plotGridWidth or y < 1 or y > World.plotGridHeight then
		return nil
	end

	return x, y
end

local function extractPrimaryResource(openResult: any)
	if type(openResult) ~= "table" then
		return nil
	end

	local createdResources = openResult.createdResources
	if type(createdResources) == "table" and type(createdResources[1]) == "table" then
		return createdResources[1]
	end

	return nil
end

local function createRevealPart(resourceTypeId: string?, origin: CFrame): BasePart
	local resourceDefinition = if resourceTypeId ~= nil then Resources[resourceTypeId] else nil
	local part = Instance.new("Part")
	part.Name = "RevealedResource"
	part.Anchored = true
	part.CanCollide = false
	part.Material = Enum.Material.Neon
	part.Color = if resourceDefinition ~= nil and resourceDefinition.color ~= nil
		then resourceDefinition.color
		else Color3.fromRGB(240, 240, 255)
	part.Shape = Enum.PartType.Ball
	part.Size = Vector3.new(0.4, 0.4, 0.4)
	part.CFrame = origin

	local light = Instance.new("PointLight")
	light.Range = 12
	light.Brightness = 0
	light.Color = part.Color
	light.Parent = part

	return part
end

local function playRevealAnimation(geodePart: BasePart, openResult: any)
	local shellPart = geodePart.Parent and geodePart.Parent:FindFirstChild(geodePart.Name .. "_Shell")
	local shellColor = if shellPart ~= nil and shellPart:IsA("BasePart") then shellPart.Color else geodePart.Color
	local shellSize = if shellPart ~= nil and shellPart:IsA("BasePart") then shellPart.Size else Vector3.new(3.2, 3.2, 3.2)
	local origin = geodePart.CFrame

	local effectFolder = Instance.new("Folder")
	effectFolder.Name = "GeodeRevealFx"
	effectFolder.Parent = Workspace
	Debris:AddItem(effectFolder, REVEAL_DURATION_SECONDS + 1)

	local leftShell = Instance.new("Part")
	leftShell.Name = "LeftShell"
	leftShell.Anchored = true
	leftShell.CanCollide = false
	leftShell.Material = Enum.Material.Slate
	leftShell.Color = shellColor
	leftShell.Size = Vector3.new(shellSize.X * 0.46, shellSize.Y, shellSize.Z)
	leftShell.CFrame = origin * CFrame.new(-0.8, 0, 0)
	leftShell.Parent = effectFolder

	local rightShell = leftShell:Clone()
	rightShell.Name = "RightShell"
	rightShell.CFrame = origin * CFrame.new(0.8, 0, 0)
	rightShell.Parent = effectFolder

	local openTweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	TweenService:Create(leftShell, openTweenInfo, {
		CFrame = origin * CFrame.new(-2.4, 0.8, 0) * CFrame.Angles(0, 0, math.rad(-22)),
		Transparency = 0.2,
	}):Play()
	TweenService:Create(rightShell, openTweenInfo, {
		CFrame = origin * CFrame.new(2.4, 0.8, 0) * CFrame.Angles(0, 0, math.rad(22)),
		Transparency = 0.2,
	}):Play()

	local resource = extractPrimaryResource(openResult)
	local revealPart = createRevealPart(resource and resource.resourceTypeId or nil, origin)
	revealPart.Parent = effectFolder

	local revealLight = revealPart:FindFirstChildWhichIsA("PointLight")
	TweenService:Create(revealPart, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = Vector3.new(2.15, 2.15, 2.15),
		CFrame = origin * CFrame.new(0, 2.8, 0),
	}):Play()
	if revealLight ~= nil then
		TweenService:Create(revealLight, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Brightness = 2.5,
		}):Play()
	end

	task.spawn(function()
		task.wait(0.28)
		local startedAt = os.clock()
		local basePosition = origin.Position + Vector3.new(0, 2.8, 0)
		local connection
		connection = RunService.RenderStepped:Connect(function()
			local elapsed = os.clock() - startedAt
			if elapsed >= REVEAL_DURATION_SECONDS - 0.28 then
				connection:Disconnect()
				if revealLight ~= nil then
					TweenService:Create(revealLight, TweenInfo.new(0.2), {
						Brightness = 0,
					}):Play()
				end
				TweenService:Create(revealPart, TweenInfo.new(0.25), {
					Transparency = 1,
				}):Play()
				TweenService:Create(leftShell, TweenInfo.new(0.25), {
					Transparency = 1,
				}):Play()
				TweenService:Create(rightShell, TweenInfo.new(0.25), {
					Transparency = 1,
				}):Play()
				return
			end

			local bounceOffset = math.sin(elapsed * 7) * 0.45
			local yaw = elapsed * 2.2
			local scalePulse = 2.15 + (math.sin(elapsed * 10) * 0.12)
			revealPart.Size = Vector3.new(scalePulse, scalePulse, scalePulse)
			revealPart.CFrame = CFrame.new(basePosition + Vector3.new(0, bounceOffset, 0))
				* CFrame.Angles(0, yaw, 0)

			if revealLight ~= nil then
				revealLight.Brightness = 2.2 + (math.sin(elapsed * 12) * 0.6)
			end
		end)
	end)
end

function GeodeInteractionController.new(context)
	return setmetatable({
		context = context or {},
	}, GeodeInteractionController)
end

function GeodeInteractionController:start()
	local app = self.context.app
	local mouse = Players.LocalPlayer:GetMouse()
	local lastClickAt = 0

	local function handleClick()
		local now = os.clock()
		if now - lastClickAt < CLICK_COOLDOWN_SECONDS then
			return
		end
		lastClickAt = now

		local target = mouse.Target
		if target == nil or not target:IsA("BasePart") then
			return
		end

		local plotModel = findPlotModel(target)
		if plotModel == nil then
			if app:getPendingGeodePlacementId() ~= nil then
				app:cancelGeodePlacement()
			end
			return
		end

		local ownerUserId = plotModel:GetAttribute("OwnerUserId")
		if ownerUserId ~= Players.LocalPlayer.UserId then
			return
		end

		local pendingGeodePlacementId = app:getPendingGeodePlacementId()
		if pendingGeodePlacementId ~= nil then
			local x, y = getGridCellFromHit(plotModel, mouse.Hit.Position)
			if x == nil or y == nil then
				app:setStatus("Click a valid cell inside your plot to place the geode.")
				return
			end

			app:requestPlaceGeode(pendingGeodePlacementId, x, y)
			return
		end

		local geodePart = resolveGeodePart(target)
		if geodePart == nil then
			return
		end

		local geodeId = geodePart:GetAttribute("GeodeId")
		local resolvedGeodeId = if geodeId ~= nil then tostring(geodeId) else geodePart.Name
		local readyState = getReadyStateLabel(geodePart)
		if readyState == nil then
			app:setStatus("That geode is not ready to crack yet.")
			return
		end

		local normalizedState = string.lower(readyState)
		if normalizedState ~= "ready" and normalizedState ~= "finished" then
			app:setStatus("That geode is still cracking.")
			return
		end

		local ok, result = app:requestOpenReadyGeode(resolvedGeodeId)
		if ok and type(result) == "table" and result.ok == true then
			playRevealAnimation(geodePart, result.open or result.claim)
		end
	end

	mouse.Button1Down:Connect(handleClick)
end

return GeodeInteractionController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="65">
            <Properties>
              <string name="Name">HUDController</string>
              <string name="Source"><![CDATA[--!strict

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Resources = require(Shared.Config.Resources)
local Stations = require(Shared.Config.Stations)
local Traits = require(Shared.Config.Traits)
local EconomyMath = require(Shared.Domain.EconomyMath)
local EconomyConfig = require(Shared.Config.Economy)
local Time = require(Shared.Util.Time)

local HUDController = {}
HUDController.__index = HUDController

local function countEntries(input)
	local count = 0
	for _ in pairs(input) do
		count += 1
	end
	return count
end

local function formatNumber(value: number): string
	local text = tostring(math.floor(value + 0.5))
	while true do
		local nextText = text:gsub("^(-?%d+)(%d%d%d)", "%1,%2")
		if nextText == text then
			break
		end
		text = nextText
	end
	return text
end

local function computePassiveRate(profile)
	local total = 0

	for _, resource in pairs(profile.resourcesById) do
		local resourceDefinition = Resources[resource.resourceTypeId]
		if resourceDefinition ~= nil and resource.stationId ~= nil then
			local traitDefinition = Traits[resource.traitId or "none"] or Traits.none
			local stationInstance = profile.stationsById[resource.stationId]
			local stationDefinition = stationInstance and Stations[stationInstance.stationTypeId] or nil
			local stationMultiplier = stationDefinition and stationDefinition.incomeMultiplier or 1
			local traitMultiplier = traitDefinition.multiplier or 1
			local prestigeMultiplier = EconomyMath.getPrestigeMultiplier(
				profile.progression.prestigeCount,
				EconomyConfig.prestigeStep,
				EconomyConfig.basePrestigeMultiplier
			)

			total += EconomyMath.getResourceIncome(
				resourceDefinition.baseCoinRate,
				traitMultiplier,
				stationMultiplier,
				prestigeMultiplier,
				1
			)
		end
	end

	return total
end

function HUDController.new(context)
	return setmetatable({
		context = context or {},
	}, HUDController)
end

function HUDController:start()
	local screen = self.context.screen
	local app = self.context.app

	local function refresh(state)
		local profile = state.profile
		local resourceCount = countEntries(profile.resourcesById)
		local stationCount = countEntries(profile.stationsById)
		local queueCount = #profile.geodeQueue
		local passiveRate = computePassiveRate(profile)
		local cavernValue = profile.currencies.coins + (resourceCount * 25) + (stationCount * 50) + (queueCount * 5)
		local plotId = profile.plotState.plotId or "Unassigned"

		screen:setStatusText(state.connectionMessage or "Ready")
		screen:setOverviewText(string.format(
			"Coins: %s\nPassive: %s / sec\nCavern Value: %s\nResources: %d\nStations: %d\nQueue: %d\nPlot: %s",
			formatNumber(profile.currencies.coins),
			formatNumber(passiveRate),
			formatNumber(cavernValue),
			resourceCount,
			stationCount,
			queueCount,
			plotId
		))
	end

	self.context.stateChanged:Connect(refresh)
	refresh(app:getState(), Time.nowUnix())
end

return HUDController


]]></string>
