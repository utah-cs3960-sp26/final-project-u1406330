        <Item class="ModuleScript" referent="53">
          <Properties>
            <string name="Name">EconomyService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Economy Service that validates requests and mutates gameplay state for this system.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Resources = require(Shared.Config.Resources)
local EconomyConfig = require(Shared.Config.Economy)
local Stations = require(Shared.Config.Stations)
local Traits = require(Shared.Config.Traits)
local EconomyMath = require(Shared.Domain.EconomyMath)
local Time = require(Shared.Util.Time)

local EconomyService = {}
EconomyService.__index = EconomyService

function EconomyService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
	}, EconomyService)
end

function EconomyService:getPassiveRate(profile)
	local total = 0

	for _, resource in pairs(profile.resourcesById) do
		local resourceDefinition = Resources[resource.resourceTypeId]
		if resourceDefinition ~= nil and resource.stationId ~= nil then
			local traitDefinition = resource.traitId and Traits[resource.traitId] or Traits.none
			local stationInstance = resource.stationId and profile.stationsById[resource.stationId] or nil
			local stationDefinition = stationInstance and Stations[stationInstance.stationTypeId] or nil
			local stationMultiplier = stationDefinition and stationDefinition.incomeMultiplier or 1
			local traitMultiplier = traitDefinition and traitDefinition.multiplier or 1
			local prestigeMultiplier = EconomyMath.getPrestigeMultiplier(
				profile.progression.prestigeCount,
				EconomyConfig.prestigeStep,
				EconomyConfig.basePrestigeMultiplier
			)

			total += EconomyMath.getResourceIncome(resourceDefinition.baseCoinRate, traitMultiplier, stationMultiplier, prestigeMultiplier, 1)
		end
	end

	return total
end

function EconomyService:getCavernValue(profile)
	local resourceValue = 0
	local stationValue = 0

	for _, resource in pairs(profile.resourcesById) do
		local resourceDefinition = Resources[resource.resourceTypeId]
		if resourceDefinition ~= nil then
			resourceValue += resourceDefinition.baseCoinRate * 100
		end
	end

	for _, station in pairs(profile.stationsById) do
		local stationDefinition = Stations[station.stationTypeId]
		if stationDefinition ~= nil then
			stationValue += stationDefinition.capacity * 50
		end
	end

	return math.floor(profile.currencies.coins + (profile.currencies.gems * 100) + resourceValue + stationValue + (self:getPassiveRate(profile) * 120))
end

function EconomyService:getEconomyState(profile)
	return {
		passiveRate = self:getPassiveRate(profile),
		cavernValue = self:getCavernValue(profile),
		prestigeMultiplier = EconomyMath.getPrestigeMultiplier(
			profile.progression.prestigeCount,
			EconomyConfig.prestigeStep,
			EconomyConfig.basePrestigeMultiplier
		),
	}
end

function EconomyService:tickPlayer(userId, profile, nowUnix)
	local currentUnix = nowUnix or Time.nowUnix()
	local lastTickUnix = profile.session.lastPassiveTickUnix or currentUnix
	local elapsedSeconds = math.max(0, currentUnix - lastTickUnix)
	local passiveRate = self:getPassiveRate(profile)
	local awardedCoins, remainder = EconomyMath.resolvePassiveAccrual(
		passiveRate,
		elapsedSeconds,
		profile.session.passiveCoinRemainder
	)

	profile.session.lastPassiveTickUnix = currentUnix
	profile.session.passiveCoinRemainder = remainder

	if awardedCoins <= 0 then
		return 0
	end

	profile.currencies.coins += awardedCoins
	local playerData = self.dependencies.playerData
	if playerData ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	return awardedCoins
end

function EconomyService:flushPlayer(userId, profile, nowUnix)
	return self:tickPlayer(userId, profile, nowUnix)
end

function EconomyService:start(services)
	self.dependencies.playerData = self.dependencies.playerData or services.playerData
	print("[GemFactory] EconomyService ready")

	task.spawn(function()
		while true do
			task.wait(1)

			local playerData = self.dependencies.playerData
			if playerData ~= nil then
				local nowUnix = Time.nowUnix()
				for userKey, profile in pairs(playerData:getActiveProfiles()) do
					local userId = tonumber(userKey)
					if userId ~= nil then
						self:tickPlayer(userId, profile, nowUnix)
					end
				end
			end
		end
	end)
end

return EconomyService


]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="54">
          <Properties>
            <string name="Name">GeodeQueueService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Geode Queue Service that validates requests and mutates gameplay state for this system.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local GeodeState = require(Shared.Domain.GeodeState)
local ResourceGuide = require(Shared.Domain.ResourceGuide)
local Resources = require(Shared.Config.Resources)
local Traits = require(Shared.Config.Traits)

local GeodeQueueService = {}
GeodeQueueService.__index = GeodeQueueService

function GeodeQueueService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
	}, GeodeQueueService)
end

function GeodeQueueService:timeRemaining(entry, nowUnix)
	return math.max(0, entry.endsAt - nowUnix)
end

function GeodeQueueService:syncQueueCache(profile, nowUnix)
	GeodeState.refreshStatuses(profile.geodesById, profile.geodeOrder, nowUnix)
	profile.geodeQueue = GeodeState.buildQueueEntries(profile.geodesById, profile.geodeOrder, nowUnix)
	return profile.geodeQueue
end

function GeodeQueueService:getClaimableEntries(profile, nowUnix, geodeId)
	self:syncQueueCache(profile, nowUnix)

	local claimable = {}
	for _, geodeInstanceId in ipairs(GeodeState.getClaimableIds(profile, nowUnix, geodeId)) do
		local geodeInstance = profile.geodesById[geodeInstanceId]
		if geodeInstance ~= nil then
			table.insert(claimable, GeodeState.toQueueEntry(geodeInstance, nowUnix))
		end
	end

	return claimable
end

function GeodeQueueService:openGeode(profile, nowUnix, rng, geodeId, playerName)
	return self:claimEntries(profile, nowUnix, rng, geodeId, playerName)
end

local function shouldAnnounceResource(resource)
	local resourceDefinition = Resources[resource.resourceTypeId]
	if resourceDefinition == nil then
		return false
	end

	if resource.traitId ~= nil and resource.traitId ~= "none" then
		return true
	end

	local rarity = resourceDefinition.rarity
	return rarity == "Rare" or rarity == "Epic" or rarity == "Legendary"
end

local function getTraitLabel(traitId)
	if traitId == nil then
		return "none"
	end

	local traitDefinition = Traits[traitId]
	if traitDefinition ~= nil then
		return traitDefinition.displayName
	end

	return traitId
end

function GeodeQueueService:getQueueState(profile, nowUnix)
	local queueEntries = self:syncQueueCache(profile, nowUnix)
	local queuedCount = 0
	local finishedCount = 0
	local nextReadyUnix = nil
	local entries = {}

	for _, entry in ipairs(queueEntries) do
		local remaining = self:timeRemaining(entry, nowUnix)
		local entryState = {
			id = entry.id,
			geodeId = entry.geodeId,
			status = entry.status,
			remainingSeconds = remaining,
			endsAt = entry.endsAt,
			isPlaced = profile.geodesById[entry.id] ~= nil and profile.geodesById[entry.id].placement ~= nil,
		}

		table.insert(entries, entryState)

		if entry.status == "finished" then
			finishedCount += 1
		elseif remaining > 0 then
			queuedCount += 1
			if nextReadyUnix == nil or entry.endsAt < nextReadyUnix then
				nextReadyUnix = entry.endsAt
			end
		else
			finishedCount += 1
		end
	end

	return {
		queuedCount = queuedCount,
		finishedCount = finishedCount,
		nextReadyUnix = nextReadyUnix,
		entries = entries,
	}
end

function GeodeQueueService:claimEntries(profile, nowUnix, rng, geodeId, playerName)
	local claimableEntries = self:getClaimableEntries(profile, nowUnix, geodeId)
	if #claimableEntries == 0 then
		return nil, "no_ready_geodes"
	end

	local geodeService = self.dependencies.geodeService
	local placementService = self.dependencies.placementService
	local rareAnnouncementService = self.dependencies.rareAnnouncementService
	if geodeService == nil then
		return nil, "open_unavailable"
	end
	local createdResources = {}
	local createdResourceIds = {}
	for _, entry in ipairs(claimableEntries) do
		local geodeInstance = profile.geodesById[entry.id]
		if geodeInstance ~= nil then
			local resource, errorCode = geodeService:createResourceInstance(
				geodeInstance.geodeTypeId,
				nowUnix,
				rng,
				geodeInstance.sizeId,
				geodeInstance.sizeValue
			)
			if resource ~= nil then
				profile.resourcesById[resource.id] = resource
				table.insert(profile.resourceOrder, resource.id)
				ResourceGuide.recordDiscovery(profile, resource.resourceTypeId, resource.traitId)
				table.insert(createdResources, resource)
				table.insert(createdResourceIds, resource.id)
				if placementService ~= nil then
					placementService:removeObjectByObjectId(profile, "geode", geodeInstance.id)
				end
				GeodeState.removeGeode(profile.geodesById, profile.geodeOrder, geodeInstance.id)
				if rareAnnouncementService ~= nil and shouldAnnounceResource(resource) then
					local resourceDefinition = Resources[resource.resourceTypeId]
					rareAnnouncementService:announce(
						playerName or "Miner",
						resourceDefinition and resourceDefinition.displayName or resource.resourceTypeId,
						getTraitLabel(resource.traitId)
					)
				end
			else
				warn("[GemFactory] Failed to resolve geode", geodeInstance.geodeTypeId, errorCode)
			end
		end
	end

	local stationService = self.dependencies.stationService
	local autoAssignment = nil
	if stationService ~= nil and #createdResourceIds > 0 then
		autoAssignment = {
			assignedResourceIds = {},
			unassignedResourceIds = createdResourceIds,
		}
	end

	self:syncQueueCache(profile, nowUnix)

	return {
		claimedEntries = claimableEntries,
		createdResources = createdResources,
		createdResourceIds = createdResourceIds,
		autoAssignment = autoAssignment,
	}
end

function GeodeQueueService:start()
	print("[GemFactory] GeodeQueueService ready")
end

return GeodeQueueService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="55">
          <Properties>
            <string name="Name">GeodeService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Geode Service that validates requests and mutates gameplay state for this system.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Resources = require(Shared.Config.Resources)
local Geodes = require(Shared.Config.Geodes)
local Traits = require(Shared.Config.Traits)
local GeodeState = require(Shared.Domain.GeodeState)
local GeodeRoller = require(Shared.Domain.GeodeRoller)
local TraitRoller = require(Shared.Domain.TraitRoller)
local Sizes = require(Shared.Config.Sizes)
local SizeRoller = require(Shared.Domain.SizeRoller)
local SizeRules = require(Shared.Domain.SizeRules)
local Id = require(Shared.Util.Id)
local Time = require(Shared.Util.Time)

local GeodeService = {}
GeodeService.__index = GeodeService

local function getTraitPool()
	return Traits.order or {
		Traits.none,
		Traits.fiery,
		Traits.frosted,
		Traits.verdant,
		Traits.radiant,
		Traits.prismatic,
		Traits.celestial,
		Traits.void_touched,
		Traits.starlit,
		Traits.cosmic,
		Traits.singularity,
	}
end

local function getSizePool()
	return Sizes.order
end

local function getCurrencyAmount(profile, currency)
	if currency == "coins" then
		return profile.currencies.coins
	elseif currency == "gems" then
		return profile.currencies.gems
	elseif currency == "eventTokens" then
		return profile.currencies.eventTokens
	end

	return nil
end

local function spendCurrency(profile, currency, amount)
	if amount <= 0 then
		return true
	end

	if currency == "coins" then
		if profile.currencies.coins < amount then
			return false, "insufficient_coins"
		end
		profile.currencies.coins -= amount
		return true
	elseif currency == "gems" then
		if profile.currencies.gems < amount then
			return false, "insufficient_gems"
		end
		profile.currencies.gems -= amount
		return true
	elseif currency == "eventTokens" then
		if profile.currencies.eventTokens < amount then
			return false, "insufficient_tokens"
		end
		profile.currencies.eventTokens -= amount
		return true
	end

	return false, "unsupported_currency"
end

local function adjustInventoryCount(profile, geodeId, delta)
	local inventory = profile.inventory
	local currentCount = inventory.geodes[geodeId] or 0
	local nextCount = math.max(0, currentCount + delta)
	inventory.geodes[geodeId] = nextCount
	return nextCount
end

function GeodeService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
	}, GeodeService)
end

function GeodeService:getDefinition(geodeId)
	return Geodes[geodeId]
end

function GeodeService:adjustInventoryCount(profile, geodeId, delta)
	return adjustInventoryCount(profile, geodeId, delta)
end

function GeodeService:createGeodeInstance(profile, geodeId, nowUnix, rng)
	local geodeDefinition = Geodes[geodeId]
	if geodeDefinition == nil then
		return nil, "unknown_geode"
	end

	local sizeRoll = SizeRoller.rollSize(getSizePool(), rng)
	local sizeId = sizeRoll and sizeRoll.id or "medium"
	local sizeValue = SizeRules.getScaleValue(sizeId, if sizeRoll ~= nil then sizeRoll.scaleValue else nil)
	local geodeInstance = GeodeState.createInstance(Id.new("geode"), geodeId, nowUnix, geodeDefinition.geodeSeconds, sizeId, sizeValue)
	profile.geodesById[geodeInstance.id] = geodeInstance
	table.insert(profile.geodeOrder, geodeInstance.id)
	adjustInventoryCount(profile, geodeId, 1)
	return geodeInstance
end

function GeodeService:buyGeode(userId, geodeId, nowUnix, rng)
	local playerData = self.dependencies.playerData
	local shopService = self.dependencies.shopService
	local profile = playerData:getOrLoadProfile(userId)
	if profile == nil then
		return nil, "profile_not_loaded"
	end

	local geodeDefinition = Geodes[geodeId]
	if geodeDefinition == nil then
		return nil, "unknown_geode"
	end

	local offer = shopService:getOffer(geodeId, nowUnix)
	if offer == nil then
		return nil, "offer_unavailable"
	end

	local balance = getCurrencyAmount(profile, offer.currency)
	if balance == nil then
		return nil, "unsupported_currency"
	end

	if balance < offer.price then
		return nil, "insufficient_funds"
	end

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		local spent, spendError = spendCurrency(currentProfile, offer.currency, offer.price)
		if not spent then
			return nil, spendError
		end

		local geodeInstance, geodeError = self:createGeodeInstance(currentProfile, geodeId, nowUnix)
		if geodeInstance == nil then
			return nil, geodeError
		end

		result = {
			offer = offer,
			geodeEntry = GeodeState.toQueueEntry(geodeInstance, nowUnix),
			geodeInstance = geodeInstance,
			inventoryCount = currentProfile.inventory.geodes[geodeId] or 0,
		}

		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function GeodeService:placeGeode(userId, geodeInstanceId, x, y)
	local playerData = self.dependencies.playerData
	local placementService = self.dependencies.placementService
	if placementService == nil then
		return nil, "placement_unavailable"
	end

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		local geodeInstance = currentProfile.geodesById[geodeInstanceId]
		if geodeInstance == nil then
			return nil, "unknown_geode_instance"
		end

		local placedGeode, placementOrReason = placementService:placeGeode(currentProfile, geodeInstance, x, y)
		if placedGeode == nil or placementOrReason == nil then
			return nil, placementOrReason or "geode_placement_failed"
		end

		adjustInventoryCount(currentProfile, geodeInstance.geodeTypeId, -1)

		result = {
			geodeInstance = placedGeode,
			placement = placementOrReason,
		}

		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function GeodeService:openGeode(userId, geodeInstanceId, nowUnix, rng, playerName)
	local playerData = self.dependencies.playerData
	local geodeQueueService = self.dependencies.geodeQueueService
	if geodeQueueService == nil then
		return nil, "open_unavailable"
	end

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		result = geodeQueueService:openGeode(currentProfile, nowUnix, rng, geodeInstanceId, playerName)
		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function GeodeService:createResourceInstance(geodeId, nowUnix, rng, sizeId, sizeValue)
	local geodeDefinition = Geodes[geodeId]
	if geodeDefinition == nil then
		return nil, "unknown_geode"
	end

	local resourceRoll = GeodeRoller.rollGeode(geodeDefinition, rng)
	if resourceRoll == nil then
		return nil, "invalid_roll"
	end

	local traitRoll = TraitRoller.rollTrait(getTraitPool(), rng)
	local resourceDefinition = Resources[resourceRoll.resourceId]
	if resourceDefinition == nil then
		return nil, "unknown_resource"
	end

	return {
		id = Id.new("resource"),
		resourceTypeId = resourceDefinition.id,
		traitId = traitRoll and traitRoll.id or "none",
		sizeId = sizeId or "medium",
		sizeValue = SizeRules.getScaleValue(sizeId, sizeValue),
		level = 1,
		stationId = nil,
		obtainedAt = nowUnix,
		placement = nil,
	}
end

function GeodeService:createRewardResourceInstance(resourceId, nowUnix)
	local resourceDefinition = Resources[resourceId]
	if resourceDefinition == nil then
		return nil, "unknown_resource"
	end

	return {
		id = Id.new("resource"),
		resourceTypeId = resourceDefinition.id,
		traitId = "none",
		sizeId = "medium",
		sizeValue = SizeRules.getScaleValue("medium", nil),
		level = 1,
		stationId = nil,
		obtainedAt = nowUnix,
		placement = nil,
	}
end

function GeodeService:resolveGeode(geodeId, rng)
	return self:createResourceInstance(geodeId, Time.nowUnix(), rng)
end

function GeodeService:start()
	print("[GemFactory] GeodeService ready")
end

return GeodeService


]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="56">
          <Properties>
            <string name="Name">GeodeToolService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Geode Tool Service that validates requests and mutates gameplay state for this system.

local Players = game:GetService("Players")
local GeodeToolService = {}
GeodeToolService.__index = GeodeToolService

local function getGeodeInstanceId(tool: Instance): string?
	if not tool:IsA("Tool") then
		return nil
	end

	local geodeInstanceId = tool:GetAttribute("GeodeInstanceId")
	if typeof(geodeInstanceId) ~= "string" or geodeInstanceId == "" then
		return nil
	end

	return geodeInstanceId
end

local function getContainer(player, containerName: string)
	local container = player[containerName]
	if container ~= nil then
		return container
	end

	local waitForChild = player.WaitForChild
	if type(waitForChild) == "function" then
		return player:WaitForChild(containerName)
	end

	return nil
end

function GeodeToolService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
		playerConnections = {},
		syncInProgress = {},
		syncQueued = {},
	}, GeodeToolService)
end

function GeodeToolService:syncPlayerTools(player)
	local backpack = getContainer(player, "Backpack")
	local starterGear = getContainer(player, "StarterGear")
	local character = player.Character
	if backpack == nil or starterGear == nil then
		return
	end

	if character ~= nil then
		for _, child in ipairs(character:GetChildren()) do
			local geodeInstanceId = getGeodeInstanceId(child)
			if geodeInstanceId ~= nil then
				child:Destroy()
			end
		end
	end

	for _, child in ipairs(starterGear:GetChildren()) do
		local geodeInstanceId = getGeodeInstanceId(child)
		if geodeInstanceId ~= nil then
			child:Destroy()
		end
	end

	for _, child in ipairs(backpack:GetChildren()) do
		local geodeInstanceId = getGeodeInstanceId(child)
		if geodeInstanceId ~= nil then
			child:Destroy()
		end
	end
end

function GeodeToolService:queuePlayerSync(player)
	local userId = player.UserId
	if self.syncInProgress[userId] then
		self.syncQueued[userId] = true
		return
	end

	self.syncInProgress[userId] = true
	task.spawn(function()
		local ok, errorMessage = pcall(function()
			self:syncPlayerTools(player)
		end)

		if not ok then
			warn("[GemFactory] GeodeToolService sync failed:", errorMessage)
		end

		self.syncInProgress[userId] = nil
		if self.syncQueued[userId] then
			self.syncQueued[userId] = nil
			local refreshedPlayer = Players:GetPlayerByUserId(userId)
			if refreshedPlayer ~= nil then
				self:queuePlayerSync(refreshedPlayer)
			end
		end
	end)
end

function GeodeToolService:syncPlayerByUserId(userId)
	local player = Players:GetPlayerByUserId(userId)
	if player ~= nil then
		self:queuePlayerSync(player)
	end
end

function GeodeToolService:onPlayerAdded(player)
	local userId = player.UserId
	local existingConnection = self.playerConnections[userId]
	if existingConnection ~= nil then
		existingConnection:Disconnect()
	end

	self.playerConnections[userId] = player.CharacterAdded:Connect(function()
		self:queuePlayerSync(player)
	end)

	self:queuePlayerSync(player)
end

function GeodeToolService:onPlayerRemoving(player)
	local userId = player.UserId
	local connection = self.playerConnections[userId]
	if connection ~= nil then
		connection:Disconnect()
		self.playerConnections[userId] = nil
	end

	self.syncInProgress[userId] = nil
	self.syncQueued[userId] = nil
end

function GeodeToolService:start()
	Players.PlayerAdded:Connect(function(player)
		self:onPlayerAdded(player)
	end)

	Players.PlayerRemoving:Connect(function(player)
		self:onPlayerRemoving(player)
	end)

	for _, player in ipairs(Players:GetPlayers()) do
		self:onPlayerAdded(player)
	end

	print("[GemFactory] GeodeToolService ready; geodes are stored in Vault")
end

return GeodeToolService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="57">
          <Properties>
            <string name="Name">MiningService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Mining Service that validates requests and mutates gameplay state for this system.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local MiningRewards = require(Shared.Domain.MiningRewards)
local PickaxeRules = require(Shared.Domain.PickaxeRules)
local Pickaxes = require(Shared.Config.Pickaxes)

local MiningService = {}
MiningService.__index = MiningService

local function getCurrencyAmount(profile, currency)
	if currency == "coins" then
		return profile.currencies.coins
	elseif currency == "gems" then
		return profile.currencies.gems
	elseif currency == "eventTokens" then
		return profile.currencies.eventTokens
	end

	return nil
end

local function spendCurrency(profile, currency, amount)
	if amount <= 0 then
		return true
	end

	if currency == "coins" then
		if profile.currencies.coins < amount then
			return false, "insufficient_coins"
		end
		profile.currencies.coins -= amount
		return true
	elseif currency == "gems" then
		if profile.currencies.gems < amount then
			return false, "insufficient_gems"
		end
		profile.currencies.gems -= amount
		return true
	elseif currency == "eventTokens" then
		if profile.currencies.eventTokens < amount then
			return false, "insufficient_tokens"
		end
		profile.currencies.eventTokens -= amount
		return true
	end

	return false, "unsupported_currency"
end

local function ensurePickaxeState(profile)
	profile.inventory.pickaxes = profile.inventory.pickaxes or {}
	profile.inventory.pickaxes, profile.progression.equippedPickaxeId = PickaxeRules.normalizeOwnedPickaxes(
		profile.inventory.pickaxes,
		profile.progression.equippedPickaxeId
	)
	return profile.progression.equippedPickaxeId
end

function MiningService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
		-- Cooldowns are tracked outside profiles so reconnecting or profile saves do not
		-- implicitly change the live input cadence enforced by the running server.
		lastMineAtByUserId = {},
	}, MiningService)
end

function MiningService:getPickaxeDefinition(pickaxeId: string?)
	if pickaxeId == nil then
		return nil
	end

	return Pickaxes.catalog[pickaxeId]
end

function MiningService:buyPickaxe(userId, pickaxeId)
	local playerData = self.dependencies.playerData
	local profile = playerData:getOrLoadProfile(userId)
	if profile == nil then
		return nil, "profile_not_loaded"
	end

	local pickaxeDefinition = self:getPickaxeDefinition(pickaxeId)
	if pickaxeDefinition == nil then
		return nil, "unknown_pickaxe"
	end

	local balance = getCurrencyAmount(profile, pickaxeDefinition.currency)
	if balance == nil then
		return nil, "unsupported_currency"
	end

	if balance < pickaxeDefinition.price then
		return nil, "insufficient_funds"
	end

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		local currentPickaxeId = ensurePickaxeState(currentProfile)
		if currentProfile.inventory.pickaxes[pickaxeId] == true then
			return nil, "pickaxe_already_owned"
		end
		if not PickaxeRules.isStrictUpgrade(currentPickaxeId, pickaxeId) then
			return nil, "pickaxe_not_upgrade"
		end

		local spent, spendError = spendCurrency(currentProfile, pickaxeDefinition.currency, pickaxeDefinition.price)
		if not spent then
			return nil, spendError
		end

		currentProfile.inventory.pickaxes = {
			[pickaxeId] = true,
		}
		currentProfile.progression.equippedPickaxeId = pickaxeId

		result = {
			pickaxeId = pickaxeId,
			pickaxe = pickaxeDefinition,
			ownedPickaxes = currentProfile.inventory.pickaxes,
			equippedPickaxeId = pickaxeId,
		}

		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function MiningService:equipPickaxe(userId, pickaxeId)
	local playerData = self.dependencies.playerData
	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		ensurePickaxeState(currentProfile)
		if Pickaxes.catalog[pickaxeId] == nil then
			return nil, "unknown_pickaxe"
		end
		if currentProfile.inventory.pickaxes[pickaxeId] ~= true then
			return nil, "pickaxe_not_owned"
		end

		currentProfile.progression.equippedPickaxeId = pickaxeId
		result = {
			pickaxeId = pickaxeId,
			pickaxe = Pickaxes.catalog[pickaxeId],
		}
		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function MiningService:mine(userId, requestedPickaxeId, nowUnix, rng)
	local playerData = self.dependencies.playerData
	local geodeService = self.dependencies.geodeService
	local profile = playerData:getOrLoadProfile(userId)
	if profile == nil then
		return nil, "profile_not_loaded"
	end

	ensurePickaxeState(profile)

	local pickaxeId = requestedPickaxeId or profile.progression.equippedPickaxeId or "stone_pickaxe"
	local pickaxeDefinition = self:getPickaxeDefinition(pickaxeId)
	if pickaxeDefinition == nil then
		return nil, "unknown_pickaxe"
	end

	if profile.inventory.pickaxes[pickaxeId] ~= true then
		return nil, "pickaxe_not_owned"
	end

	local nowClock = os.clock()
	local lastMineAt = self.lastMineAtByUserId[userId]
	if lastMineAt ~= nil and nowClock - lastMineAt < pickaxeDefinition.cooldownSeconds then
		return nil, "mine_cooldown"
	end

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		ensurePickaxeState(currentProfile)
		if currentProfile.inventory.pickaxes[pickaxeId] ~= true then
			return nil, "pickaxe_not_owned"
		end

		currentProfile.progression.equippedPickaxeId = pickaxeId
		-- The reward roll happens inside the profile mutation so the awarded state and the
		-- resulting inventory/currency changes are committed together or rejected together.
		local reward, rewardError = MiningRewards.rollReward(pickaxeDefinition, rng)
		if reward == nil then
			return nil, rewardError or "mine_roll_failed"
		end

		if reward.rewardType == "coins" then
			currentProfile.currencies.coins += reward.coins or 0
		elseif reward.rewardType == "geode" then
			if geodeService == nil then
				return nil, "geode_service_unavailable"
			end

			-- Geodes are created through GeodeService so size rolls, lifecycle timestamps, and
			-- instance bookkeeping stay centralized in one authoritative place.
			local geodeInstance, geodeError = geodeService:createGeodeInstance(currentProfile, reward.geodeId, nowUnix)
			if geodeInstance == nil then
				return nil, geodeError or "geode_create_failed"
			end
			reward.geodeInstance = geodeInstance
		else
			return nil, "unknown_reward"
		end

		result = {
			reward = reward,
			pickaxe = pickaxeDefinition,
			pickaxeId = pickaxeId,
		}
		return result
	end)

	if result ~= nil then
		self.lastMineAtByUserId[userId] = nowClock
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function MiningService:start()
	print("[GemFactory] MiningService ready")
end

return MiningService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="58">
          <Properties>
            <string name="Name">MockPersistenceService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Mock Persistence Service that validates requests and mutates gameplay state for this system.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local TableUtil = require(Shared.Util.TableUtil)

local MockPersistenceService = {}
MockPersistenceService.__index = MockPersistenceService

function MockPersistenceService.new()
	return setmetatable({
		store = {},
		seeds = {},
	}, MockPersistenceService)
end

function MockPersistenceService:load(userId)
	local userKey = tostring(userId)
	local stored = self.store[userKey]
	if stored ~= nil then
		return TableUtil.deepCopy(stored)
	end

	local seed = self.seeds[userKey]
	if seed ~= nil then
		return TableUtil.deepCopy(seed)
	end

	return nil
end

function MockPersistenceService:save(userId, profile)
	self.store[tostring(userId)] = TableUtil.deepCopy(profile)
end

function MockPersistenceService:seed(userId, profile)
	self.seeds[tostring(userId)] = TableUtil.deepCopy(profile)
end

function MockPersistenceService:reset()
	table.clear(self.store)
	table.clear(self.seeds)
end

function MockPersistenceService:start()
	print("[GemFactory] MockPersistenceService ready")
end

return MockPersistenceService

]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="59">
          <Properties>
            <string name="Name">OfflineProgressService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Offline Progress Service that validates requests and mutates gameplay state for this system.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local EconomyConfig = require(Shared.Config.Economy)
local OfflineMath = require(Shared.Domain.OfflineMath)
local Time = require(Shared.Util.Time)

local OfflineProgressService = {}
OfflineProgressService.__index = OfflineProgressService

function OfflineProgressService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
	}, OfflineProgressService)
end

function OfflineProgressService:buildSummary(profile, nowUnix)
	local passiveRate = self.dependencies.economyService:getPassiveRate(profile)
	local geodeQueueService = self.dependencies.geodeQueueService
	local summary = OfflineMath.buildSummary(
		profile.session.lastLogoutUnix,
		nowUnix,
		passiveRate,
		EconomyConfig.offlineCapSeconds
	)

	if summary == nil then
		return nil
	end

	local claimableEntries = if geodeQueueService ~= nil then geodeQueueService:getClaimableEntries(profile, nowUnix) else {}
	summary.finishedGeodes = {}
	for _, entry in ipairs(claimableEntries) do
		table.insert(summary.finishedGeodes, entry.id)
	end
	return summary
end

function OfflineProgressService:claimOfflineRewards(userId, nowUnix, rng, playerName)
	local playerData = self.dependencies.playerData
	local geodeQueueService = self.dependencies.geodeQueueService
	local profile = playerData:getOrLoadProfile(userId)
	if profile == nil then
		return nil, "profile_not_loaded"
	end

	local currentUnix = nowUnix or Time.nowUnix()
	local summary = profile.unclaimedOfflineRewards or self:buildSummary(profile, currentUnix)
	if summary == nil then
		return nil, "no_offline_rewards"
	end

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		currentProfile.currencies.coins += summary.coins
		local geodeResult = geodeQueueService:claimEntries(currentProfile, currentUnix, rng, nil, playerName)

		currentProfile.unclaimedOfflineRewards = nil
		currentProfile.session.lastLogoutUnix = nil

		result = {
			summary = summary,
			reveals = geodeResult,
		}

		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function OfflineProgressService:start()
	print("[GemFactory] OfflineProgressService ready")
end

return OfflineProgressService



]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="60">
          <Properties>
            <string name="Name">PickaxeToolService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Pickaxe Tool Service that validates requests and mutates gameplay state for this system.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")
local Shared = ReplicatedStorage:WaitForChild("Shared")
local Server = ServerScriptService:WaitForChild("Server")

local Pickaxes = require(Shared.Config.Pickaxes)
local PickaxeModelBuilder = require(Server.Util.PickaxeModelBuilder)

local PickaxeToolService = {}
PickaxeToolService.__index = PickaxeToolService

local function getPickaxeId(tool: Instance): string?
	if not tool:IsA("Tool") then
		return nil
	end

	local pickaxeId = tool:GetAttribute("PickaxeId") or tool:GetAttribute("PickaxeTypeId")
	if typeof(pickaxeId) ~= "string" or pickaxeId == "" then
		return nil
	end

	return pickaxeId
end

local function getContainer(player, containerName: string)
	local container = player[containerName]
	if container ~= nil then
		return container
	end

	local waitForChild = player.WaitForChild
	if type(waitForChild) == "function" then
		return player:WaitForChild(containerName)
	end

	return nil
end

local function collectOwnedPickaxes(profile)
	local owned = {}
	local ownedMap = {}
	local inventory = profile.inventory or {}
	local pickaxes = inventory.pickaxes or {}

	for _, pickaxeId in ipairs(Pickaxes.order) do
		if pickaxes[pickaxeId] == true then
			table.insert(owned, pickaxeId)
			ownedMap[pickaxeId] = true
		end
	end

	return owned, ownedMap
end

function PickaxeToolService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
		playerConnections = {},
		syncInProgress = {},
		syncQueued = {},
	}, PickaxeToolService)
end

function PickaxeToolService:createPickaxeTool(pickaxeId: string)
	local definition = Pickaxes.catalog[pickaxeId]
	local tool = Instance.new("Tool")
	tool.Name = if definition ~= nil then definition.displayName else pickaxeId
	tool.CanBeDropped = false
	tool.ToolTip = tool.Name
	tool:SetAttribute("GemFactoryPickaxeTool", true)
	tool:SetAttribute("PickaxeId", pickaxeId)
	tool:SetAttribute("PickaxeTypeId", pickaxeId)
	if definition ~= nil then
		tool:SetAttribute("PickaxeRarity", definition.rarity)
	end
	PickaxeModelBuilder.addHeldPickaxe(tool, definition)
	return tool
end

function PickaxeToolService:ensurePickaxeToolModel(tool: Tool, pickaxeId: string)
	local definition = Pickaxes.catalog[pickaxeId]
	tool.CanBeDropped = false
	tool.RequiresHandle = true
	if
		tool:FindFirstChild("Handle") == nil
		or tool:GetAttribute("PickaxeModelVersion") ~= PickaxeModelBuilder.getModelVersion()
	then
		PickaxeModelBuilder.addHeldPickaxe(tool, definition)
	end
end

function PickaxeToolService:syncPlayerTools(player)
	local playerData = self.dependencies.playerData
	if playerData == nil then
		return
	end

	local profile = playerData:getProfile(player.UserId)
	if profile == nil then
		return
	end

	local backpack = getContainer(player, "Backpack")
	local starterGear = getContainer(player, "StarterGear")
	local character = player.Character
	if backpack == nil or starterGear == nil then
		return
	end

	local ownedPickaxes, ownedMap = collectOwnedPickaxes(profile)
	local equippedById = {}

	if character ~= nil then
		for _, child in ipairs(character:GetChildren()) do
			local pickaxeId = getPickaxeId(child)
			if pickaxeId ~= nil then
				if ownedMap[pickaxeId] ~= true or equippedById[pickaxeId] == true then
					child:Destroy()
				else
					self:ensurePickaxeToolModel(child :: Tool, pickaxeId)
					equippedById[pickaxeId] = true
				end
			end
		end
	end

	for _, container in ipairs({ starterGear, backpack }) do
		for _, child in ipairs(container:GetChildren()) do
			if getPickaxeId(child) ~= nil then
				child:Destroy()
			end
		end
	end

	for _, pickaxeId in ipairs(ownedPickaxes) do
		self:createPickaxeTool(pickaxeId).Parent = starterGear
		if equippedById[pickaxeId] ~= true then
			self:createPickaxeTool(pickaxeId).Parent = backpack
		end
	end
end

function PickaxeToolService:queuePlayerSync(player)
	local userId = player.UserId
	if self.syncInProgress[userId] then
		self.syncQueued[userId] = true
		return
	end

	self.syncInProgress[userId] = true
	task.spawn(function()
		local ok, errorMessage = pcall(function()
			self:syncPlayerTools(player)
		end)

		if not ok then
			warn("[GemFactory] PickaxeToolService sync failed:", errorMessage)
		end

		self.syncInProgress[userId] = nil
		if self.syncQueued[userId] then
			self.syncQueued[userId] = nil
			local refreshedPlayer = Players:GetPlayerByUserId(userId)
			if refreshedPlayer ~= nil then
				self:queuePlayerSync(refreshedPlayer)
			end
		end
	end)
end

function PickaxeToolService:syncPlayerByUserId(userId)
	local player = Players:GetPlayerByUserId(userId)
	if player ~= nil then
		self:queuePlayerSync(player)
	end
end

function PickaxeToolService:onPlayerAdded(player)
	local userId = player.UserId
	local existingConnection = self.playerConnections[userId]
	if existingConnection ~= nil then
		existingConnection:Disconnect()
	end

	self.playerConnections[userId] = player.CharacterAdded:Connect(function()
		self:queuePlayerSync(player)
	end)

	self:queuePlayerSync(player)
end

function PickaxeToolService:onPlayerRemoving(player)
	local userId = player.UserId
	local connection = self.playerConnections[userId]
	if connection ~= nil then
		connection:Disconnect()
		self.playerConnections[userId] = nil
	end

	self.syncInProgress[userId] = nil
	self.syncQueued[userId] = nil
end

function PickaxeToolService:start()
	Players.PlayerAdded:Connect(function(player)
		self:onPlayerAdded(player)
	end)

	Players.PlayerRemoving:Connect(function(player)
		self:onPlayerRemoving(player)
	end)

	for _, player in ipairs(Players:GetPlayers()) do
		self:onPlayerAdded(player)
	end

	print("[GemFactory] PickaxeToolService ready")
end

return PickaxeToolService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="61">
          <Properties>
            <string name="Name">PlacementService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Placement Service that validates requests and mutates gameplay state for this system.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Geodes = require(Shared.Config.Geodes)
local Resources = require(Shared.Config.Resources)
local World = require(Shared.Config.World)
local PlacementRules = require(Shared.Domain.PlacementRules)
local Id = require(Shared.Util.Id)

local PlacementService = {}
PlacementService.__index = PlacementService

function PlacementService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
	}, PlacementService)
end

function PlacementService:canPlace(profile, x, y, width, height)
	if profile.plotState.plotId == nil then
		return false, "plot_unassigned"
	end

	return PlacementRules.canPlace({
		width = World.plotGridWidth,
		height = World.plotGridHeight,
		}, profile.plotState.gridOccupancy, x, y, width, height)
end

function PlacementService:findFirstOpenCell(profile, width, height)
	if profile.plotState.plotId == nil then
		return nil, "plot_unassigned"
	end

	return PlacementRules.findFirstPlacement({
		width = World.plotGridWidth,
		height = World.plotGridHeight,
	}, profile.plotState.gridOccupancy, width, height)
end

function PlacementService:place(profile, objectType, objectId, x, y, width, height)
	local canPlace, reason = self:canPlace(profile, x, y, width, height)
	if not canPlace then
		return nil, reason
	end

	local placementId = Id.new("placement")
	local record = {
		id = placementId,
		plotId = profile.plotState.plotId,
		objectType = objectType,
		objectId = objectId,
		x = x,
		y = y,
		width = width,
		height = height,
	}

	profile.placedObjects[placementId] = record

	for dx = 0, width - 1 do
		for dy = 0, height - 1 do
			local cellKey = PlacementRules.buildOccupancyKey(x + dx, y + dy)
			profile.plotState.gridOccupancy[cellKey] = placementId
		end
	end

	return record
end

function PlacementService:placeStation(profile, stationTypeId, x, y)
	local stationService = self.dependencies.stationService
	local stationDefinition = stationService and stationService:getDefinition(stationTypeId) or nil

	if stationDefinition == nil then
		return nil, "unknown_station"
	end

	local station = nil
	for _, existingStation in pairs(profile.stationsById) do
		if existingStation.stationTypeId == stationTypeId and existingStation.placement == nil then
			station = existingStation
			break
		end
	end

	if station == nil then
		if stationTypeId == (stationService and stationService:getStarterStationTypeId() or nil) then
			station = stationService and stationService:ensureStarterStation(profile) or nil
		else
			station = stationService and stationService:createStationInstance(stationTypeId) or nil
		end
	end

	if station == nil then
		return nil, "station_unavailable"
	end

	if station.placement ~= nil then
		return nil, "station_already_placed"
	end

	local targetX = x
	local targetY = y
	if targetX == nil or targetY == nil then
		local placementTarget, placementReason = self:findFirstOpenCell(
			profile,
			stationDefinition.gridSize.width,
			stationDefinition.gridSize.height
		)
		if placementTarget == nil then
			return nil, placementReason
		end

		targetX = placementTarget.x
		targetY = placementTarget.y
	end

	profile.stationsById[station.id] = station

	local placement, reason = self:place(
		profile,
		"station",
		station.id,
		targetX,
		targetY,
		stationDefinition.gridSize.width,
		stationDefinition.gridSize.height
	)
	if placement == nil then
		if stationTypeId ~= (stationService and stationService:getStarterStationTypeId() or nil) then
			profile.stationsById[station.id] = nil
		end
		return nil, reason
	end

	station.placement = {
		plotId = placement.plotId,
		x = placement.x,
		y = placement.y,
		width = placement.width,
		height = placement.height,
	}

	return station, placement
end

function PlacementService:placeGeode(profile, geodeInstance, x, y)
	local geodeDefinition = Geodes[geodeInstance.geodeTypeId]
	if geodeDefinition == nil then
		return nil, "unknown_geode"
	end

	if geodeInstance.placement ~= nil then
		return nil, "geode_already_placed"
	end

	local gridSize = geodeDefinition.gridSize or { width = 1, height = 1 }
	local targetX = x
	local targetY = y
	if targetX == nil or targetY == nil then
		local placementTarget, placementReason = self:findFirstOpenCell(profile, gridSize.width, gridSize.height)
		if placementTarget == nil then
			return nil, placementReason
		end

		targetX = placementTarget.x
		targetY = placementTarget.y
	end

	local placement, reason = self:place(profile, "geode", geodeInstance.id, targetX, targetY, gridSize.width, gridSize.height)
	if placement == nil then
		return nil, reason
	end

	geodeInstance.placement = {
		plotId = placement.plotId,
		x = placement.x,
		y = placement.y,
		width = placement.width,
		height = placement.height,
	}

	return geodeInstance, placement
end

function PlacementService:placeResource(profile, resourceInstance, x, y)
	local resourceDefinition = Resources[resourceInstance.resourceTypeId]
	if resourceDefinition == nil then
		return nil, "unknown_resource"
	end

	if resourceInstance.placement ~= nil then
		return nil, "resource_already_placed"
	end

	local gridSize = resourceDefinition.gridSize or { width = 1, height = 1 }
	local targetX = x
	local targetY = y
	if targetX == nil or targetY == nil then
		local placementTarget, placementReason = self:findFirstOpenCell(profile, gridSize.width, gridSize.height)
		if placementTarget == nil then
			return nil, placementReason
		end

		targetX = placementTarget.x
		targetY = placementTarget.y
	end

	local placement, reason = self:place(profile, "resource", resourceInstance.id, targetX, targetY, gridSize.width, gridSize.height)
	if placement == nil then
		return nil, reason
	end

	resourceInstance.placement = {
		plotId = placement.plotId,
		x = placement.x,
		y = placement.y,
		width = placement.width,
		height = placement.height,
	}

	return resourceInstance, placement
end

function PlacementService:removeObjectByObjectId(profile, objectType, objectId)
	for placementId, record in pairs(profile.placedObjects) do
		if record.objectType == objectType and record.objectId == objectId then
			return self:remove(profile, placementId)
		end
	end

	return false, "placement_not_found"
end

function PlacementService:remove(profile, placementId)
	local record = profile.placedObjects[placementId]
	if record == nil then
		return false, "placement_not_found"
	end

	PlacementRules.clearFootprint(profile.plotState.gridOccupancy, record)

	local station = profile.stationsById[record.objectId]
	if station ~= nil and station.placement ~= nil then
		station.placement = nil
	end

	local geodeInstance = profile.geodesById[record.objectId]
	if geodeInstance ~= nil and geodeInstance.placement ~= nil then
		geodeInstance.placement = nil
	end

	local resource = profile.resourcesById[record.objectId]
	if resource ~= nil and resource.placement ~= nil then
		resource.placement = nil
	end

	profile.placedObjects[placementId] = nil
	return true
end

function PlacementService:move(profile, placementId, x, y)
	local record = profile.placedObjects[placementId]
	if record == nil then
		return nil, "placement_not_found"
	end

	PlacementRules.clearFootprint(profile.plotState.gridOccupancy, record)

	local canPlace, reason = self:canPlace(profile, x, y, record.width, record.height)
	if not canPlace then
		for dx = 0, record.width - 1 do
			for dy = 0, record.height - 1 do
				local cellKey = PlacementRules.buildOccupancyKey(record.x + dx, record.y + dy)
				profile.plotState.gridOccupancy[cellKey] = placementId
			end
		end
		return nil, reason
	end

	record.x = x
	record.y = y

	local station = profile.stationsById[record.objectId]
	if station ~= nil and station.placement ~= nil then
		station.placement.x = x
		station.placement.y = y
	end

	local geodeInstance = profile.geodesById[record.objectId]
	if geodeInstance ~= nil and geodeInstance.placement ~= nil then
		geodeInstance.placement.x = x
		geodeInstance.placement.y = y
	end

	local resource = profile.resourcesById[record.objectId]
	if resource ~= nil and resource.placement ~= nil then
		resource.placement.x = x
		resource.placement.y = y
	end

	for dx = 0, record.width - 1 do
		for dy = 0, record.height - 1 do
			local cellKey = PlacementRules.buildOccupancyKey(x + dx, y + dy)
			profile.plotState.gridOccupancy[cellKey] = placementId
		end
	end

	return record
end

function PlacementService:start()
	print("[GemFactory] PlacementService ready")
end

return PlacementService

]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="62">
          <Properties>
            <string name="Name">PlayerDataService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Player Data Service that validates requests and mutates gameplay state for this system.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local PlayerProfile = require(Shared.Types.PlayerProfile)
local TableUtil = require(Shared.Util.TableUtil)
local Time = require(Shared.Util.Time)

local PlayerDataService = {}
PlayerDataService.__index = PlayerDataService

function PlayerDataService.new(persistenceService)
	return setmetatable({
		persistenceService = persistenceService,
		activeProfiles = {},
		services = nil,
		onProfileChanged = nil,
	}, PlayerDataService)
end

function PlayerDataService:createDefaultProfile()
	return PlayerProfile.new(Time.nowUnix())
end

function PlayerDataService:loadProfile(userId)
	local userKey = tostring(userId)
	local activeProfile = self.activeProfiles[userKey]
	if activeProfile ~= nil then
		return activeProfile
	end

	local savedProfile = self.persistenceService:load(userId)
	local nowUnix = Time.nowUnix()
	local profile = if savedProfile then PlayerProfile.reconcile(savedProfile, nowUnix) else PlayerProfile.new(nowUnix)
	self.activeProfiles[userKey] = profile
	return profile
end

function PlayerDataService:getProfile(userId)
	return self.activeProfiles[tostring(userId)]
end

function PlayerDataService:getOrLoadProfile(userId)
	return self:getProfile(userId) or self:loadProfile(userId)
end

function PlayerDataService:getActiveProfiles()
	return self.activeProfiles
end

function PlayerDataService:notifyProfileChanged(userId)
	if self.onProfileChanged ~= nil then
		self.onProfileChanged(userId)
	end
end

function PlayerDataService:mutateProfile(userId, mutator)
	local profile = self:getProfile(userId)
	if profile == nil then
		return nil, "profile_not_loaded"
	end

	local result = table.pack(mutator(profile))
	return table.unpack(result, 1, result.n)
end

function PlayerDataService:saveProfile(userId)
	local profile = self:getProfile(userId)
	if profile ~= nil then
		profile.meta.lastSavedAt = Time.nowUnix()
		self.persistenceService:save(userId, profile)
	end
end

function PlayerDataService:onPlayerAdded(player)
	local profile = self:loadProfile(player.UserId)
	local services = self.services

	if services ~= nil and services.plot ~= nil then
		local plotId = services.plot:assignPlot(player.UserId)
		if plotId ~= nil then
			for _, placement in pairs(profile.placedObjects) do
				placement.plotId = plotId
			end

			for _, station in pairs(profile.stationsById) do
				if station.placement ~= nil then
					station.placement.plotId = plotId
				end
			end

			for _, geodeInstance in pairs(profile.geodesById) do
				if geodeInstance.placement ~= nil then
					geodeInstance.placement.plotId = plotId
				end
			end

			for _, resource in pairs(profile.resourcesById) do
				if resource.placement ~= nil then
					resource.placement.plotId = plotId
				end
			end

			profile.plotState.plotId = plotId
		end
	end

	if services ~= nil and services.offlineProgress ~= nil then
		local summary = services.offlineProgress:buildSummary(profile, Time.nowUnix())
		if summary ~= nil then
			profile.unclaimedOfflineRewards = summary
			profile.session.lastLogoutUnix = nil
		end
	end

	profile.session.lastPassiveTickUnix = Time.nowUnix()
	profile.session.passiveCoinRemainder = 0

	self:notifyProfileChanged(player.UserId)
end

function PlayerDataService:onPlayerRemoving(player)
	local profile = self:getProfile(player.UserId)
	if profile ~= nil then
		local nowUnix = Time.nowUnix()
		if self.services ~= nil and self.services.economy ~= nil then
			self.services.economy:flushPlayer(player.UserId, profile, nowUnix)
		end

		profile.session.lastLogoutUnix = nowUnix
		profile.session.lastPassiveTickUnix = nil
		profile.session.passiveCoinRemainder = 0
	end

	if self.services ~= nil and self.services.plot ~= nil then
		self.services.plot:releasePlot(player.UserId)
	end

	self:releaseProfile(player.UserId)
end

function PlayerDataService:releaseProfile(userId)
	self:saveProfile(userId)
	self.activeProfiles[tostring(userId)] = nil
end

function PlayerDataService:getPublicState(userId, nowUnix)
	local services = self.services
	local profile = self:getOrLoadProfile(userId)
	local currentUnix = nowUnix or Time.nowUnix()

	local publicProfile = TableUtil.deepCopy(profile)
	local shopState = nil
	local dailyState = nil
	local economyState = nil
	local geodeQueueState = nil

	if services ~= nil then
		if services.shop ~= nil then
			shopState = services.shop:getShopState(currentUnix)
		end

		if services.dailyRewards ~= nil then
			dailyState = services.dailyRewards:getClaimState(profile, currentUnix)
		end

		if services.economy ~= nil then
			economyState = services.economy:getEconomyState(profile)
		end

		if services.geodeQueue ~= nil then
			geodeQueueState = services.geodeQueue:getQueueState(profile, currentUnix)
			publicProfile.geodeQueue = TableUtil.deepCopy(geodeQueueState.entries)
		end
	end

	return {
		userId = userId,
		serverUnix = currentUnix,
		profile = publicProfile,
		economy = economyState,
		shop = shopState,
		dailyRewards = dailyState,
		geodeQueue = geodeQueueState,
		offlineRewards = TableUtil.deepCopy(profile.unclaimedOfflineRewards),
	}
end

function PlayerDataService:start(services)
	self.services = services
	Players.PlayerAdded:Connect(function(player)
		self:onPlayerAdded(player)
	end)

	Players.PlayerRemoving:Connect(function(player)
		self:onPlayerRemoving(player)
	end)

	game:BindToClose(function()
		for _, player in ipairs(Players:GetPlayers()) do
			self:onPlayerRemoving(player)
		end
	end)

	for _, player in ipairs(Players:GetPlayers()) do
		self:onPlayerAdded(player)
	end

	print("[GemFactory] PlayerDataService ready")
end

return PlayerDataService

]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="63">
          <Properties>
            <string name="Name">PlotService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Plot Service that validates requests and mutates gameplay state for this system.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local World = require(Shared.Config.World)

local PlotService = {}
PlotService.__index = PlotService

local function getPlotPosition(index)
	local plotOffset = World.plotOffsets[index]
	if plotOffset ~= nil then
		return {
			x = World.plotOrigin.x + plotOffset.x,
			y = World.plotOrigin.y,
			z = World.plotOrigin.z + plotOffset.z,
		}
	end

	local row = math.floor((index - 1) / World.plotColumns)
	local column = (index - 1) % World.plotColumns
	local horizontalStart = -(((World.plotColumns - 1) * World.plotSpacing) / 2)
	local verticalStart = -(((math.max(World.plotRows, 1) - 1) * World.plotSpacing) / 2)

	return {
		x = World.plotOrigin.x + horizontalStart + (column * World.plotSpacing),
		y = World.plotOrigin.y,
		z = World.plotOrigin.z + verticalStart + (row * World.plotSpacing),
	}
end

function PlotService.new(dependencies)
	local plots = {}
	local assignedByUserId = {}
	local assignedByPlotId = {}
	local plotsById = {}
	local totalPlots = math.min(World.plotCount, World.maxPlots)

	for index = 1, totalPlots do
		local plotId = "plot_" .. tostring(index)
		local position = getPlotPosition(index)

		plots[index] = {
			id = plotId,
			index = index,
			userId = nil,
			position = position,
		}
		plotsById[plotId] = plots[index]
	end

	return setmetatable({
		dependencies = dependencies or {},
		plots = plots,
		plotsById = plotsById,
		assignedByUserId = assignedByUserId,
		assignedByPlotId = assignedByPlotId,
	}, PlotService)
end

function PlotService:assignPlot(userId)
	local userKey = tostring(userId)
	local existingPlotId = self.assignedByUserId[userKey]
	if existingPlotId ~= nil then
		return existingPlotId
	end

	for _, plot in ipairs(self.plots) do
		if plot.userId == nil then
			plot.userId = userId
			self.assignedByUserId[userKey] = plot.id
			self.assignedByPlotId[plot.id] = plot
			return plot.id
		end
	end

	return nil, "plot_limit_reached"
end

function PlotService:releasePlot(userId)
	local userKey = tostring(userId)
	local plotId = self.assignedByUserId[userKey]
	if plotId == nil then
		return false, "plot_not_assigned"
	end

	local plot = self.assignedByPlotId[plotId]
	if plot ~= nil then
		plot.userId = nil
	end

	self.assignedByUserId[userKey] = nil
	self.assignedByPlotId[plotId] = nil
	return true
end

function PlotService:getPlotLimit()
	return #self.plots
end

function PlotService:getPlotById(plotId)
	return self.plotsById[plotId]
end

function PlotService:getPlotForUserId(userId)
	local plotId = self.assignedByUserId[tostring(userId)]
	if plotId == nil then
		return nil
	end

	return self.plotsById[plotId]
end

function PlotService:getAllPlots()
	return self.plots
end

function PlotService:getPlotWorldPosition(plotId)
	local plot = self:getPlotById(plotId)
	if plot == nil then
		return nil
	end

	return plot.position
end

function PlotService:start()
	print("[GemFactory] PlotService ready")
end

return PlotService

]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="64">
          <Properties>
            <string name="Name">ShopService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Shop Service that validates requests and mutates gameplay state for this system.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Shops = require(Shared.Config.Shops)
local ShopRotation = require(Shared.Domain.ShopRotation)
local TableUtil = require(Shared.Util.TableUtil)

local ShopService = {}
ShopService.__index = ShopService

function ShopService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
	}, ShopService)
end

function ShopService:getHourlyOffer(nowUnix)
	local offers = Shops.hourlyRotation
	local state = ShopRotation.getHourlyState(nowUnix, #offers)
	return offers[state.index], state.index, state.secondsRemaining
end

function ShopService:getOffer(offerId, nowUnix)
	for _, offer in ipairs(Shops.starterOffers) do
		if offer.offerId == offerId then
			local copy = TableUtil.deepCopy(offer)
			copy.source = "starter"
			return copy
		end
	end

	local hourlyOffer, hourlyIndex, secondsRemaining = self:getHourlyOffer(nowUnix)
	if hourlyOffer ~= nil and hourlyOffer.offerId == offerId then
		local copy = TableUtil.deepCopy(hourlyOffer)
		copy.source = "hourly"
		copy.rotationIndex = hourlyIndex
		copy.secondsRemaining = secondsRemaining
		return copy
	end

	return nil
end

function ShopService:getShopState(nowUnix)
	local hourlyOffer, hourlyIndex, secondsRemaining = self:getHourlyOffer(nowUnix)
	local currentHourlyOffer = nil
	if hourlyOffer ~= nil then
		currentHourlyOffer = TableUtil.deepCopy(hourlyOffer)
		currentHourlyOffer.source = "hourly"
		currentHourlyOffer.rotationIndex = hourlyIndex
		currentHourlyOffer.secondsRemaining = secondsRemaining
	end

	return {
		starterOffer = TableUtil.deepCopy(Shops.starterOffers[1]),
		currentOffer = currentHourlyOffer,
		offerIndex = hourlyIndex,
		secondsRemaining = secondsRemaining,
	}
end

function ShopService:start()
	print("[GemFactory] ShopService ready")
end

return ShopService

]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="65">
          <Properties>
            <string name="Name">StationService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Station Service that validates requests and mutates gameplay state for this system.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Stations = require(Shared.Config.Stations)
local StationAssignment = require(Shared.Domain.StationAssignment)
local World = require(Shared.Config.World)
local Id = require(Shared.Util.Id)

local StationService = {}
StationService.__index = StationService

function StationService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
	}, StationService)
end

function StationService:getDefinition(stationTypeId)
	return Stations[stationTypeId]
end

function StationService:getStarterStationTypeId()
	return World.starterStationTypeId
end

function StationService:getStarterStation(profile)
	for _, station in pairs(profile.stationsById) do
		if station.stationTypeId == self:getStarterStationTypeId() then
			return station
		end
	end

	return nil
end

function StationService:createStationInstance(stationTypeId)
	local stationDefinition = self:getDefinition(stationTypeId)
	if stationDefinition == nil then
		return nil, "unknown_station"
	end

	return {
		id = Id.new("station"),
		stationTypeId = stationTypeId,
		level = 1,
		occupantIds = {},
		placement = nil,
	}, nil
end

function StationService:grantStarterStation(profile)
	local existingStarter = self:getStarterStation(profile)
	if existingStarter ~= nil then
		return existingStarter
	end

	local starterTypeId = self:getStarterStationTypeId()
	local station = self:createStationInstance(starterTypeId)
	if station == nil then
		return nil, "starter_station_missing"
	end

	profile.stationsById[station.id] = station
	return station
end

function StationService:ensureStarterStation(profile)
	return self:grantStarterStation(profile)
end

function StationService:autoAssignResources(profile, resourceIds)
	return StationAssignment.autoAssignResources(profile, Stations, resourceIds)
end

function StationService:assignResource(profile, resourceId, stationId)
	return StationAssignment.assignResourceToStation(profile, Stations, resourceId, stationId)
end

function StationService:getTemplate(stationTypeId)
	return self:getDefinition(stationTypeId)
end

function StationService:start()
	print("[GemFactory] StationService ready")
end

return StationService

]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="66">
          <Properties>
            <string name="Name">VaultService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-authoritative service for Vault Service that validates requests and mutates gameplay state for this system.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Geodes = require(Shared.Config.Geodes)
local Resources = require(Shared.Config.Resources)
local Traits = require(Shared.Config.Traits)
local GeodeState = require(Shared.Domain.GeodeState)
local SizeRules = require(Shared.Domain.SizeRules)
local VaultMath = require(Shared.Domain.VaultMath)

local VaultService = {}
VaultService.__index = VaultService

local function removeFromOrder(order, id)
	-- Orders are stored as arrays for stable UI/world presentation, so removals have to
	-- preserve relative order instead of rebuilding the whole list from a dictionary.
	for index = #order, 1, -1 do
		if order[index] == id then
			table.remove(order, index)
			return
		end
	end
end

local function adjustGeodeInventory(profile, geodeTypeId, delta)
	local current = profile.inventory.geodes[geodeTypeId] or 0
	profile.inventory.geodes[geodeTypeId] = math.max(0, current + delta)
end

function VaultService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
	}, VaultService)
end

function VaultService:getResourceSellValue(resource)
	local resourceDefinition = resource ~= nil and Resources[resource.resourceTypeId] or nil
	local traitDefinition = resource ~= nil and Traits[resource.traitId or "none"] or Traits.none
	local sizeDefinition = if resource ~= nil then SizeRules.resolveDefinition(resource.sizeId, resource.sizeValue) else nil
	return VaultMath.getResourceSellValue(resourceDefinition, traitDefinition, sizeDefinition)
end

function VaultService:getGeodeSellValue(geode)
	local geodeDefinition = geode ~= nil and Geodes[geode.geodeTypeId] or nil
	return VaultMath.getGeodeSellValue(geodeDefinition)
end

function VaultService:placeResource(userId, resourceId, x, y)
	local playerData = self.dependencies.playerData
	local placementService = self.dependencies.placementService
	if placementService == nil then
		return nil, "placement_unavailable"
	end

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		local resource = currentProfile.resourcesById[resourceId]
		if resource == nil then
			return nil, "unknown_resource_instance"
		end

		if resource.stationId ~= nil then
			return nil, "resource_assigned_to_station"
		end

		local placedResource, placementOrReason = placementService:placeResource(currentProfile, resource, x, y)
		if placedResource == nil or placementOrReason == nil then
			return nil, placementOrReason or "resource_placement_failed"
		end

		result = {
			resource = placedResource,
			placement = placementOrReason,
		}
		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function VaultService:pickupResource(userId, resourceId)
	local playerData = self.dependencies.playerData
	local placementService = self.dependencies.placementService
	if placementService == nil then
		return nil, "placement_unavailable"
	end

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		local resource = currentProfile.resourcesById[resourceId]
		if resource == nil then
			return nil, "unknown_resource_instance"
		end

		if resource.stationId ~= nil then
			return nil, "resource_assigned_to_station"
		end

		if resource.placement == nil then
			return nil, "resource_not_placed"
		end

		-- Vault pickup is authoritative on the server because the plot footprint has to be
		-- cleared in lockstep with the resource's placement field to avoid ghost occupancy.
		local removed, removeReason = placementService:removeObjectByObjectId(currentProfile, "resource", resource.id)
		if not removed then
			return nil, removeReason or "resource_pickup_failed"
		end

		result = {
			resource = resource,
		}
		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function VaultService:sellResource(userId, resourceId)
	local playerData = self.dependencies.playerData
	local placementService = self.dependencies.placementService

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		local resource = currentProfile.resourcesById[resourceId]
		if resource == nil then
			return nil, "unknown_resource_instance"
		end

		local sellValue = self:getResourceSellValue(resource)
		if sellValue <= 0 then
			return nil, "resource_not_sellable"
		end

		if resource.stationId ~= nil then
			local station = currentProfile.stationsById[resource.stationId]
			if station ~= nil and station.occupantIds ~= nil then
				-- Selling a station occupant must clear the station order as well as the vault copy,
				-- otherwise passive-income state would still point at a deleted resource id.
				removeFromOrder(station.occupantIds, resource.id)
			end
		end

		if placementService ~= nil then
			-- World placement is derived from profile state, so the placement footprint has to be
			-- cleared before the resource is removed from the authoritative profile tables.
			placementService:removeObjectByObjectId(currentProfile, "resource", resource.id)
		end

		currentProfile.resourcesById[resource.id] = nil
		removeFromOrder(currentProfile.resourceOrder, resource.id)
		currentProfile.currencies.coins += sellValue

		result = {
			resourceId = resource.id,
			coins = sellValue,
		}
		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function VaultService:sellGeode(userId, geodeInstanceId)
	local playerData = self.dependencies.playerData
	local placementService = self.dependencies.placementService

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		local geode = currentProfile.geodesById[geodeInstanceId]
		if geode == nil then
			return nil, "unknown_geode_instance"
		end

		local sellValue = self:getGeodeSellValue(geode)
		if sellValue <= 0 then
			return nil, "geode_not_sellable"
		end

		if placementService ~= nil then
			-- Selling a placed geode must clear its occupied cells before the geode leaves
			-- profile state, otherwise later placement checks would think the plot is blocked.
			placementService:removeObjectByObjectId(currentProfile, "geode", geode.id)
		end

		adjustGeodeInventory(currentProfile, geode.geodeTypeId, -1)
		GeodeState.removeGeode(currentProfile.geodesById, currentProfile.geodeOrder, geode.id)
		currentProfile.currencies.coins += sellValue

		result = {
			geodeInstanceId = geode.id,
			coins = sellValue,
		}
		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function VaultService:start()
	print("[GemFactory] VaultService ready")
end

return VaultService
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="67">
          <Properties>
            <string name="Name">WorldReplicaService</string>
            <string name="Source"><![CDATA[--!strict

-- Server-owned world projection service that turns authoritative profile and plot state
-- into static workspace models for plots, mine/shop set dressing, geodes, resources, and
-- other replicated presentation without moving gameplay ownership out of server code.

local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Geodes = require(Shared.Config.Geodes)
local Resources = require(Shared.Config.Resources)
local Traits = require(Shared.Config.Traits)
local GeodePresentation = require(Shared.Domain.GeodePresentation)
local ResourceVisuals = require(Shared.Domain.ResourceVisuals)
local SizeRules = require(Shared.Domain.SizeRules)
local WorldLabelPresentation = require(Shared.Domain.WorldLabelPresentation)
local Stations = require(Shared.Config.Stations)
local World = require(Shared.Config.World)

local WorldReplicaService = {}
WorldReplicaService.__index = WorldReplicaService

local SHARED_FLOOR_NAME = "SharedFloor"
local PLOT_MARKER_FOLDER_NAME = "PlotMarkers"
local SHOP_FRONT_NAME = "PickaxeShop"
local MINE_NAME = "GeodeMine"
local VAULT_FRONT_NAME = "VaultStation"
local WORLD_SHELL_NAME = "WorldShell"
local SKY_DECOR_NAME = "SkyDecor"
local PLAYER_CALLOUT_FOLDER_NAME = "GemFactoryWorldCallouts"
local SHOP_PROMPT_ATTRIBUTE = "GemFactoryShopPrompt"
local VAULT_PROMPT_ATTRIBUTE = "GemFactoryVaultPrompt"
local MINE_TARGET_ATTRIBUTE = "GemFactoryMineTarget"
local MINE_ZONE_ATTRIBUTE = "GemFactoryMineZone"
local STATIC_WORLD_LAYOUT_VERSION = 7
local PLOT_SURFACE_COLLIDER_NAME = "PlotSurfaceCollider"
local REPLICA_TRANSPARENCY_ATTRIBUTE = "ReplicaTransparency"
local PLOT_SURFACE_OFFSET_Y = 1.2
local PLOT_SURFACE_HEIGHT = 0.4
local PLOT_LAYOUT_VERSION = 3
local PLOT_STAND_CAP_HEIGHT = 0.55
local PLOT_STAND_CAP_CLEARANCE = 0.06
local PLOT_STAND_SUPPORT_HEIGHT = 0.9
local PLOT_STAND_SUPPORT_GAP = 0.08
local PLOT_STAND_LIP_HEIGHT = 0.18
local PLOT_STAND_LIP_GAP = 0.02
local PLOT_STAND_MARKER_HEIGHT = 2.2
local PLOT_STAND_MARKER_INSET = 2.6
local MINE_CALLOUT_ANCHOR_NAME = "MineCalloutAnchor"
local SHOP_CALLOUT_ANCHOR_NAME = "ShopCalloutAnchor"
local SHOP_PROMPT_ANCHOR_NAME = "ShopPromptAnchor"

local ROCK_VARIANTS = {
	{
		{ x = -28, z = -26, height = 10, radius = 3.5, yaw = 8 },
		{ x = 30, z = -18, height = 6, radius = 2.25, yaw = 28 },
		{ x = -18, z = 30, height = 8, radius = 2.75, yaw = -18 },
		{ x = 26, z = 28, height = 4, radius = 4.5, yaw = 14, kind = "boulder" },
		{ x = -32, z = 8, height = 3, radius = 5, yaw = -10, kind = "boulder" },
	},
	{
		{ x = 27, z = -28, height = 11, radius = 3.25, yaw = -12 },
		{ x = -31, z = 14, height = 7, radius = 2.5, yaw = 34 },
		{ x = 18, z = 29, height = 5, radius = 2.25, yaw = -24 },
		{ x = -24, z = -31, height = 4, radius = 4.75, yaw = 19, kind = "boulder" },
		{ x = 32, z = 10, height = 3, radius = 4.5, yaw = -24, kind = "boulder" },
	},
	{
		{ x = -30, z = -6, height = 9, radius = 3, yaw = 22 },
		{ x = 26, z = 24, height = 7, radius = 2.5, yaw = -30 },
		{ x = -8, z = 31, height = 5, radius = 2.25, yaw = 14 },
		{ x = -29, z = -29, height = 4, radius = 4.25, yaw = -18, kind = "boulder" },
		{ x = 30, z = -12, height = 3, radius = 4.75, yaw = 26, kind = "boulder" },
	},
	{
		{ x = 31, z = 8, height = 10, radius = 3.25, yaw = 16 },
		{ x = -25, z = -29, height = 6, radius = 2.5, yaw = -26 },
		{ x = 12, z = -31, height = 8, radius = 2.75, yaw = 10 },
		{ x = 28, z = 29, height = 4, radius = 4.5, yaw = -12, kind = "boulder" },
		{ x = -30, z = -4, height = 3, radius = 4.75, yaw = 20, kind = "boulder" },
	},
}

function WorldReplicaService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
		records = {},
		models = {},
		signatures = {},
		running = false,
	}, WorldReplicaService)
end

local function ensureWorldFolder()
	local worldFolder = Workspace:FindFirstChild(World.worldFolderName)
	if worldFolder == nil then
		worldFolder = Instance.new("Folder")
		worldFolder.Name = World.worldFolderName
		worldFolder.Parent = Workspace
	end

	local plotFolder = worldFolder:FindFirstChild(World.plotFolderName)
	if plotFolder == nil then
		plotFolder = Instance.new("Folder")
		plotFolder.Name = World.plotFolderName
		plotFolder.Parent = worldFolder
	end

	return worldFolder, plotFolder
end

local function clearChildren(container)
	for _, child in ipairs(container:GetChildren()) do
		child:Destroy()
	end
end

local function getPlayerRootPart(player: Player): BasePart?
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if root ~= nil and root:IsA("BasePart") then
		return root
	end

	return nil
end

local function isPositionInsidePart(position: Vector3, part: BasePart): boolean
	local localPosition = part.CFrame:PointToObjectSpace(position)
	local halfSize = part.Size / 2
	return math.abs(localPosition.X) <= halfSize.X
		and math.abs(localPosition.Y) <= halfSize.Y
		and math.abs(localPosition.Z) <= halfSize.Z
end

local function getPlotHalfSize()
	return World.plotBaseSize.width / 2, World.plotBaseSize.depth / 2
end

local function getSharedFloorSize()
	local sharedBaseplateSize = World.sharedBaseplateSize
	if sharedBaseplateSize ~= nil then
		return sharedBaseplateSize.width, sharedBaseplateSize.height, sharedBaseplateSize.depth
	end

	local padding = World.sharedFloorPadding or 32
	return
		(World.plotColumns * World.plotSpacing) + World.plotBaseSize.width + padding,
		2,
		(math.max(World.plotRows or 1, 1) * World.plotSpacing) + World.plotBaseSize.depth + padding
end

