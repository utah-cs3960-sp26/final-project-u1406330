        <Item class="ModuleScript" referent="44">
          <Properties>
            <string name="Name">GeodeQueueService</string>
            <string name="Source"><![CDATA[--!strict

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local GeodeState = require(Shared.Domain.GeodeState)
local Resources = require(Shared.Config.Resources)
local Traits = require(Shared.Config.Traits)

local GeodeQueueService = {}
GeodeQueueService.__index = GeodeQueueService

function GeodeQueueService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
	}, GeodeQueueService)
end

function GeodeQueueService:timeRemaining(entry, nowUnix)
	return math.max(0, entry.endsAt - nowUnix)
end

function GeodeQueueService:syncQueueCache(profile, nowUnix)
	GeodeState.refreshStatuses(profile.geodesById, profile.geodeOrder, nowUnix)
	profile.geodeQueue = GeodeState.buildQueueEntries(profile.geodesById, profile.geodeOrder, nowUnix)
	return profile.geodeQueue
end

function GeodeQueueService:getClaimableEntries(profile, nowUnix, geodeId)
	self:syncQueueCache(profile, nowUnix)

	local claimable = {}
	for _, geodeInstanceId in ipairs(GeodeState.getClaimableIds(profile, nowUnix, geodeId)) do
		local geodeInstance = profile.geodesById[geodeInstanceId]
		if geodeInstance ~= nil then
			table.insert(claimable, GeodeState.toQueueEntry(geodeInstance, nowUnix))
		end
	end

	return claimable
end

function GeodeQueueService:openGeode(profile, nowUnix, rng, geodeId, playerName)
	return self:claimEntries(profile, nowUnix, rng, geodeId, playerName)
end

local function shouldAnnounceResource(resource)
	local resourceDefinition = Resources[resource.resourceTypeId]
	if resourceDefinition == nil then
		return false
	end

	if resource.traitId ~= nil and resource.traitId ~= "none" then
		return true
	end

	local rarity = resourceDefinition.rarity
	return rarity == "Rare" or rarity == "Epic" or rarity == "Legendary"
end

local function getTraitLabel(traitId)
	if traitId == nil then
		return "none"
	end

	local traitDefinition = Traits[traitId]
	if traitDefinition ~= nil then
		return traitDefinition.displayName
	end

	return traitId
end

function GeodeQueueService:getQueueState(profile, nowUnix)
	local queueEntries = self:syncQueueCache(profile, nowUnix)
	local queuedCount = 0
	local finishedCount = 0
	local nextReadyUnix = nil
	local entries = {}

	for _, entry in ipairs(queueEntries) do
		local remaining = self:timeRemaining(entry, nowUnix)
		local entryState = {
			id = entry.id,
			geodeId = entry.geodeId,
			status = entry.status,
			remainingSeconds = remaining,
			endsAt = entry.endsAt,
			isPlaced = profile.geodesById[entry.id] ~= nil and profile.geodesById[entry.id].placement ~= nil,
		}

		table.insert(entries, entryState)

		if entry.status == "finished" then
			finishedCount += 1
		elseif remaining > 0 then
			queuedCount += 1
			if nextReadyUnix == nil or entry.endsAt < nextReadyUnix then
				nextReadyUnix = entry.endsAt
			end
		else
			finishedCount += 1
		end
	end

	return {
		queuedCount = queuedCount,
		finishedCount = finishedCount,
		nextReadyUnix = nextReadyUnix,
		entries = entries,
	}
end

function GeodeQueueService:claimEntries(profile, nowUnix, rng, geodeId, playerName)
	local claimableEntries = self:getClaimableEntries(profile, nowUnix, geodeId)
	if #claimableEntries == 0 then
		return nil, "no_ready_geodes"
	end

	local geodeService = self.dependencies.geodeService
	local placementService = self.dependencies.placementService
	local rareAnnouncementService = self.dependencies.rareAnnouncementService
	if geodeService == nil then
		return nil, "open_unavailable"
	end
	local createdResources = {}
	local createdResourceIds = {}
	for _, entry in ipairs(claimableEntries) do
		local geodeInstance = profile.geodesById[entry.id]
		if geodeInstance ~= nil then
			local resource, errorCode = geodeService:createResourceInstance(geodeInstance.geodeTypeId, nowUnix, rng)
			if resource ~= nil then
				profile.resourcesById[resource.id] = resource
				table.insert(profile.resourceOrder, resource.id)
				table.insert(createdResources, resource)
				table.insert(createdResourceIds, resource.id)
				if placementService ~= nil then
					placementService:removeObjectByObjectId(profile, "geode", geodeInstance.id)
				end
				GeodeState.removeGeode(profile.geodesById, profile.geodeOrder, geodeInstance.id)
				if rareAnnouncementService ~= nil and shouldAnnounceResource(resource) then
					local resourceDefinition = Resources[resource.resourceTypeId]
					rareAnnouncementService:announce(
						playerName or "Miner",
						resourceDefinition and resourceDefinition.displayName or resource.resourceTypeId,
						getTraitLabel(resource.traitId)
					)
				end
			else
				warn("[GemFactory] Failed to resolve geode", geodeInstance.geodeTypeId, errorCode)
			end
		end
	end

	local stationService = self.dependencies.stationService
	local autoAssignment = nil
	if stationService ~= nil and #createdResourceIds > 0 then
		autoAssignment = stationService:autoAssignResources(profile, createdResourceIds)
	end

	self:syncQueueCache(profile, nowUnix)

	return {
		claimedEntries = claimableEntries,
		createdResources = createdResources,
		createdResourceIds = createdResourceIds,
		autoAssignment = autoAssignment,
	}
end

function GeodeQueueService:start()
	print("[GemFactory] GeodeQueueService ready")
end

return GeodeQueueService


]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="45">
          <Properties>
            <string name="Name">GeodeService</string>
            <string name="Source"><![CDATA[--!strict

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Resources = require(Shared.Config.Resources)
local Geodes = require(Shared.Config.Geodes)
local Traits = require(Shared.Config.Traits)
local GeodeState = require(Shared.Domain.GeodeState)
local GeodeRoller = require(Shared.Domain.GeodeRoller)
local TraitRoller = require(Shared.Domain.TraitRoller)
local Id = require(Shared.Util.Id)
local Time = require(Shared.Util.Time)

local GeodeService = {}
GeodeService.__index = GeodeService

local function getTraitPool()
	return {
		Traits.none,
		Traits.flawless,
		Traits.prismatic,
		Traits.celestial,
		Traits.radiant,
		Traits.void_touched,
	}
end

local function getCurrencyAmount(profile, currency)
	if currency == "coins" then
		return profile.currencies.coins
	elseif currency == "gems" then
		return profile.currencies.gems
	elseif currency == "eventTokens" then
		return profile.currencies.eventTokens
	end

	return nil
end

local function spendCurrency(profile, currency, amount)
	if amount <= 0 then
		return true
	end

	if currency == "coins" then
		if profile.currencies.coins < amount then
			return false, "insufficient_coins"
		end
		profile.currencies.coins -= amount
		return true
	elseif currency == "gems" then
		if profile.currencies.gems < amount then
			return false, "insufficient_gems"
		end
		profile.currencies.gems -= amount
		return true
	elseif currency == "eventTokens" then
		if profile.currencies.eventTokens < amount then
			return false, "insufficient_tokens"
		end
		profile.currencies.eventTokens -= amount
		return true
	end

	return false, "unsupported_currency"
end

local function adjustInventoryCount(profile, geodeId, delta)
	local inventory = profile.inventory
	local currentCount = inventory.geodes[geodeId] or 0
	local nextCount = math.max(0, currentCount + delta)
	inventory.geodes[geodeId] = nextCount
	return nextCount
end

function GeodeService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
	}, GeodeService)
end

function GeodeService:getDefinition(geodeId)
	return Geodes[geodeId]
end

function GeodeService:adjustInventoryCount(profile, geodeId, delta)
	return adjustInventoryCount(profile, geodeId, delta)
end

function GeodeService:createGeodeInstance(profile, geodeId, nowUnix)
	local geodeDefinition = Geodes[geodeId]
	if geodeDefinition == nil then
		return nil, "unknown_geode"
	end

	local geodeInstance = GeodeState.createInstance(Id.new("geode"), geodeId, nowUnix, geodeDefinition.geodeSeconds)
	profile.geodesById[geodeInstance.id] = geodeInstance
	table.insert(profile.geodeOrder, geodeInstance.id)
	adjustInventoryCount(profile, geodeId, 1)
	return geodeInstance
end

function GeodeService:buyGeode(userId, geodeId, nowUnix, rng)
	local playerData = self.dependencies.playerData
	local shopService = self.dependencies.shopService
	local profile = playerData:getOrLoadProfile(userId)
	if profile == nil then
		return nil, "profile_not_loaded"
	end

	local geodeDefinition = Geodes[geodeId]
	if geodeDefinition == nil then
		return nil, "unknown_geode"
	end

	local offer = shopService:getOffer(geodeId, nowUnix)
	if offer == nil then
		return nil, "offer_unavailable"
	end

	local balance = getCurrencyAmount(profile, offer.currency)
	if balance == nil then
		return nil, "unsupported_currency"
	end

	if balance < offer.price then
		return nil, "insufficient_funds"
	end

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		local spent, spendError = spendCurrency(currentProfile, offer.currency, offer.price)
		if not spent then
			return nil, spendError
		end

		local geodeInstance, geodeError = self:createGeodeInstance(currentProfile, geodeId, nowUnix)
		if geodeInstance == nil then
			return nil, geodeError
		end

		result = {
			offer = offer,
			geodeEntry = GeodeState.toQueueEntry(geodeInstance, nowUnix),
			geodeInstance = geodeInstance,
			inventoryCount = currentProfile.inventory.geodes[geodeId] or 0,
		}

		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function GeodeService:placeGeode(userId, geodeInstanceId, x, y)
	local playerData = self.dependencies.playerData
	local placementService = self.dependencies.placementService
	if placementService == nil then
		return nil, "placement_unavailable"
	end

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		local geodeInstance = currentProfile.geodesById[geodeInstanceId]
		if geodeInstance == nil then
			return nil, "unknown_geode_instance"
		end

		local placedGeode, placementOrReason = placementService:placeGeode(currentProfile, geodeInstance, x, y)
		if placedGeode == nil or placementOrReason == nil then
			return nil, placementOrReason or "geode_placement_failed"
		end

		adjustInventoryCount(currentProfile, geodeInstance.geodeTypeId, -1)

		result = {
			geodeInstance = placedGeode,
			placement = placementOrReason,
		}

		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function GeodeService:openGeode(userId, geodeInstanceId, nowUnix, rng, playerName)
	local playerData = self.dependencies.playerData
	local geodeQueueService = self.dependencies.geodeQueueService
	if geodeQueueService == nil then
		return nil, "open_unavailable"
	end

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		result = geodeQueueService:openGeode(currentProfile, nowUnix, rng, geodeInstanceId, playerName)
		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function GeodeService:createResourceInstance(geodeId, nowUnix, rng)
	local geodeDefinition = Geodes[geodeId]
	if geodeDefinition == nil then
		return nil, "unknown_geode"
	end

	local resourceRoll = GeodeRoller.rollGeode(geodeDefinition, rng)
	if resourceRoll == nil then
		return nil, "invalid_roll"
	end

	local traitRoll = TraitRoller.rollTrait(getTraitPool(), rng)
	local resourceDefinition = Resources[resourceRoll.resourceId]
	if resourceDefinition == nil then
		return nil, "unknown_resource"
	end

	return {
		id = Id.new("resource"),
		resourceTypeId = resourceDefinition.id,
		traitId = traitRoll and traitRoll.id or "none",
		level = 1,
		stationId = nil,
		obtainedAt = nowUnix,
	}
end

function GeodeService:createRewardResourceInstance(resourceId, nowUnix)
	local resourceDefinition = Resources[resourceId]
	if resourceDefinition == nil then
		return nil, "unknown_resource"
	end

	return {
		id = Id.new("resource"),
		resourceTypeId = resourceDefinition.id,
		traitId = "none",
		level = 1,
		stationId = nil,
		obtainedAt = nowUnix,
	}
end

function GeodeService:resolveGeode(geodeId, rng)
	return self:createResourceInstance(geodeId, Time.nowUnix(), rng)
end

function GeodeService:start()
	print("[GemFactory] GeodeService ready")
end

return GeodeService



]]></string>
