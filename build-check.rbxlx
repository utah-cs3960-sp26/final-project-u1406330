        </Item>
        <Item class="ModuleScript" referent="44">
          <Properties>
            <string name="Name">MockPersistenceService</string>
            <string name="Source"><![CDATA[--!strict

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local TableUtil = require(Shared.Util.TableUtil)

local MockPersistenceService = {}
MockPersistenceService.__index = MockPersistenceService

function MockPersistenceService.new()
	return setmetatable({
		store = {},
		seeds = {},
	}, MockPersistenceService)
end

function MockPersistenceService:load(userId)
	local userKey = tostring(userId)
	local stored = self.store[userKey]
	if stored ~= nil then
		return TableUtil.deepCopy(stored)
	end

	local seed = self.seeds[userKey]
	if seed ~= nil then
		return TableUtil.deepCopy(seed)
	end

	return nil
end

function MockPersistenceService:save(userId, profile)
	self.store[tostring(userId)] = TableUtil.deepCopy(profile)
end

function MockPersistenceService:seed(userId, profile)
	self.seeds[tostring(userId)] = TableUtil.deepCopy(profile)
end

function MockPersistenceService:reset()
	table.clear(self.store)
	table.clear(self.seeds)
end

function MockPersistenceService:start()
	print("[GemFactory] MockPersistenceService ready")
end

return MockPersistenceService

]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="45">
          <Properties>
            <string name="Name">OfflineProgressService</string>
            <string name="Source"><![CDATA[--!strict

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local EconomyConfig = require(Shared.Config.Economy)
local OfflineMath = require(Shared.Domain.OfflineMath)
local Time = require(Shared.Util.Time)

local OfflineProgressService = {}
OfflineProgressService.__index = OfflineProgressService

function OfflineProgressService.new(dependencies)
	return setmetatable({
		dependencies = dependencies or {},
	}, OfflineProgressService)
end

function OfflineProgressService:buildSummary(profile, nowUnix)
	local passiveRate = self.dependencies.economyService:getPassiveRate(profile)
	local geodeQueueService = self.dependencies.geodeQueueService
	local summary = OfflineMath.buildSummary(
		profile.session.lastLogoutUnix,
		nowUnix,
		passiveRate,
		EconomyConfig.offlineCapSeconds
	)

	if summary == nil then
		return nil
	end

	local claimableEntries = if geodeQueueService ~= nil then geodeQueueService:getClaimableEntries(profile, nowUnix) else {}
	summary.finishedGeodes = {}
	for _, entry in ipairs(claimableEntries) do
		table.insert(summary.finishedGeodes, entry.id)
	end
	return summary
end

function OfflineProgressService:claimOfflineRewards(userId, nowUnix, rng, playerName)
	local playerData = self.dependencies.playerData
	local geodeQueueService = self.dependencies.geodeQueueService
	local profile = playerData:getOrLoadProfile(userId)
	if profile == nil then
		return nil, "profile_not_loaded"
	end

	local currentUnix = nowUnix or Time.nowUnix()
	local summary = profile.unclaimedOfflineRewards or self:buildSummary(profile, currentUnix)
	if summary == nil then
		return nil, "no_offline_rewards"
	end

	local result
	local _, mutateError = playerData:mutateProfile(userId, function(currentProfile)
		currentProfile.currencies.coins += summary.coins
		local geodeResult = geodeQueueService:claimEntries(currentProfile, currentUnix, rng, nil, playerName)

		currentProfile.unclaimedOfflineRewards = nil
		currentProfile.session.lastLogoutUnix = nil

		result = {
			summary = summary,
			reveals = geodeResult,
		}

		return result
	end)

	if result ~= nil then
		playerData:notifyProfileChanged(userId)
	end

	if result == nil and mutateError ~= nil then
		return nil, mutateError
	end

	return result
end

function OfflineProgressService:start()
	print("[GemFactory] OfflineProgressService ready")
end

return OfflineProgressService



]]></string>
