		"Legendary",
		"Storm",
		"Ancient",
		"Prismatic",
		"Sovereign",
	}

	for index, rarityName in ipairs(rarityNames) do
		local rarityChip = Instance.new("TextLabel")
		rarityChip.Name = string.format("Rarity%d", index)
